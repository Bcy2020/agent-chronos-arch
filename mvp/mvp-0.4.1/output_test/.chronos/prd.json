{
  "metadata": {
    "project_name": "Personal Task Manager",
    "project_id": "com.example.taskmanager",
    "version": "1.0.0"
  },
  "functional_requirements": [
    {
      "fr_id": "FR-001",
      "title": "Task Creation",
      "description": "Users can create a new task with a title and optional description. Each task gets a unique auto-incremented ID, status set to 'pending', and a creation timestamp.",
      "priority": "high",
      "related_nfr_ids": [],
      "depends_on": []
    },
    {
      "fr_id": "FR-002",
      "title": "Task Listing",
      "description": "Users can list all tasks, optionally filtered by status (pending/completed/all). Output shows task ID, title, status, and creation time.",
      "priority": "high",
      "related_nfr_ids": [],
      "depends_on": []
    },
    {
      "fr_id": "FR-003",
      "title": "Task Completion",
      "description": "Users can mark a task as completed by its ID. Must validate that the task exists and return success/error message.",
      "priority": "high",
      "related_nfr_ids": [],
      "depends_on": [
        "FR-001"
      ]
    },
    {
      "fr_id": "FR-004",
      "title": "Task Deletion",
      "description": "Users can delete a task by its ID. Must validate that the task exists and return success/error message.",
      "priority": "high",
      "related_nfr_ids": [],
      "depends_on": [
        "FR-001"
      ]
    }
  ],
  "non_functional_requirements": [
    {
      "nfr_id": "NFR-001",
      "category": "usability",
      "description": "Clean, readable code structure."
    },
    {
      "nfr_id": "NFR-002",
      "category": "reliability",
      "description": "Error handling for invalid inputs."
    }
  ],
  "acceptance_criteria": [
    {
      "ac_id": "AC-001",
      "description": "All CRUD operations work correctly.",
      "verification_method": "automated_test",
      "related_fr_ids": [
        "FR-001",
        "FR-002",
        "FR-003",
        "FR-004"
      ]
    },
    {
      "ac_id": "AC-002",
      "description": "Error handling for invalid inputs.",
      "verification_method": "automated_test",
      "related_fr_ids": [
        "FR-001",
        "FR-002",
        "FR-003",
        "FR-004"
      ]
    },
    {
      "ac_id": "AC-003",
      "description": "Clean, readable code structure.",
      "verification_method": "manual_review",
      "related_fr_ids": [
        "FR-001",
        "FR-002",
        "FR-003",
        "FR-004"
      ]
    }
  ],
  "technical_constraints": {
    "storage": {
      "type": "memory",
      "details": "In-memory storage, no database persistence."
    },
    "concurrency": {
      "model": "single-user",
      "auth_required": false
    },
    "ui": {
      "type": "cli"
    },
    "language": "Python"
  },
  "glossary": {
    "task": "A unit of work with a title, description, status, and creation timestamp.",
    "status": "The state of a task: 'pending' or 'completed'."
  },
  "global_state_sources": [
    {
      "source_id": "tasks",
      "type": "list",
      "description": "List of all tasks stored in memory.",
      "initial_state": [],
      "item_schema": {
        "id": "integer",
        "title": "string",
        "description": "string",
        "status": "string",
        "created_at": "datetime"
      }
    },
    {
      "source_id": "next_id",
      "type": "dict",
      "description": "Counter for auto-incrementing task IDs.",
      "initial_state": {
        "value": 1
      },
      "item_schema": {
        "value": "integer"
      }
    }
  ],
  "input_spec": {
    "format": "json",
    "description": "Input is a JSON object with command and task_data fields.",
    "schema": {
      "command": "string (create, list, complete, delete)",
      "task_data": "optional dict with title, description, task_id, status_filter"
    },
    "examples": [
      {
        "command": "create",
        "task_data": {
          "title": "Buy groceries",
          "description": "Milk, eggs, bread"
        }
      },
      {
        "command": "list",
        "task_data": {
          "status_filter": "all"
        }
      }
    ]
  },
  "output_spec": {
    "format": "json",
    "description": "Output is a JSON object with success status, message, and optional data.",
    "schema": {
      "success": "boolean",
      "message": "string",
      "data": "optional dict (e.g., task_id, tasks list)"
    },
    "examples": [
      {
        "success": true,
        "message": "Task created with ID 1",
        "data": {
          "task_id": 1
        }
      },
      {
        "success": true,
        "message": "Found 1 task",
        "data": {
          "tasks": []
        }
      }
    ]
  }
}