
# Python cache
__pycache__/
*.pyc
*.pyo

# Debug output from failed LLM responses
**/debug/

# Environment
.env
*.env.local

# Old informal test files (superseded by formal tests)
tests/test_1_*.py
tests/test_2_*.py
tests/test_3_*.py
tests/test_4_*.py
tests/test_5_*.py
tests/test_a_*.py
tests/test_b_*.py
tests/test_codegen_*.py
tests/test_provenance_*.py

# Old test outputs (non-essential)
tests/output/test_codegen_formal/
tests/output/test_codegen_real_llm/

# Keep formal test outputs
# tests/output/test_leaf_rejection/*

# Generated outputs (LLM pipeline products)
output/
pipeline_output.log
output_shell.txt

# Test run artifacts with timestamps
tests/output/**/e2e_results_*.json
tests/output/**/formal_results_*.json
tests/output/**/raw_records_*.json

# Ignore self — .gitignore rules are local-only
.gitignore
