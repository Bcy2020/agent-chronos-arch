{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DecompositionTreeNode",
  "description": "Decomposition tree node format for decomposition-verification paradigm",
  "type": "object",
  "required": ["node_id", "name", "depth", "function_spec", "boundary", "implementation"],
  "properties": {
    "node_id": {
      "type": "string",
      "description": "Unique node identifier, format: depth_index (e.g., 0_0, 1_0, 1_1)"
    },
    "name": {
      "type": "string",
      "description": "Node/function name using snake_case"
    },
    "depth": {
      "type": "integer",
      "minimum": 0,
      "description": "Node depth, root node is 0"
    },
    "parent_id": {
      "type": ["string", "null"],
      "description": "Parent node ID, null for root node"
    },

    "function_spec": {
      "type": "object",
      "description": "Complete function specification",
      "required": ["purpose", "detailed_description", "inputs", "outputs"],
      "properties": {
        "purpose": {
          "type": "string",
          "description": "One-sentence summary of function purpose"
        },
        "detailed_description": {
          "type": "string",
          "description": "Detailed description including business logic, boundary conditions, exception handling, data transformation rules"
        },
        "inputs": {
          "type": "array",
          "description": "Input parameters list",
          "items": {
            "type": "object",
            "required": ["name", "type", "description"],
            "properties": {
              "name": {"type": "string", "description": "Parameter name"},
              "type": {"type": "string", "description": "Python type, e.g., str, int, List[dict], Optional[str]"},
              "description": {"type": "string", "description": "Parameter meaning and usage"},
              "required": {"type": "boolean", "default": true},
              "default_value": {"type": ["string", "number", "boolean", "null"], "description": "Default value"},
              "constraints": {"type": "string", "description": "Constraints, e.g., '>=0', 'non-empty string', 'enum: A|B|C'"}
            }
          }
        },
        "outputs": {
          "type": "object",
          "description": "Return value description",
          "required": ["type", "description"],
          "properties": {
            "type": {"type": "string", "description": "Return type"},
            "description": {"type": "string", "description": "Return value meaning"},
            "structure": {"type": "string", "description": "If complex type, describe its structure"}
          }
        },
        "side_effects": {
          "type": "string",
          "description": "Side effects description, e.g., 'modifies global variable X', 'writes to file', 'no side effects'"
        },
        "error_handling": {
          "type": "string",
          "description": "Error handling strategy: exception types, trigger conditions, handling methods"
        },
        "preconditions": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Preconditions list"
        },
        "postconditions": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Postconditions list"
        },
        "invariants": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Invariants: conditions that remain unchanged during execution"
        }
      }
    },

    "boundary": {
      "type": "object",
      "description": "Responsibility boundary",
      "required": ["in_scope", "out_of_scope"],
      "properties": {
        "in_scope": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Functionality this node is responsible for"
        },
        "out_of_scope": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Functionality this node is NOT responsible for (handled by other nodes or external)"
        }
      }
    },

    "global_variables": {
      "type": "object",
      "description": "Global variable dependencies",
      "properties": {
        "required": {
          "type": "array",
          "description": "Required global variables",
          "items": {
            "type": "object",
            "required": ["name", "type", "access_mode", "description"],
            "properties": {
              "name": {"type": "string", "description": "Variable name"},
              "type": {"type": "string", "description": "Type"},
              "access_mode": {
                "type": "string",
                "enum": ["read", "write", "read-write"],
                "description": "Access mode"
              },
              "description": {"type": "string", "description": "Usage description"},
              "initial_value": {"type": ["string", "number", "boolean", "null"], "description": "Suggested initial value"}
            }
          }
        },
        "operations_pushed_to_leaves": {
          "type": "boolean",
          "default": true,
          "description": "Whether global variable operations have been pushed down to leaf nodes"
        }
      }
    },

    "implementation": {
      "type": "object",
      "description": "Implementation information",
      "required": ["is_leaf"],
      "properties": {
        "is_leaf": {
          "type": "boolean",
          "description": "Whether this is a leaf node (no further decomposition)"
        },
        "stop_reason": {
          "type": "string",
          "description": "Reason for stopping decomposition: independently_implementable, atomic_operation, below_line_threshold, etc."
        },
        "estimated_lines": {
          "type": "integer",
          "description": "Estimated lines of code"
        },
        "code": {
          "type": "string",
          "description": "Generated Python code (assuming child nodes are implemented)"
        },
        "code_file": {
          "type": "string",
          "description": "Code storage file path (stored by level)"
        },
        "dependencies": {
          "type": "array",
          "items": {"type": "string"},
          "description": "List of dependent child node IDs"
        },
        "child_interaction_flow": {
          "type": "string",
          "description": "Child node interaction flow description (for non-leaf nodes)"
        },
        "composition_logic": {
          "type": "string",
          "description": "Composition logic: how parent node functionality is implemented through child nodes"
        }
      }
    },

    "interface_preservation": {
      "type": "object",
      "description": "Interface preservation verification",
      "properties": {
        "parent_inputs_covered_by": {
          "type": "object",
          "description": "How parent inputs are covered by child nodes {parent_input: [child_node_ids]}"
        },
        "parent_outputs_produced_by": {
          "type": "object",
          "description": "Parent outputs produced by which child nodes {parent_output: child_node_id}"
        },
        "internal_interfaces": {
          "type": "array",
          "description": "Internal interfaces (data passed between child nodes)",
          "items": {
            "type": "object",
            "properties": {
              "from_node": {"type": "string"},
              "to_node": {"type": "string"},
              "data_type": {"type": "string"},
              "description": {"type": "string"}
            }
          }
        },
        "external_interface": {
          "type": "object",
          "description": "External interface (consistent with parent interface)",
          "properties": {
            "inputs": {"type": "array"},
            "outputs": {"type": "array"}
          }
        },
        "validation_passed": {
          "type": "boolean",
          "description": "Whether interface preservation validation passed"
        },
        "validation_notes": {
          "type": "string",
          "description": "Validation notes"
        }
      }
    },

    "validation": {
      "type": "object",
      "description": "Validation information",
      "properties": {
        "decomposition_quality": {
          "type": "string",
          "enum": ["excellent", "good", "acceptable", "needs_refinement"],
          "description": "Decomposition quality assessment"
        },
        "issues": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Issues found"
        },
        "suggestions": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Improvement suggestions"
        }
      }
    },

    "children": {
      "type": "array",
      "items": {"$ref": "#"},
      "description": "Child nodes list"
    },

    "metadata": {
      "type": "object",
      "description": "Metadata",
      "properties": {
        "created_at": {"type": "string"},
        "model_used": {"type": "string"},
        "tokens_used": {"type": "integer"},
        "decomposition_round": {"type": "integer"}
      }
    }
  }
}
