{
  "children": [
    {
      "name": "CheckDuplicate",
      "purpose": "Check if student_id already exists in students data store",
      "behavior": "Query the students data store for the given student_id and return whether it exists",
      "boundary": {
        "in_scope": [
          "Query data store by student_id",
          "Return boolean existence flag"
        ],
        "out_of_scope": [
          "Insertion",
          "Error handling"
        ]
      },
      "semantic_inputs": [
        {
          "name": "student_id",
          "description": "Student identifier to check",
          "source": "parent input"
        }
      ],
      "semantic_outputs": [
        {
          "name": "exists",
          "description": "Whether student_id already exists",
          "consumer": "parent"
        }
      ],
      "preconditions": [
        "student_id is provided"
      ],
      "postconditions": [
        "Data store is not modified"
      ],
      "guarantees": [
        "Read-only operation"
      ],
      "composition_role": "query",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "InsertRecord",
      "purpose": "Insert new student record into students data store",
      "behavior": "Write student_id and student_name into the students data store",
      "boundary": {
        "in_scope": [
          "Insert student_id and student_name",
          "Return success indicator"
        ],
        "out_of_scope": [
          "Duplicate checking",
          "Validation"
        ]
      },
      "semantic_inputs": [
        {
          "name": "student_id",
          "description": "Student identifier to insert",
          "source": "parent input"
        },
        {
          "name": "student_name",
          "description": "Student name to insert",
          "source": "parent input"
        }
      ],
      "semantic_outputs": [
        {
          "name": "insert_success",
          "description": "Whether insertion succeeded",
          "consumer": "parent"
        }
      ],
      "preconditions": [
        "student_id does not exist in data store"
      ],
      "postconditions": [
        "New student record is added to data store"
      ],
      "guarantees": [
        "Write operation"
      ],
      "composition_role": "mutate",
      "stop_decompose": false,
      "stop_reason": ""
    }
  ],
  "decomposition_rationale": "The parent responsibility is split into two sequential steps: first check for duplicate, then insert if unique. This separates the read-only check from the write operation, allowing independent testing and potential reuse.",
  "orchestration_model": "conditional",
  "dataflow_sketch": [
    {
      "from": "parent",
      "to": "CheckDuplicate",
      "data": "student_id",
      "note": "pass student_id for duplicate check"
    },
    {
      "from": "CheckDuplicate",
      "to": "parent",
      "data": "exists",
      "note": "return existence flag"
    },
    {
      "from": "parent",
      "to": "InsertRecord",
      "data": "student_id, student_name",
      "note": "pass data for insertion only if not duplicate"
    },
    {
      "from": "InsertRecord",
      "to": "parent",
      "data": "insert_success",
      "note": "return insertion result"
    }
  ]
}