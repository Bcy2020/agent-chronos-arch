{
  "children": [
    {
      "name": "CheckDuplicate",
      "purpose": "Check if student_id already exists in the students data store",
      "behavior": "Query the students data store for the given student_id. Return true if found, false otherwise.",
      "boundary": {
        "in_scope": [
          "Query students data store by student_id",
          "Return boolean existence indicator"
        ],
        "out_of_scope": [
          "Insertion",
          "Error handling beyond existence check"
        ]
      },
      "semantic_inputs": [
        {
          "name": "student_id",
          "description": "Student identifier to check",
          "source": "parent input"
        }
      ],
      "semantic_outputs": [
        {
          "name": "exists",
          "description": "Whether student_id already exists",
          "consumer": "parent"
        }
      ],
      "preconditions": [
        "student_id is provided"
      ],
      "postconditions": [
        "No modification to data store"
      ],
      "guarantees": [
        "Read-only operation"
      ],
      "composition_role": "query",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "InsertRecord",
      "purpose": "Insert a new student record into the students data store",
      "behavior": "Insert the student_id and student_name into the students data store. Return success indicator.",
      "boundary": {
        "in_scope": [
          "Insert student_id and student_name",
          "Return success/failure"
        ],
        "out_of_scope": [
          "Duplicate checking",
          "Validation"
        ]
      },
      "semantic_inputs": [
        {
          "name": "student_id",
          "description": "Student identifier to insert",
          "source": "parent input"
        },
        {
          "name": "student_name",
          "description": "Student name to insert",
          "source": "parent input"
        }
      ],
      "semantic_outputs": [
        {
          "name": "insertion_success",
          "description": "Whether insertion succeeded",
          "consumer": "parent"
        }
      ],
      "preconditions": [
        "student_id is unique",
        "student_name is provided"
      ],
      "postconditions": [
        "Student record is inserted if unique"
      ],
      "guarantees": [
        "Insertion is atomic"
      ],
      "composition_role": "mutate",
      "stop_decompose": false,
      "stop_reason": ""
    }
  ],
  "decomposition_rationale": "The parent responsibility is split into two sequential steps: first check for duplicate, then insert if unique. This separates the read-only query from the mutation, allowing clear conditional logic in the parent.",
  "orchestration_model": "conditional",
  "dataflow_sketch": [
    {
      "from": "parent",
      "to": "CheckDuplicate",
      "data": "student_id",
      "note": "Pass student_id to check existence"
    },
    {
      "from": "CheckDuplicate",
      "to": "parent",
      "data": "exists",
      "note": "Return existence boolean"
    },
    {
      "from": "parent",
      "to": "InsertRecord",
      "data": "student_id, student_name",
      "note": "Pass data for insertion if not duplicate"
    },
    {
      "from": "InsertRecord",
      "to": "parent",
      "data": "insertion_success",
      "note": "Return insertion result"
    }
  ]
}