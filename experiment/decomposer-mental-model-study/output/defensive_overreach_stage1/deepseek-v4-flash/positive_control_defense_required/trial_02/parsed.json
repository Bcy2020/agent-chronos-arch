{
  "children": [
    {
      "name": "CheckDuplicate",
      "purpose": "Check if student_id already exists in the students data store",
      "behavior": "Query the students data store to determine if a record with the given student_id already exists. Return a boolean indicating existence.",
      "boundary": {
        "in_scope": [
          "Query students data store by student_id",
          "Return existence status"
        ],
        "out_of_scope": [
          "Inserting records",
          "Modifying data store"
        ]
      },
      "semantic_inputs": [
        {
          "name": "student_id",
          "description": "Student identifier to check",
          "source": "parent input"
        }
      ],
      "semantic_outputs": [
        {
          "name": "exists",
          "description": "Whether student_id already exists",
          "consumer": "parent"
        }
      ],
      "preconditions": [
        "student_id is provided"
      ],
      "postconditions": [
        "Data store is not modified"
      ],
      "guarantees": [
        "Returns true if student_id exists, false otherwise"
      ],
      "composition_role": "query",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "InsertRecord",
      "purpose": "Insert a new student record into the students data store",
      "behavior": "Insert a new record with the given student_id and student_name into the students data store. Return success indicator.",
      "boundary": {
        "in_scope": [
          "Insert record into students data store",
          "Return insertion success"
        ],
        "out_of_scope": [
          "Checking duplicates",
          "Validating inputs"
        ]
      },
      "semantic_inputs": [
        {
          "name": "student_id",
          "description": "Student identifier to insert",
          "source": "parent input"
        },
        {
          "name": "student_name",
          "description": "Student name to insert",
          "source": "parent input"
        }
      ],
      "semantic_outputs": [
        {
          "name": "insertion_success",
          "description": "Whether insertion succeeded",
          "consumer": "parent"
        }
      ],
      "preconditions": [
        "student_id is unique",
        "student_name is provided"
      ],
      "postconditions": [
        "New student record is added to data store"
      ],
      "guarantees": [
        "Inserts record if precondition holds"
      ],
      "composition_role": "mutate",
      "stop_decompose": false,
      "stop_reason": ""
    }
  ],
  "decomposition_rationale": "The parent responsibility is split into two sequential steps: first check for duplicate student_id, then insert if unique. This separates the query and mutation concerns.",
  "orchestration_model": "conditional",
  "dataflow_sketch": [
    {
      "from": "parent",
      "to": "CheckDuplicate",
      "data": "student_id",
      "note": "pass student_id to check existence"
    },
    {
      "from": "CheckDuplicate",
      "to": "parent",
      "data": "exists",
      "note": "return existence status to parent"
    },
    {
      "from": "parent",
      "to": "InsertRecord",
      "data": "student_id, student_name",
      "note": "pass data for insertion if no duplicate"
    },
    {
      "from": "InsertRecord",
      "to": "parent",
      "data": "insertion_success",
      "note": "return insertion result to parent"
    }
  ]
}