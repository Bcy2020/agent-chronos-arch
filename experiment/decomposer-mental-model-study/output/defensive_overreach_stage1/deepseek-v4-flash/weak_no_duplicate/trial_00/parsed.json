{
  "children": [
    {
      "name": "BuildStudentRecord",
      "purpose": "Construct the student record object from inputs",
      "behavior": "Takes student_id and student_name, creates a data structure (e.g., dict or object) representing the student record.",
      "boundary": {
        "in_scope": [
          "Construct student record with given fields"
        ],
        "out_of_scope": [
          "Data store operations",
          "Validation"
        ]
      },
      "semantic_inputs": [
        {
          "name": "student_id",
          "description": "Unique student identifier",
          "source": "parent input"
        },
        {
          "name": "student_name",
          "description": "Student name",
          "source": "parent input"
        }
      ],
      "semantic_outputs": [
        {
          "name": "student_record",
          "description": "Constructed student record object",
          "consumer": "InsertRecord"
        }
      ],
      "preconditions": [
        "student_id and student_name are provided"
      ],
      "postconditions": [
        "student_record is created with student_id and student_name"
      ],
      "guarantees": [
        "Output record contains exactly the provided fields"
      ],
      "composition_role": "transform",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "InsertRecord",
      "purpose": "Insert the student record into the data store",
      "behavior": "Takes the student record and writes it to the students data store. Returns a boolean indicating success.",
      "boundary": {
        "in_scope": [
          "Write record to data store",
          "Return success/failure"
        ],
        "out_of_scope": [
          "Record construction",
          "Duplicate checking"
        ]
      },
      "semantic_inputs": [
        {
          "name": "student_record",
          "description": "Student record to insert",
          "source": "BuildStudentRecord"
        }
      ],
      "semantic_outputs": [
        {
          "name": "success",
          "description": "Whether insertion succeeded",
          "consumer": "parent"
        }
      ],
      "preconditions": [
        "student_record is valid",
        "Data store is accessible"
      ],
      "postconditions": [
        "Record is inserted if successful"
      ],
      "guarantees": [
        "Returns true only if record was inserted"
      ],
      "composition_role": "execute",
      "stop_decompose": true,
      "stop_reason": "Atomic data store write operation"
    }
  ],
  "decomposition_rationale": "The parent responsibility is split into two sequential steps: first building the record object, then inserting it. This separates data construction from data store interaction.",
  "orchestration_model": "sequence",
  "dataflow_sketch": [
    {
      "from": "parent",
      "to": "BuildStudentRecord",
      "data": "student_id, student_name",
      "note": "Inputs for record construction"
    },
    {
      "from": "BuildStudentRecord",
      "to": "InsertRecord",
      "data": "student_record",
      "note": "Constructed record to insert"
    },
    {
      "from": "InsertRecord",
      "to": "parent",
