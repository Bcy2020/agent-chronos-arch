{
  "children": [
    {
      "name": "PlaceOrder",
      "purpose": "Execute the complete place order workflow: validate stock, charge payment, reserve inventory, create order record, send notification.",
      "behavior": "Calls validation, payment, inventory, order creation, and notification functions in sequence with rollback on failure.",
      "boundary": {
        "in_scope": [
          "validating items and stock",
          "charging payment",
          "reserving inventory",
          "creating order record",
          "sending confirmation"
        ],
        "out_of_scope": [
          "cancelling orders",
          "tracking orders",
          "handling other commands"
        ]
      },
      "preconditions": [
        "command is 'place'"
      ],
      "postconditions": [
        "If success, order record created with status 'confirmed'",
        "If failure, no side effects remain"
      ],
      "guarantees": [
        "Atomicity: rollback on any failure",
        "Payment charged before inventory decremented"
      ],
      "composition_role": "execute",
      "stop_decompose": false,
      "stop_reason": "",
      "inputs": [
        {
          "name": "order_data",
          "type": "dict",
          "description": "Order payload with items (list), payment_method (str), shipping_address (dict)",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "order_result",
          "type": "dict",
          "description": "Result with success (bool), order_id (str), status (str), message (str)",
          "consumer": "parent"
        }
      ],
      "signature": "def PlaceOrder(order_data: dict) -> dict"
    },
    {
      "name": "CancelOrder",
      "purpose": "Execute the cancel order workflow: verify order exists and not shipped, refund payment, restore inventory, update order status.",
      "behavior": "Calls verification, refund, inventory restoration, and status update functions in sequence with rollback on failure.",
      "boundary": {
        "in_scope": [
          "verifying order exists and not shipped",
          "refunding payment",
          "restoring inventory",
          "updating order status"
        ],
        "out_of_scope": [
          "placing orders",
          "tracking orders",
          "handling other commands"
        ]
      },
      "preconditions": [
        "command is 'cancel'"
      ],
      "postconditions": [
        "If success, order status set to 'cancelled'",
        "If failure, no side effects remain"
      ],
      "guarantees": [
        "Atomicity: rollback on any failure",
        "Cannot cancel shipped order"
      ],
      "composition_role": "execute",
      "stop_decompose": false,
      "stop_reason": "",
      "inputs": [
        {
          "name": "order_data",
          "type": "dict",
          "description": "Order payload with order_id (str)",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "order_result",
          "type": "dict",
          "description": "Result with success (bool), order_id (str), status (str), message (str)",
          "consumer": "parent"
        }
      ],
      "signature": "def CancelOrder(order_data: dict) -> dict"
    },
    {
      "name": "TrackOrder",
      "purpose": "Return current order status and estimated delivery time for a given order.",
      "behavior": "Looks up order by order_id in orders data store and returns status and estimated delivery time.",
      "boundary": {
        "in_scope": [
          "reading order status",
          "estimating delivery time"
        ],
        "out_of_scope": [
          "modifying orders",
          "placing or cancelling orders"
        ]
      },
      "preconditions": [
        "command is 'track'"
      ],
      "postconditions": [
        "Order data is read, not modified"
      ],
      "guarantees": [
        "Read-only operation"
      ],
      "composition_role": "query",
      "stop_decompose": false,
      "stop_reason": "",
      "inputs": [
        {
          "name": "order_data",
          "type": "dict",
          "description": "Order payload with order_id (str)",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "order_result",
          "type": "dict",
          "description": "Result with success (bool), order_id (str), status (str), message (str) including delivery time",
          "consumer": "parent"
        }
      ],
      "signature": "def TrackOrder(order_data: dict) -> dict"
    }
  ],
  "interface_preservation": {
    "parent_inputs_covered_by": {
      "command": "not passed to children (used for routing only)",
      "order_data": "PlaceOrder.inputs[0], CancelOrder.inputs[0], TrackOrder.inputs[0]"
    },
    "parent_outputs_produced_by": {
      "order_result": "PlaceOrder.outputs[0], CancelOrder.outputs[0], TrackOrder.outputs[0]"
    }
  },
  "dataflow_edges": [
    {
      "from_node": "parent",
      "from_output": "order_data",
      "to_node": "PlaceOrder",
      "to_input": "order_data",
      "note": "When command is 'place'"
    },
    {
      "from_node": "parent",
      "from_output": "order_data",
      "to_node": "CancelOrder",
      "to_input": "order_data",
      "note": "When command is 'cancel'"
    },
    {
      "from_node": "parent",
      "from_output": "order_data",
      "to_node": "TrackOrder",
      "to_input": "order_data",
      "note": "When command is 'track'"
    },
    {
      "from_node": "PlaceOrder",
      "from_output": "order_result",
      "to_node": "parent",
      "to_input": "order_result",
      "note": "Result of place operation"
    },
    {
      "from_node": "CancelOrder",
      "from_output": "order_result",
      "to_node": "parent",
      "to_input": "order_result",
      "note": "Result of cancel operation"
    },
    {
      "from_node": "TrackOrder",
      "from_output": "order_result",
      "to_node": "parent",
      "to_input": "order_result",
      "note": "Result of track operation"
    }
  ]
}