[
  {
    "name": "PlaceOrder",
    "purpose": "Execute the complete place order workflow: validate, charge, reserve, create record, notify.",
    "behavior": "Calls validate items, charge payment, reserve inventory, create order record, and send notification in sequence, rolling back on failure.",
    "boundary": {
      "in_scope": [
        "validating items and stock",
        "charging payment",
        "reserving inventory",
        "creating order record",
        "sending confirmation"
      ],
      "out_of_scope": [
        "cancelling orders",
        "tracking orders",
        "handling other commands"
      ]
    },
    "semantic_inputs": [
      {
        "name": "order_data",
        "description": "Order payload with items, payment_method, shipping_address",
        "source": "parent input"
      },
      {
        "name": "command",
        "description": "Must be 'place'",
        "source": "parent input"
      }
    ],
    "semantic_outputs": [
      {
        "name": "order_result",
        "description": "Result dict with success, order_id, status, message",
        "consumer": "parent"
      }
    ],
    "preconditions": [
      "command is 'place'",
      "order_data contains items, payment_method, shipping_address"
    ],
    "postconditions": [
      "If success: order record created, payment charged, inventory reserved, notification sent",
      "If failure: all changes rolled back"
    ],
    "guarantees": [
      "Atomicity: all-or-nothing",
      "Payment charged before inventory reserved"
    ],
    "composition_role": "execute",
    "stop_decompose": false,
    "stop_reason": "",
    "inputs": [
      {
        "name": "command",
        "type": "str",
        "description": "Must be 'place'",
        "source": "parent input"
      },
      {
        "name": "order_data",
        "type": "dict",
        "description": "Order payload with items (list), payment_method (str), shipping_address (dict)",
        "source": "parent input"
      }
    ],
    "outputs": [
      {
        "name": "order_result",
        "type": "dict",
        "description": "Result dict with success (bool), order_id (str), status (str), message (str)",
        "consumer": "parent"
      }
    ],
    "signature": "def PlaceOrder(command: str, order_data: dict) -> dict",
    "global_vars": [
      {
        "variable": "orders",
        "op": "read_write",
        "description": "Create new order record and update status"
      },
      {
        "variable": "inventory",
        "op": "read_write",
        "description": "Reserve items and update stock counts"
      },
      {
        "variable": "payments",
        "op": "read_write",
        "description": "Create payment record and charge payment"
      }
    ],
    "data_operations": [
      {
        "source_name": "orders",
        "operation_type": "read_write",
        "description": "Create order record, update status on rollback"
      },
      {
        "source_name": "inventory",
        "operation_type": "read_write",
        "description": "Read stock, reserve items, update counts"
      },
      {
        "source_name": "payments",
        "operation_type": "read_write",
        "description": "Create payment record, charge payment"
      }
    ],
    "requested_capabilities": [
      "orders.read_write",
      "inventory.read_write",
      "payments.read_write"
    ],
    "constraints": [
      {
        "constraint_id": "C-001",
        "description": "Must rollback all changes if any step fails"
      },
      {
        "constraint_id": "C-002",
        "description": "Payment must be charged before inventory is reserved"
      }
    ],
    "acceptance_criteria": [
      {
        "ac_id": "AC-001",
        "description": "Order record created with status 'confirmed'"
      },
      {
        "ac_id": "AC-002",
        "description": "Payment charged successfully"
      },
      {
        "ac_id": "AC-003",
        "description": "Inventory reserved correctly"
      },
      {
        "ac_id": "AC-004",
        "description": "All changes rolled back on failure"
      }
    ],
    "traceability": {
      "parent_requirement_ids": [
        "FR-001",
        "FR-002"
      ]
    },
    "node_type": "atomic_operation"
  },
