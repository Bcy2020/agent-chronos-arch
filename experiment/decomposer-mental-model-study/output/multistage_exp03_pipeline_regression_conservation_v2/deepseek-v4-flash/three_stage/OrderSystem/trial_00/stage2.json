      "note": "Pass order data to place workflow"
    },
    {
      "from_node": "parent",
      "from_output": "command",
      "to_node": "CancelOrder",
      "to_input": "command",
      "note": "Route command to cancel workflow"
    },
    {
      "from_node": "parent",
      "from_output": "order_data",
      "to_node": "CancelOrder",
      "to_input": "order_data",
      "note": "Pass order data to cancel workflow"
    },
    {
      "from_node": "parent",
      "from_output": "command",
      "to_node": "TrackOrder",
      "to_input": "command",
      "note": "Route command to track workflow"
    },
    {
      "from_node": "parent",
      "from_output": "order_data",
      "to_node": "TrackOrder",
      "to_input": "order_data",
      "note": "Pass order data to track workflow"
    },
    {
      "from_node": "PlaceOrder",
      "from_output": "order_result",
      "to_node": "parent",
      "to_input": "order_result",
      "note": "Return place result to parent"
    },
    {
      "from_node": "CancelOrder",
      "from_output": "order_result",
      "to_node": "parent",
      "to_input": "order_result",
      "note": "Return cancel result to parent"
    },
    {
      "from_node": "TrackOrder",
      "from_output": "order_result",
      "to_node": "parent",
      "to_input": "order_result",
      "note": "Return track result to parent"
    }
  ]
}