{
  "metadata": {
    "project_name": "Order Management System",
    "project_id": "com.example.order.management",
    "version": "1.0.0"
  },
  "functional_requirements": [
    {
      "fr_id": "FR-001",
      "title": "Create Order",
      "description": "创建订单：用户指定商品列表和用户ID，检查用户存在、库存充足，计算总价，扣减库存，创建状态为pending的订单。",
      "priority": "high",
      "related_nfr_ids": [
        "NFR-001"
      ],
      "depends_on": []
    },
    {
      "fr_id": "FR-002",
      "title": "Pay Order",
      "description": "支付订单：检查订单存在且状态为pending，用户余额充足，扣减余额，更新订单状态为paid。",
      "priority": "high",
      "related_nfr_ids": [
        "NFR-001"
      ],
      "depends_on": [
        "FR-001"
      ]
    },
    {
      "fr_id": "FR-003",
      "title": "Ship Order",
      "description": "订单发货：检查订单存在且状态为paid，更新状态为shipped。",
      "priority": "high",
      "related_nfr_ids": [],
      "depends_on": [
        "FR-002"
      ]
    },
    {
      "fr_id": "FR-004",
      "title": "Complete Order",
      "description": "订单完成：检查订单存在且状态为shipped，更新状态为completed。",
      "priority": "high",
      "related_nfr_ids": [],
      "depends_on": [
        "FR-003"
      ]
    },
    {
      "fr_id": "FR-005",
      "title": "Cancel Order",
      "description": "取消订单：检查订单存在且状态为pending或paid，恢复商品库存，若已支付退还余额，更新状态为cancelled。",
      "priority": "high",
      "related_nfr_ids": [
        "NFR-001"
      ],
      "depends_on": [
        "FR-001",
        "FR-002"
      ]
    },
    {
      "fr_id": "FR-006",
      "title": "List Orders",
      "description": "列出所有订单，支持按用户和状态筛选，显示订单详情。",
      "priority": "medium",
      "related_nfr_ids": [],
      "depends_on": []
    },
    {
      "fr_id": "FR-007",
      "title": "Get User Orders",
      "description": "获取指定用户的所有订单，计算订单总额及各种状态订单数量。",
      "priority": "medium",
      "related_nfr_ids": [],
      "depends_on": []
    },
    {
      "fr_id": "FR-008",
      "title": "List Products",
      "description": "列出所有商品，显示信息和库存，可筛选库存不足的商品。",
      "priority": "medium",
      "related_nfr_ids": [],
      "depends_on": []
    }
  ],
  "non_functional_requirements": [
    {
      "nfr_id": "NFR-001",
      "category": "reliability",
      "description": "数据一致性：库存扣减和恢复、余额扣减和退还必须保证原子性，避免数据不一致。"
    },
    {
      "nfr_id": "NFR-002",
      "category": "usability",
      "description": "错误处理：提供明确错误信息，如库存不足、余额不足、无效订单等。"
    }
  ],
  "acceptance_criteria": [
    {
      "ac_id": "AC-001",
      "description": "创建订单成功后，库存正确扣减，订单状态为pending。",
      "verification_method": "automated_test",
      "related_fr_ids": [
        "FR-001"
      ]
    },
    {
      "ac_id": "AC-002",
      "description": "支付订单成功后，用户余额正确扣减，订单状态变为paid。",
      "verification_method": "automated_test",
      "related_fr_ids": [
        "FR-002"
      ]
    },
    {
      "ac_id": "AC-003",
      "description": "取消订单后，库存和余额恢复，订单状态变为cancelled。",
      "verification_method": "automated_test",
      "related_fr_ids": [
        "FR-005"
      ]
    },
    {
      "ac_id": "AC-004",
      "description": "订单状态流转正确：pending→paid→shipped→completed。",
      "verification_method": "automated_test",
      "related_fr_ids": [
        "FR-001",
        "FR-002",
        "FR-003",
        "FR-004"
      ]
    },
    {
      "ac_id": "AC-005",
      "description": "库存不足时创建订单返回失败信息。",
      "verification_method": "automated_test",
      "related_fr_ids": [
        "FR-001"
      ]
    },
    {
      "ac_id": "AC-006",
      "description": "余额不足时支付订单返回失败信息。",
      "verification_method": "automated_test",
      "related_fr_ids": [
        "FR-002"
      ]
    }
  ],
  "technical_constraints": {
    "storage": {
      "type": "memory",
      "details": "三个独立内存字典存储users, products, orders"
    },
    "concurrency": {
      "model": "single-user",
      "auth_required": false
    },
    "ui": {
      "type": "api"
    },
    "language": "Python"
  },
  "glossary": {
    "订单状态": "订单生命周期状态：pending, paid, shipped, completed, cancelled",
    "余额": "用户账户中的可用金额",
    "库存": "商品的可售数量"
  },
  "global_state_sources": [
    {
      "source_id": "users",
      "type": "dict",
      "description": "存储用户信息，以user_id为键",
      "initial_state": {
        "1": {
          "user_id": 1,
          "name": "张三",
          "email": "zhang@test.com",
          "balance": 500.0
        },
        "2": {
          "user_id": 2,
          "name": "李四",
          "email": "li@test.com",
          "balance": 300.0
        },
        "3": {
          "user_id": 3,
          "name": "王五",
          "email": "wang@test.com",
          "balance": 100.0
        }
      },
      "item_schema": {
        "user_id": "int",
        "name": "string",
        "email": "string",
        "balance": "float"
      }
    },
    {
      "source_id": "products",
      "type": "dict",
      "description": "存储商品信息，以product_id为键",
      "initial_state": {
        "1": {
          "product_id": 1,
          "name": "手机",
          "price": 999.0,
          "stock": 10
        },
        "2": {
          "product_id": 2,
          "name": "耳机",
          "price": 99.9,
          "stock": 20
        },
        "3": {
          "product_id": 3,
          "name": "充电器",
          "price": 49.9,
          "stock": 50
        },
        "4": {
          "product_id": 4,
          "name": "数据线",
          "price": 19.9,
          "stock": 100
        },
        "5": {
          "product_id": 5,
          "name": "手机壳",
          "price": 29.9,
          "stock": 30
        }
      },
      "item_schema": {
        "product_id": "int",
        "name": "string",
        "price": "float",
        "stock": "int"
      }
    },
    {
      "source_id": "orders",
      "type": "dict",
      "description": "存储订单记录，以order_id为键",
      "initial_state": {},
      "item_schema": {
        "order_id": "int",
        "user_id": "int",
        "items": "list of objects (product_id, quantity)",
        "total_price": "float",
        "status": "string (pending|paid|shipped|completed|cancelled)",
        "created_at": "string (ISO datetime)"
      }
    }
  ],
  "input_spec": {
    "format": "json",
    "description": "通过 manage_order函数接收命令和订单数据",
    "schema": {
      "command": "string (create_order|pay_order|ship_order|complete_order|cancel_order|list_orders|get_user_orders|list_products)",
      "order_data": "object (包含user_id, order_id, items, status_filter, user_filter, low_stock等字段，根据命令不同)"
    },
    "examples": [
      {
        "command": "create_order",
        "order_data": {
          "user_id": 1,
          "items": [
            {
              "product_id": 2,
              "quantity": 2
            }
          ]
        }
      },
      {
        "command": "pay_order",
        "order_data": {
          "order_id": 1
        }
      }
    ]
  },
  "output_spec": {
    "format": "json",
    "description": "返回操作结果，包含成功标志、消息和数据",
    "schema": {
      "success": "boolean",
      "message": "string",
      "data": "object (包含订单详情、用户余额等，具体取决于命令)"
    },
    "examples": [
      {
        "success": true,
        "message": "订单创建成功",
        "data": {
          "order_id": 1,
          "total_price": 199.8
        }
      },
      {
        "success": false,
        "message": "商品库存不足",
        "data": {
          "product_id": 1,
          "available": 10,
          "requested": 15
        }
      }
    ]
  }
}