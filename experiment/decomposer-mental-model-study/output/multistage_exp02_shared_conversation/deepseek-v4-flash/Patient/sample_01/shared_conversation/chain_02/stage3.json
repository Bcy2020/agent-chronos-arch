        {
          "resource": "patients",
          "op": "read",
          "reason": "verify patient exists"
        },
        {
          "resource": "appointments",
          "op": "read_write",
          "reason": "check slot availability and store appointment"
        }
      ],
      "outputs": [
        {
          "name": "result",
          "type": "dict",
          "description": "JSON with success, data, message",
          "consumer": "parent"
        }
