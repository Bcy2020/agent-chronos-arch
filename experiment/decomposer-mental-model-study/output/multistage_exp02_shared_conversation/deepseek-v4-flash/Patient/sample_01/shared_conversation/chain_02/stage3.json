{
  "children": [
    {
      "name": "RegisterPatient",
      "purpose": "Register a new patient with provided details",
      "behavior": "Validate input, check for duplicate, store patient in patients store, return success or error",
      "boundary": {
        "in_scope": [
          "patient registration",
          "duplicate check"
        ],
        "out_of_scope": [
          "appointment booking",
          "record retrieval",
          "profile update"
        ]
      },
      "preconditions": [
        "input contains valid patient data"
      ],
      "postconditions": [
        "patient is stored in patients store"
      ],
      "guarantees": [
        "no duplicate patient created"
      ],
      "composition_role": "mutate",
      "call_inputs": [
        {
          "name": "patient_data",
          "type": "dict",
          "description": "JSON with patient details",
          "source": "parent input"
        }
      ],
      "internal_leaf_accesses": [
        {
          "resource": "patients",
          "op": "read_write",
          "reason": "check for duplicate and store new patient"
        }
      ],
      "outputs": [
        {
          "name": "result",
          "type": "dict",
          "description": "JSON with success, data, message",
          "consumer": "parent"
        }
      ],
      "signature": "def RegisterPatient(patient_data: dict) -> dict",
      "global_vars": [
        {
          "variable": "patients",
          "op": "read_write",
          "description": "read for duplicate check, write for storing new patient"
        }
      ],
      "data_operations": [
        {
          "source_name": "patients",
          "operation_type": "read_write",
          "description": "check for duplicate and store new patient"
        }
      ],
      "requested_capabilities": [
        "patients.read_write"
      ],
      "constraints": [
        {
          "constraint_id": "C-001",
          "description": "Patient data must be valid JSON with required fields"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-001",
          "description": "New patient is stored successfully and no duplicate is created"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-001"
        ]
      },
      "node_type": "pure_function",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
