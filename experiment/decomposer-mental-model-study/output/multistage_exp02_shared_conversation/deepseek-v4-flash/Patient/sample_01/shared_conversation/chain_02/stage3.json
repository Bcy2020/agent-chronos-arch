        {
          "variable": "patients",
          "op": "read",
          "description": "read to verify patient exists"
        },
        {
          "variable": "appointments",
          "op": "read_write",
          "description": "read for slot check, write for storing appointment"
        }
      ],
      "data_operations": [
        {
          "source_name": "patients",
          "operation_type": "read",
          "description": "verify patient exists"
        },
        {
          "source_name": "appointments",
          "operation_type": "read_write",
          "description": "check slot availability and store appointment"
        }
      ],
      "requested_capabilities": [
        "patients.read",
        "appointments.read_write"
      ],
      "constraints": [
        {
          "constraint_id": "C-002",
          "description": "Patient must be registered before booking"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-002",
          "description": "Appointment is booked only if patient exists and slot is available"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-002"
        ]
      },
      "node_type": "pure_function",
      "stop_decompose": false,
      "stop_reason": ""
