      "composition_role": "query",
      "call_inputs": [
        {
          "name": "input",
          "type": "dict",
          "description": "JSON with patient ID",
          "source": "parent input"
        }
      ],
      "internal_leaf_accesses": [
        {
          "resource": "patients",
          "op": "read",
          "reason": "verify patient exists and fetch records"
        }
      ],
      "outputs": [
        {
          "name": "result",
          "type": "dict",
          "description": "JSON with success status, records data, and message",
          "consumer": "parent"
        }
      ],
      "signature": "def GetRecords(input: dict) -> dict",
      "global_vars": [
        {
          "variable": "patients",
          "op": "read",
          "description": "verify patient exists and fetch records"
        }
      ],
      "data_operations": [
        {
          "source_name": "patients",
          "operation_type": "read",
          "description": "verify patient exists and fetch records"
        }
      ],
      "requested_capabilities": [
        "patients.read"
      ],
      "constraints": [
