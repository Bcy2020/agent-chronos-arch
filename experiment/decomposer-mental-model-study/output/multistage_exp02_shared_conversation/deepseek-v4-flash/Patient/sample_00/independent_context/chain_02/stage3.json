          "constraint_id": "C-003",
          "description": "Patient must exist"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-003",
          "description": "Records are returned for existing patient"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-003"
        ]
      },
      "node_type": "pure_function",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
