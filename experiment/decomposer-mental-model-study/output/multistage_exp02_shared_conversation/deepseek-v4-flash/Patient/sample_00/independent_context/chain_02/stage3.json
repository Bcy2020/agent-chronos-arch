{
  "children": [
    {
      "name": "RegisterPatient",
      "purpose": "Register a new patient in the system",
      "behavior": "Extract patient details from input, validate uniqueness, store in patients data store, return success or error",
      "boundary": {
        "in_scope": [
          "patient registration",
          "data validation",
          "store patient"
        ],
        "out_of_scope": [
          "appointment booking",
          "record retrieval",
          "profile update"
        ]
      },
      "preconditions": [
        "input contains valid patient data"
      ],
      "postconditions": [
        "patient is stored in patients data store"
      ],
      "guarantees": [
        "patient ID is unique",
        "data is persisted"
      ],
      "composition_role": "execute",
      "call_inputs": [
        {
          "name": "input",
          "type": "dict",
          "description": "JSON with patient registration details",
          "source": "parent input"
        }
      ],
      "internal_leaf_accesses": [
        {
          "resource": "patients",
          "op": "read_write",
          "reason": "check uniqueness and store new patient"
        }
      ],
      "outputs": [
        {
          "name": "result",
          "type": "dict",
          "description": "JSON with success status, patient ID, and message",
          "consumer": "parent"
        }
      ],
      "signature": "def RegisterPatient(input: dict) -> dict",
      "global_vars": [
        {
          "variable": "patients",
          "op": "read_write",
          "description": "check uniqueness and store new patient"
        }
      ],
      "data_operations": [
        {
          "source_name": "patients",
          "operation_type": "read_write",
          "description": "check uniqueness and store new patient"
        }
      ],
      "requested_capabilities": [
        "patients.read_write"
      ],
      "constraints": [
        {
          "constraint_id": "C-001",
          "description": "Patient ID must be unique"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-001",
          "description": "Patient is stored and returned with unique ID"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-001"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "BookAppointment",
      "purpose": "Book an appointment for a registered patient",
      "behavior": "Extract patient ID and appointment details, verify patient exists, check slot availability, store appointment, return success or error",
      "boundary": {
        "in_scope": [
          "appointment booking",
          "patient existence check",
          "slot availability",
          "store appointment"
        ],
        "out_of_scope": [
          "patient registration",
          "record retrieval",
          "profile update"
        ]
      },
      "preconditions": [
        "patient is registered",
        "appointment slot is available"
      ],
      "postconditions": [
        "appointment is stored in appointments data store"
      ],
      "guarantees": [
        "appointment ID is unique",
        "no double booking"
      ],
      "composition_role": "execute",
      "call_inputs": [
        {
          "name": "input",
          "type": "dict",
          "description": "JSON with patient ID and appointment details",
          "source": "parent input"
        }
      ],
      "internal_leaf_accesses": [
        {
          "resource": "patients",
          "op": "read",
          "reason": "verify patient exists"
        },
        {
          "resource": "appointments",
          "op": "read_write",
          "reason": "check slot availability and store appointment"
        }
      ],
      "outputs": [
        {
          "name": "result",
          "type": "dict",
          "description": "JSON with success status, appointment ID, and message",
          "consumer": "parent"
        }
      ],
      "signature": "def BookAppointment(input: dict) -> dict",
      "global_vars": [
        {
          "variable": "patients",
          "op": "read",
          "description": "verify patient exists"
        },
        {
          "variable": "appointments",
          "op": "read_write",
          "description": "check slot availability and store appointment"
        }
      ],
      "data_operations": [
        {
          "source_name": "patients",
          "operation_type": "read",
          "description": "verify patient exists"
        },
        {
          "source_name": "appointments",
          "operation_type": "read_write",
          "description": "check slot availability and store appointment"
        }
      ],
      "requested_capabilities": [
        "patients.read",
        "appointments.read_write"
      ],
      "constraints": [
        {
          "constraint_id": "C-002",
          "description": "Appointment slot must be available"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-002",
          "description": "Appointment is stored and returned with unique ID"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-002"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "GetRecords",
