        {
          "variable": "builds",
          "op": "read_write",
          "description": "Check for existing build and create new build record"
        },
        {
          "variable": "artifacts",
          "op": "write",
          "description": "Initialize artifact storage for new build"
        }
      ],
      "data_operations": [
        {
          "source_name": "builds",
          "operation_type": "read_write",
          "description": "Check for existing build and create new build record"
        },
        {
          "source_name": "artifacts",
          "operation_type": "write",
          "description": "Initialize artifact storage for new build"
        }
      ],
      "requested_capabilities": [
        "builds.read_write",
        "artifacts.write"
      ],
      "constraints": [
        {
          "constraint_id": "C-003",
          "description": "Only one build per repo+branch allowed"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-005",
          "description": "Returns build_id for new build"
        },
        {
          "ac_id": "AC-006",
          "description": "Returns error if build already exists for repo+branch"
        }
