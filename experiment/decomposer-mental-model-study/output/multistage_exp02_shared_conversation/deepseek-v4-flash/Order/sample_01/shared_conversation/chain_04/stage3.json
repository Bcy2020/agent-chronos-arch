{
  "children": [
    {
      "name": "ParseCommand",
      "purpose": "Extract and validate the command type from input",
      "behavior": "Parse input JSON to extract command field, validate it is one of 'place', 'cancel', 'track'",
      "boundary": {
        "in_scope": [
          "command extraction",
          "command validation"
        ],
        "out_of_scope": [
          "order data validation",
          "business logic"
        ]
      },
      "preconditions": [
        "input is valid JSON"
      ],
      "postconditions": [
        "command is one of place/cancel/track"
      ],
      "guarantees": [
        "returns error if command missing or invalid"
      ],
      "composition_role": "validate",
      "call_inputs": [
        {
          "name": "input",
          "type": "dict",
          "description": "Raw input JSON from parent",
          "source": "parent input"
        }
      ],
      "internal_leaf_accesses": [],
      "outputs": [
        {
          "name": "command",
          "type": "str",
          "description": "Validated command string",
          "consumer": "parent"
        },
        {
          "name": "order_data",
          "type": "dict",
          "description": "Remaining input data",
          "consumer": "parent"
        }
      ],
      "signature": "def ParseCommand(input: dict) -> tuple[str, dict]",
      "global_vars": [],
      "data_operations": [],
      "requested_capabilities": [],
      "constraints": [],
      "acceptance_criteria": [
        {
          "ac_id": "AC-001",
          "description": "Given valid JSON with command 'place', ParseCommand returns ('place', order_data)"
        },
        {
          "ac_id": "AC-002",
          "description": "Given invalid JSON, ParseCommand raises error"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-001",
          "FR-002",
          "FR-003"
        ]
      },
      "node_type": "pure_function",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "PlaceOrder",
      "purpose": "Execute order placement logic",
      "behavior": "Validate order data, check inventory, process payment, create order record, update inventory",
      "boundary": {
        "in_scope": [
          "order validation",
          "inventory check",
          "payment processing",
          "order creation"
        ],
        "out_of_scope": [
          "cancellation",
          "tracking"
        ]
      },
      "preconditions": [
        "order_data is valid",
        "inventory sufficient",
        "payment succeeds"
      ],
      "postconditions": [
        "order created in orders store",
        "inventory decremented",
        "payment recorded"
      ],
      "guarantees": [
        "atomic operation: all or nothing"
      ],
      "composition_role": "execute",
      "call_inputs": [
        {
          "name": "order_data",
          "type": "dict",
          "description": "Order details from ParseCommand",
          "source": "ParseCommand output"
        }
      ],
      "internal_leaf_accesses": [
        {
          "resource": "orders",
          "op": "write",
          "reason": "Create new order record"
        },
        {
          "resource": "inventory",
          "op": "write",
          "reason": "Decrement stock for ordered items"
        },
        {
          "resource": "payments",
          "op": "write",
          "reason": "Record payment transaction"
        }
      ],
      "outputs": [
        {
          "name": "order_id",
          "type": "str",
          "description": "Generated order ID",
          "consumer": "parent"
        },
        {
          "name": "status",
          "type": "str",
          "description": "Order status after placement",
          "consumer": "parent"
        },
        {
          "name": "message",
          "type": "str",
          "description": "Success or error message",
          "consumer": "parent"
        }
      ],
      "signature": "def PlaceOrder(order_data: dict) -> tuple[str, str, str]",
      "global_vars": [
        {
          "variable": "orders",
          "op": "write",
          "description": "Create new order record"
        },
        {
          "variable": "inventory",
          "op": "write",
          "description": "Decrement stock for ordered items"
        },
        {
          "variable": "payments",
          "op": "write",
          "description": "Record payment transaction"
        }
      ],
      "data_operations": [
        {
          "source_name": "orders",
          "operation_type": "write",
          "description": "Create new order record"
        },
        {
          "source_name": "inventory",
          "operation_type": "write",
          "description": "Decrement stock for ordered items"
        },
        {
          "source_name": "payments",
          "operation_type": "write",
          "description": "Record payment transaction"
        }
      ],
      "requested_capabilities": [
        "orders.write",
        "inventory.write",
        "payments.write"
      ],
      "constraints": [
        {
          "constraint_id": "C-001",
          "description": "All writes must be atomic: if any write fails, all must rollback"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-001",
          "description": "Given valid order_data, PlaceOrder creates order, decrements inventory, records payment"
        },
        {
          "ac_id": "AC-002",
          "description": "Given insufficient inventory, PlaceOrder returns error and no writes occur"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-001"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "CancelOrder",
      "purpose": "Execute order cancellation logic",
      "behavior": "Validate order exists, check order is not shipped, update order status to cancelled, restore inventory, process refund",
      "boundary": {
        "in_scope": [
          "order lookup",
          "status check",
          "inventory restoration",
          "refund processing"
        ],
        "out_of_scope": [
          "placement",
          "tracking"
        ]
      },
      "preconditions": [
        "order exists",
        "order not shipped"
      ],
      "postconditions": [
        "order status set to cancelled",
        "inventory restored",
        "refund initiated"
      ],
      "guarantees": [
        "atomic operation: all or nothing"
      ],
      "composition_role": "execute",
      "call_inputs": [
        {
          "name": "order_data",
          "type": "dict",
          "description": "Contains order_id to cancel",
          "source": "ParseCommand output"
        }
      ],
      "internal_leaf_accesses": [
        {
          "resource": "orders",
          "op": "write",
          "reason": "Update order status to cancelled"
        },
        {
          "resource": "inventory",
          "op": "write",
          "reason": "Restore inventory for cancelled items"
        },
        {
          "resource": "payments",
          "op": "write",
          "reason": "Process refund"
        }
      ],
      "outputs": [
