          "name": "order_id",
          "type": "str",
          "description": "Cancelled order ID",
          "consumer": "parent"
        },
        {
          "name": "status",
          "type": "str",
          "description": "Updated order status",
          "consumer": "parent"
        },
        {
          "name": "message",
          "type": "str",
          "description": "Success or error message",
          "consumer": "parent"
        }
      ],
      "signature": "def CancelOrder(order_data: dict) -> tuple[str, str, str]",
      "global_vars": [
        {
          "variable": "orders",
          "op": "write",
          "description": "Update order status to cancelled"
        },
        {
          "variable": "inventory",
          "op": "write",
          "description": "Restore inventory for cancelled items"
        },
        {
          "variable": "payments",
          "op": "write",
          "description": "Process refund"
        }
      ],
      "data_operations": [
        {
          "source_name": "orders",
          "operation_type": "write",
          "description": "Update order status to cancelled"
        },
        {
          "source_name": "inventory",
          "operation_type": "write",
          "description": "Restore inventory for cancelled items"
        },
        {
          "source_name": "payments",
          "operation_type": "write",
          "description": "Process refund"
        }
      ],
      "requested_capabilities": [
        "orders.write",
        "inventory.write",
        "payments.write"
      ],
      "constraints": [
        {
          "constraint_id": "C-001",
          "description": "Cannot cancel a shipped order"
        },
        {
          "constraint_id": "C-002",
          "description": "All writes must be atomic: if any write fails, all must rollback"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-001",
          "description": "Given valid order_id for non-shipped order, CancelOrder updates status, restores inventory, processes refund"
        },
        {
          "ac_id": "AC-002",
          "description": "Given shipped order, CancelOrder returns error and no writes occur"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-002"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "TrackOrder",
      "purpose": "Retrieve and return order tracking information",
      "behavior": "Look up order by ID, return current status and tracking details",
      "boundary": {
        "in_scope": [
