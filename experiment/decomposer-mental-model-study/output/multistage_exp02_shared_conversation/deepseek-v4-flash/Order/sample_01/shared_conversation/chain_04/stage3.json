      "signature": "def TrackOrder(order_data: dict) -> tuple[str, str, str]",
      "global_vars": [
        {
          "variable": "orders",
          "op": "read",
          "description": "Retrieve order status and tracking info"
        }
      ],
      "data_operations": [
        {
          "source_name": "orders",
          "operation_type": "read",
          "description": "Retrieve order status and tracking info"
        }
      ],
      "requested_capabilities": [
        "orders.read"
      ],
      "constraints": [],
      "acceptance_criteria": [
        {
          "ac_id": "AC-001",
