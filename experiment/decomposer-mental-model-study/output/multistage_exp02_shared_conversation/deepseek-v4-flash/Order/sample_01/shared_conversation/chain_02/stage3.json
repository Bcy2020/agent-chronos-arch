          "order lookup",
          "status check",
          "inventory restoration",
          "refund processing"
        ],
        "out_of_scope": [
          "placement",
          "tracking"
        ]
      },
      "preconditions": [
        "order exists",
        "order not shipped"
      ],
      "postconditions": [
        "order status set to cancelled",
        "inventory restored",
        "refund initiated"
      ],
      "guarantees": [
        "atomic operation: all or nothing"
      ],
      "composition_role": "execute",
      "call_inputs": [
        {
          "name": "order_data",
          "type": "dict",
          "description": "Contains order_id to cancel",
          "source": "ParseCommand output"
        }
      ],
      "internal_leaf_accesses": [
        {
          "resource": "orders",
          "op": "read_write",
          "reason": "lookup and update order status"
