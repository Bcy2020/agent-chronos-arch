          "name": "order_id",
          "type": "str",
          "description": "Cancelled order ID",
          "consumer": "parent"
        },
        {
          "name": "status",
          "type": "str",
          "description": "Updated order status",
          "consumer": "parent"
        },
        {
          "name": "message",
          "type": "str",
          "description": "Success or error message",
          "consumer": "parent"
        }
      ],
      "signature": "def CancelOrder(order_data: dict) -> dict",
      "global_vars": [
        {
          "variable": "orders",
          "op": "read_write",
          "description": "lookup and update order status"
        },
        {
          "variable": "inventory",
          "op": "read_write",
          "description": "restore inventory"
        },
        {
          "variable": "payments",
          "op": "read_write",
          "description": "process refund"
        }
      ],
      "data_operations": [
        {
          "source_name": "orders",
          "operation_type": "read_write",
          "description": "lookup and update order status"
        },
        {
          "source_name": "inventory",
          "operation_type": "read_write",
          "description": "restore inventory"
        },
        {
          "source_name": "payments",
          "operation_type": "read_write",
          "description": "process refund"
        }
      ],
      "requested_capabilities": [
        "orders.read_write",
        "inventory.read_write",
        "payments.read_write"
      ],
      "constraints": [
        {
          "constraint_id": "C-004",
          "description": "Cannot cancel a shipped order"
        },
        {
          "constraint_id": "C-005",
          "description": "Cancellation must be atomic"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-005",
          "description": "Order status updated to cancelled"
        },
        {
          "ac_id": "AC-006",
          "description": "Inventory restored correctly"
        },
        {
          "ac_id": "AC-007",
          "description": "Refund initiated"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-002"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "TrackOrder",
