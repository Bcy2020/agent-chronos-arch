{
  "children": [
    {
      "name": "ParseCommand",
      "purpose": "Extract and validate the command type from input",
      "behavior": "Parse input JSON to extract command field, validate it is one of 'place', 'cancel', 'track'",
      "boundary": {
        "in_scope": [
          "command extraction",
          "command validation"
        ],
        "out_of_scope": [
          "order data validation",
          "business logic"
        ]
      },
      "preconditions": [
        "input is valid JSON"
      ],
      "postconditions": [
        "command is one of place/cancel/track"
      ],
      "guarantees": [
        "returns error if command missing or invalid"
      ],
      "composition_role": "validate",
      "call_inputs": [
        {
          "name": "input",
          "type": "dict",
          "description": "Raw input JSON from parent",
          "source": "parent input"
        }
      ],
      "internal_leaf_accesses": [],
      "outputs": [
        {
          "name": "command",
          "type": "str",
          "description": "Validated command string",
          "consumer": "parent"
        },
        {
          "name": "order_data",
          "type": "dict",
          "description": "Remaining input data",
          "consumer": "parent"
        }
      ],
      "signature": "def ParseCommand(input: dict) -> dict",
      "global_vars": [],
      "data_operations": [],
      "requested_capabilities": [],
      "constraints": [
        {
          "constraint_id": "C-001",
          "description": "Input must be valid JSON"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-001",
          "description": "Returns command and order_data for valid input"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-001",
          "FR-002",
          "FR-003"
        ]
      },
      "node_type": "pure_function",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "PlaceOrder",
      "purpose": "Execute order placement logic",
      "behavior": "Validate order data, check inventory, process payment, create order record, update inventory",
      "boundary": {
        "in_scope": [
          "order validation",
          "inventory check",
          "payment processing",
          "order creation"
        ],
        "out_of_scope": [
          "cancellation",
          "tracking"
        ]
      },
      "preconditions": [
        "order_data is valid",
        "inventory sufficient",
        "payment succeeds"
      ],
      "postconditions": [
        "order created in orders store",
        "inventory decremented",
        "payment recorded"
      ],
      "guarantees": [
        "atomic operation: all or nothing"
      ],
      "composition_role": "execute",
      "call_inputs": [
        {
          "name": "order_data",
          "type": "dict",
          "description": "Order details from ParseCommand",
          "source": "ParseCommand output"
        }
      ],
      "internal_leaf_accesses": [
        {
          "resource": "orders",
          "op": "read_write",
          "reason": "create order record"
        },
        {
          "resource": "inventory",
          "op": "read_write",
          "reason": "check and decrement inventory"
        },
        {
          "resource": "payments",
          "op": "read_write",
          "reason": "process payment"
        }
      ],
      "outputs": [
        {
          "name": "order_id",
          "type": "str",
          "description": "Generated order ID",
          "consumer": "parent"
        },
        {
          "name": "status",
          "type": "str",
          "description": "Order status after placement",
          "consumer": "parent"
        },
        {
          "name": "message",
          "type": "str",
          "description": "Success or error message",
          "consumer": "parent"
        }
      ],
      "signature": "def PlaceOrder(order_data: dict) -> dict",
      "global_vars": [
        {
          "variable": "orders",
          "op": "read_write",
          "description": "create order record"
        },
        {
          "variable": "inventory",
          "op": "read_write",
          "description": "check and decrement inventory"
        },
        {
          "variable": "payments",
          "op": "read_write",
          "description": "process payment"
        }
      ],
      "data_operations": [
        {
          "source_name": "orders",
          "operation_type": "read_write",
          "description": "create order record"
        },
        {
          "source_name": "inventory",
          "operation_type": "read_write",
          "description": "check and decrement inventory"
        },
        {
          "source_name": "payments",
          "operation_type": "read_write",
          "description": "process payment"
        }
      ],
      "requested_capabilities": [
        "orders.read_write",
        "inventory.read_write",
        "payments.read_write"
      ],
      "constraints": [
        {
          "constraint_id": "C-002",
          "description": "Order placement must be atomic"
        },
        {
          "constraint_id": "C-003",
          "description": "Inventory must be sufficient before decrement"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-002",
          "description": "Order is created with unique ID"
        },
        {
          "ac_id": "AC-003",
          "description": "Inventory is decremented correctly"
        },
        {
          "ac_id": "AC-004",
          "description": "Payment is processed successfully"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-001"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "CancelOrder",
