      "boundary": {
        "in_scope": [
          "order validation",
          "inventory check",
          "payment processing",
          "order creation"
        ],
        "out_of_scope": [
          "cancellation",
          "tracking"
        ]
      },
      "semantic_inputs": [
        {
          "name": "order_data",
          "description": "Order details including items, customer info",
          "source": "ParseCommand output"
        }
      ],
      "semantic_outputs": [
        {
          "name": "order_id",
          "description": "Generated order ID",
          "consumer": "parent"
        },
        {
          "name": "status",
          "description": "Order status after placement",
          "consumer": "parent"
        },
        {
          "name": "message",
          "description": "Success or error message",
          "consumer": "parent"
        }
