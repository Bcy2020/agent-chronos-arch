      "outputs": [
        {
          "name": "order_id",
          "type": "str",
          "description": "Cancelled order ID",
          "consumer": "parent"
        },
        {
          "name": "status",
          "type": "str",
          "description": "Updated order status",
          "consumer": "parent"
        },
        {
          "name": "message",
          "type": "str",
          "description": "Success or error message",
          "consumer": "parent"
        }
