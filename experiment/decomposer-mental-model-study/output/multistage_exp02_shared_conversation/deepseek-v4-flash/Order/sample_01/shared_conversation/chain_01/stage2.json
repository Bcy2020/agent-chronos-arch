          "resource": "orders",
          "op": "read_write",
          "reason": "Create order record"
        },
        {
          "resource": "inventory",
          "op": "read_write",
          "reason": "Check and decrement inventory"
        },
        {
          "resource": "payments",
          "op": "read_write",
          "reason": "Process payment"
        }
      ],
      "outputs": [
        {
          "name": "order_id",
          "type": "str",
          "description": "Generated order ID",
          "consumer": "parent"
        },
        {
          "name": "status",
          "type": "str",
          "description": "Order status after placement",
          "consumer": "parent"
        },
        {
          "name": "message",
          "type": "str",
          "description": "Success or error message",
          "consumer": "parent"
        }
