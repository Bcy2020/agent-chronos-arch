          "op": "read",
          "reason": "Lookup order status"
        }
      ],
      "outputs": [
        {
          "name": "order_id",
          "type": "str",
          "description": "Requested order ID",
          "consumer": "parent"
        },
        {
          "name": "status",
          "type": "str",
          "description": "Current order status",
          "consumer": "parent"
        },
        {
          "name": "message",
          "type": "str",
          "description": "Tracking details or error",
          "consumer": "parent"
