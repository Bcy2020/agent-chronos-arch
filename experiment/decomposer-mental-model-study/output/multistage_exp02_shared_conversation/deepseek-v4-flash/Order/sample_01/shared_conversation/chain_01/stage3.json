          "name": "order_id",
          "type": "str",
          "description": "Requested order ID",
          "consumer": "parent"
        },
        {
          "name": "status",
          "type": "str",
          "description": "Current order status",
          "consumer": "parent"
        },
        {
          "name": "message",
          "type": "str",
          "description": "Tracking details or error",
          "consumer": "parent"
        }
      ],
      "signature": "def TrackOrder(order_data: dict) -> dict",
      "global_vars": [
        {
          "variable": "orders",
          "op": "read",
          "description": "Lookup order status"
        }
      ],
      "data_operations": [
        {
          "source_name": "orders",
          "operation_type": "read",
          "description": "Lookup order status"
        }
      ],
      "requested_capabilities": [
        "orders.read"
      ],
      "constraints": [],
      "acceptance_criteria": [
        {
          "ac_id": "AC-009",
          "description": "Given existing order, return order_id, status, and tracking details"
        },
        {
          "ac_id": "AC-010",
          "description": "Given non-existent order, return error"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-003"
        ]
      },
      "node_type": "pure_function",
      "stop_decompose": false,
      "stop_reason": ""
    }
  ],
  "governance_notes": "ParseCommand is a pure function with no resource access. PlaceOrder and CancelOrder are atomic operations with read_write access to orders, inventory, and payments. TrackOrder is a pure function with read-only access to orders. All constraints from functional requirements are captured. Acceptance criteria cover positive and negative scenarios.",
  "resource_audit": {
