{
  "children": [
    {
      "name": "ParseCommand",
      "purpose": "Extract and validate the command type from input",
      "behavior": "Parse input JSON to extract command field, validate it is one of 'place', 'cancel', 'track'",
      "boundary": {
        "in_scope": [
          "command extraction",
          "command validation"
        ],
        "out_of_scope": [
          "order data validation",
          "business logic"
        ]
      },
      "preconditions": [
        "input is valid JSON"
      ],
      "postconditions": [
        "command is one of place/cancel/track"
      ],
      "guarantees": [
        "returns error if command missing or invalid"
      ],
      "composition_role": "validate",
      "call_inputs": [
        {
          "name": "input",
          "type": "dict",
          "description": "Raw input JSON from parent",
          "source": "parent input"
        }
      ],
      "internal_leaf_accesses": [],
      "outputs": [
        {
          "name": "command",
          "type": "str",
          "description": "Validated command string",
          "consumer": "parent"
        },
        {
          "name": "order_data",
          "type": "dict",
          "description": "Remaining input data",
          "consumer": "parent"
        }
      ],
      "signature": "def ParseCommand(input: dict) -> dict",
      "global_vars": [],
      "data_operations": [],
      "requested_capabilities": [],
      "constraints": [],
      "acceptance_criteria": [
        {
          "ac_id": "AC-001",
          "description": "Given valid JSON with command field, ParseCommand returns command and order_data"
        },
        {
          "ac_id": "AC-002",
          "description": "Given invalid JSON, ParseCommand returns error"
        }
      ],
      "traceability": {
        "parent_requirement_ids": []
      },
      "node_type": "pure_function",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "PlaceOrder",
      "purpose": "Execute order placement logic",
      "behavior": "Validate order data, check inventory, process payment, create order record, update inventory",
      "boundary": {
        "in_scope": [
          "order validation",
          "inventory check",
          "payment processing",
          "order creation"
        ],
        "out_of_scope": [
          "cancellation",
          "tracking"
        ]
      },
      "preconditions": [
        "order_data is valid",
        "inventory sufficient",
        "payment succeeds"
      ],
      "postconditions": [
        "order created in orders store",
        "inventory decremented",
        "payment recorded"
      ],
      "guarantees": [
        "atomic operation: all or nothing"
      ],
      "composition_role": "execute",
      "call_inputs": [
        {
          "name": "order_data",
          "type": "dict",
          "description": "Order details from ParseCommand",
          "source": "ParseCommand output"
        }
      ],
      "internal_leaf_accesses": [
        {
          "resource": "orders",
          "op": "read_write",
          "reason": "Create order record"
        },
        {
          "resource": "inventory",
          "op": "read_write",
          "reason": "Check and decrement inventory"
        },
        {
          "resource": "payments",
          "op": "read_write",
          "reason": "Process payment"
        }
      ],
      "outputs": [
        {
          "name": "order_id",
          "type": "str",
          "description": "Generated order ID",
          "consumer": "parent"
        },
        {
          "name": "status",
          "type": "str",
          "description": "Order status after placement",
          "consumer": "parent"
        },
        {
          "name": "message",
          "type": "str",
          "description": "Success or error message",
          "consumer": "parent"
        }
      ],
      "signature": "def PlaceOrder(order_data: dict) -> dict",
      "global_vars": [
        {
          "variable": "orders",
          "op": "read_write",
          "description": "Create order record"
        },
        {
          "variable": "inventory",
          "op": "read_write",
          "description": "Check and decrement inventory"
        },
        {
          "variable": "payments",
          "op": "read_write",
          "description": "Process payment"
        }
      ],
      "data_operations": [
        {
          "source_name": "orders",
          "operation_type": "read_write",
          "description": "Create order record"
        },
        {
          "source_name": "inventory",
          "operation_type": "read_write",
          "description": "Check and decrement inventory"
        },
        {
          "source_name": "payments",
          "operation_type": "read_write",
          "description": "Process payment"
        }
      ],
      "requested_capabilities": [
        "orders.read_write",
        "inventory.read_write",
        "payments.read_write"
      ],
      "constraints": [
        {
          "constraint_id": "C-001",
          "description": "All operations must be atomic"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-003",
          "description": "Given valid order_data and sufficient inventory, order is created, inventory decremented, payment recorded"
        },
        {
          "ac_id": "AC-004",
          "description": "Given insufficient inventory, order is not created and error returned"
        },
        {
          "ac_id": "AC-005",
          "description": "Given payment failure, order is not created and error returned"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-001"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "CancelOrder",
      "purpose": "Execute order cancellation logic",
      "behavior": "Validate order exists, check order is not shipped, update order status to cancelled, restore inventory, process refund",
      "boundary": {
        "in_scope": [
          "order lookup",
          "status check",
          "inventory restoration",
          "refund processing"
        ],
        "out_of_scope": [
          "placement",
          "tracking"
        ]
      },
      "preconditions": [
        "order exists",
        "order not shipped"
      ],
      "postconditions": [
        "order status set to cancelled",
        "inventory restored",
        "refund initiated"
      ],
      "guarantees": [
        "atomic operation: all or nothing"
      ],
      "composition_role": "execute",
      "call_inputs": [
        {
          "name": "order_data",
          "type": "dict",
          "description": "Contains order_id to cancel",
          "source": "ParseCommand output"
        }
      ],
      "internal_leaf_accesses": [
        {
          "resource": "orders",
          "op": "read_write",
          "reason": "Lookup and update order status"
        },
        {
          "resource": "inventory",
          "op": "read_write",
          "reason": "Restore inventory"
        },
        {
          "resource": "payments",
          "op": "read_write",
          "reason": "Process refund"
        }
      ],
      "outputs": [
        {
          "name": "order_id",
          "type": "str",
          "description": "Cancelled order ID",
          "consumer": "parent"
        },
        {
          "name": "status",
          "type": "str",
          "description": "Updated order status",
          "consumer": "parent"
        },
        {
          "name": "message",
          "type": "str",
          "description": "Success or error message",
          "consumer": "parent"
        }
      ],
      "signature": "def CancelOrder(order_data: dict) -> dict",
      "global_vars": [
        {
          "variable": "orders",
          "op": "read_write",
          "description": "Lookup and update order status"
        },
        {
          "variable": "inventory",
          "op": "read_write",
          "description": "Restore inventory"
        },
        {
          "variable": "payments",
          "op": "read_write",
          "description": "Process refund"
        }
      ],
      "data_operations": [
        {
          "source_name": "orders",
          "operation_type": "read_write",
          "description": "Lookup and update order status"
        },
        {
          "source_name": "inventory",
          "operation_type": "read_write",
          "description": "Restore inventory"
        },
        {
          "source_name": "payments",
          "operation_type": "read_write",
          "description": "Process refund"
        }
      ],
      "requested_capabilities": [
        "orders.read_write",
        "inventory.read_write",
        "payments.read_write"
      ],
      "constraints": [
        {
          "constraint_id": "C-002",
          "description": "Cannot cancel a shipped order"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-006",
          "description": "Given existing order not shipped, order is cancelled, inventory restored, refund initiated"
        },
        {
          "ac_id": "AC-007",
          "description": "Given shipped order, cancellation fails with error"
        },
        {
          "ac_id": "AC-008",
          "description": "Given non-existent order, cancellation fails with error"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-002"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "TrackOrder",
      "purpose": "Retrieve and return order tracking information",
      "behavior": "Look up order by ID, return current status and tracking details",
      "boundary": {
        "in_scope": [
          "order lookup",
          "status retrieval"
        ],
        "out_of_scope": [
          "order modification",
          "payment"
        ]
      },
      "preconditions": [
        "order exists"
      ],
      "postconditions": [
        "order data read without modification"
      ],
      "guarantees": [
        "read-only operation"
      ],
      "composition_role": "query",
      "call_inputs": [
        {
          "name": "order_data",
          "type": "dict",
          "description": "Contains order_id to track",
          "source": "ParseCommand output"
        }
      ],
      "internal_leaf_accesses": [
