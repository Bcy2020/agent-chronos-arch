{
  "children": [
    {
      "name": "IngestData",
      "purpose": "Read data from external source and store in raw_data",
      "behavior": "Reads input source, parses data, writes to raw_data store, logs ingestion",
      "boundary": {
        "in_scope": [
          "reading source",
          "parsing",
          "writing to raw_data",
          "logging"
        ],
        "out_of_scope": [
          "transformation",
          "validation",
          "export"
        ]
      },
      "semantic_inputs": [
        {
          "name": "input",
          "description": "JSON with action and source",
          "source": "parent input"
        }
      ],
      "semantic_outputs": [
        {
          "name": "ingest_result",
          "description": "JSON with success, records_ingested, errors",
          "consumer": "parent"
        }
      ],
      "preconditions": [
        "input.action == 'ingest'",
        "source is accessible"
      ],
      "postconditions": [
        "raw_data contains ingested records"
      ],
      "guarantees": [
        "logs ingestion details"
      ],
      "composition_role": "execute",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "TransformData",
      "purpose": "Apply transformations to raw data and store in processed_data",
      "behavior": "Reads raw_data, applies transformation rules, writes to processed_data, logs transformation",
      "boundary": {
        "in_scope": [
          "reading raw_data",
          "transforming",
          "writing to processed_data",
          "logging"
        ],
        "out_of_scope": [
          "ingestion",
          "validation",
          "export"
        ]
      },
      "semantic_inputs": [
        {
          "name": "input",
          "description": "JSON with action",
          "source": "parent input"
        }
      ],
      "semantic_outputs": [
        {
          "name": "transform_result",
          "description": "JSON with success, records_transformed, errors",
          "consumer": "parent"
        }
      ],
      "preconditions": [
        "input.action == 'transform'",
        "raw_data is not empty"
      ],
      "postconditions": [
        "processed_data contains transformed records"
      ],
      "guarantees": [
        "logs transformation details"
      ],
      "composition_role": "execute",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "ValidateQuality",
      "purpose": "Validate records in processed_data and mark valid/invalid",
      "behavior": "Reads processed_data, applies validation rules, updates processed_data with validity flag, logs validation",
      "boundary": {
        "in_scope": [
          "reading processed_data",
          "validating",
          "updating processed_data",
          "logging"
        ],
        "out_of_scope": [
          "ingestion",
          "transformation",
          "export"
        ]
      },
      "semantic_inputs": [
        {
          "name": "input",
          "description": "JSON with action",
          "source": "parent input"
        }
      ],
      "semantic_outputs": [
        {
          "name": "validate_result",
          "description": "JSON with success, records_valid, records_invalid, errors",
          "consumer": "parent"
        }
      ],
      "preconditions": [
        "input.action == 'validate'",
        "processed_data is not empty"
      ],
      "postconditions": [
        "processed_data records have validity flag"
      ],
      "guarantees": [
        "logs validation details"
      ],
      "composition_role": "validate",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "ExportResults",
      "purpose": "Export only valid records from processed_data to output",
      "behavior": "Reads processed_data, filters valid records, formats output, logs export",
      "boundary": {
        "in_scope": [
          "reading processed_data",
          "filtering valid",
          "formatting output",
          "logging"
        ],
        "out_of_scope": [
          "ingestion",
          "transformation",
          "validation"
        ]
      },
      "semantic_inputs": [
        {
          "name": "input",
          "description": "JSON with action",
          "source": "parent input"
        }
      ],
      "semantic_outputs": [
        {
          "name": "export_result",
          "description": "JSON with success, records_exported, errors, data",
          "consumer": "parent"
        }
      ],
      "preconditions": [
        "input.action == 'export'",
        "processed_data contains valid records"
      ],
      "postconditions": [
        "output contains exported data"
      ],
      "guarantees": [
        "only valid records exported",
        "logs export details"
      ],
      "composition_role": "execute",
      "stop_decompose": false,
      "stop_reason": ""
    }
  ],
  "decomposition_rationale": "Each functional requirement maps to a child function that handles one step of the ETL pipeline. Children are independent and do not call each other; parent orchestrates based on action.",
  "orchestration_model": "conditional",
  "dataflow_sketch": [
    {
      "from": "parent",
      "to": "IngestData",
      "data": "input",
      "note": "action=ingest"
    },
    {
      "from": "parent",
      "to": "TransformData",
      "data": "input",
      "note": "action=transform"
    },
    {
      "from": "parent",
      "to": "ValidateQuality",
      "data": "input",
      "note": "action=validate"
    },
    {
      "from": "parent",
      "to": "ExportResults",
      "data": "input",
      "note": "action=export"
    },
    {
      "from": "IngestData",
      "to": "parent",
      "data": "ingest_result",
      "note": "return result"
    },
    {
      "from": "TransformData",
      "to": "parent",
      "data": "transform_result",
      "note": "return result"
    },
    {
      "from": "ValidateQuality",
      "to": "parent",
      "data": "validate_result",
      "note": "return result"
    },
    {
      "from": "ExportResults",
      "to": "parent",
      "data": "export_result",
      "note": "return result"
    }
  ]
}