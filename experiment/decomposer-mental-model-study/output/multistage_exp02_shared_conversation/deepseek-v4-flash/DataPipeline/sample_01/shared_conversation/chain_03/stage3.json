{
  "children": [
    {
      "name": "IngestData",
      "purpose": "Read data from external source and store in raw_data",
      "behavior": "Reads input source, parses data, writes to raw_data store, logs ingestion",
      "boundary": {
        "in_scope": [
          "reading source",
          "parsing",
          "writing to raw_data",
          "logging"
        ],
        "out_of_scope": [
          "transformation",
          "validation",
          "export"
        ]
      },
      "preconditions": [
        "input.action == 'ingest'",
        "source is accessible"
      ],
      "postconditions": [
        "raw_data contains ingested records"
      ],
      "guarantees": [
        "logs ingestion details"
      ],
      "composition_role": "execute",
      "call_inputs": [
        {
          "name": "source",
          "type": "str",
          "description": "source location from parent input",
          "source": "parent input.source"
        }
      ],
      "internal_leaf_accesses": [
        {
          "resource": "raw_data",
          "op": "write",
          "reason": "store ingested records"
        }
      ],
      "outputs": [
        {
          "name": "ingest_result",
          "type": "dict",
          "description": "JSON with success, records_ingested, errors",
          "consumer": "parent"
        }
      ],
      "signature": "def IngestData(source: str) -> dict",
      "global_vars": [
        {
          "variable": "raw_data",
          "op": "write",
          "description": "write ingested records"
        }
      ],
      "data_operations": [
        {
          "source_name": "raw_data",
          "operation_type": "write",
          "description": "write ingested records"
        }
      ],
      "requested_capabilities": [
        "raw_data.write"
      ],
      "constraints": [
        {
          "constraint_id": "C-001",
          "description": "Source must be accessible and parseable"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-001",
          "description": "Records are written to raw_data without error"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-001"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "TransformData",
      "purpose": "Apply transformations to raw data and store in processed_data",
      "behavior": "Reads raw_data, applies transformation rules, writes to processed_data, logs transformation",
      "boundary": {
        "in_scope": [
          "reading raw_data",
          "transforming",
          "writing to processed_data",
          "logging"
        ],
        "out_of_scope": [
          "ingestion",
          "validation",
          "export"
        ]
      },
      "preconditions": [
        "input.action == 'transform'",
        "raw_data is not empty"
      ],
      "postconditions": [
        "processed_data contains transformed records"
      ],
      "guarantees": [
        "logs transformation details"
      ],
      "composition_role": "execute",
      "call_inputs": [
        {
          "name": "transform_rules",
          "type": "dict",
          "description": "transformation rules from parent input",
          "source": "parent input.transform_rules"
        }
      ],
      "internal_leaf_accesses": [
        {
          "resource": "raw_data",
          "op": "read",
          "reason": "read raw records to transform"
        },
        {
          "resource": "processed_data",
          "op": "write",
          "reason": "store transformed records"
        }
      ],
      "outputs": [
        {
          "name": "transform_result",
          "type": "dict",
          "description": "JSON with success, records_transformed, errors",
          "consumer": "parent"
        }
      ],
      "signature": "def TransformData(transform_rules: dict) -> dict",
      "global_vars": [
        {
          "variable": "raw_data",
          "op": "read",
          "description": "read raw records"
        },
        {
          "variable": "processed_data",
          "op": "write",
          "description": "write transformed records"
        }
      ],
      "data_operations": [
        {
          "source_name": "raw_data",
          "operation_type": "read",
          "description": "read raw records"
        },
        {
          "source_name": "processed_data",
          "operation_type": "write",
          "description": "write transformed records"
        }
      ],
      "requested_capabilities": [
        "raw_data.read",
        "processed_data.write"
      ],
      "constraints": [
        {
          "constraint_id": "C-002",
          "description": "Transformation rules must be valid"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-002",
          "description": "Transformed records are written to processed_data without error"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-002"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "ValidateQuality",
      "purpose": "Validate records in processed_data and mark valid/invalid",
      "behavior": "Reads processed_data, applies validation rules, updates processed_data with validity flag, logs validation",
      "boundary": {
        "in_scope": [
          "reading processed_data",
          "validating",
          "updating processed_data",
          "logging"
        ],
        "out_of_scope": [
          "ingestion",
          "transformation",
          "export"
        ]
      },
      "preconditions": [
        "input.action == 'validate'",
        "processed_data is not empty"
      ],
      "postconditions": [
        "processed_data records have validity flag"
      ],
      "guarantees": [
        "logs validation details"
      ],
      "composition_role": "validate",
      "call_inputs": [
        {
          "name": "validation_rules",
          "type": "dict",
          "description": "validation rules from parent input",
          "source": "parent input.validation_rules"
        }
      ],
      "internal_leaf_accesses": [
        {
          "resource": "processed_data",
          "op": "read_write",
          "reason": "read records and update validity flag"
        }
      ],
      "outputs": [
        {
          "name": "validate_result",
          "type": "dict",
          "description": "JSON with success, records_valid, records_invalid, errors",
          "consumer": "parent"
        }
      ],
      "signature": "def ValidateQuality(validation_rules: dict) -> dict",
      "global_vars": [
        {
          "variable": "processed_data",
          "op": "read_write",
          "description": "read records and update validity flag"
        }
      ],
      "data_operations": [
        {
          "source_name": "processed_data",
          "operation_type": "read_write",
          "description": "read records and update validity flag"
        }
      ],
      "requested_capabilities": [
        "processed_data.read_write"
      ],
      "constraints": [
        {
          "constraint_id": "C-003",
          "description": "Validation rules must be valid"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-003",
          "description": "Records in processed_data have validity flag set correctly"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-003"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "ExportResults",
      "purpose": "Export only valid records from processed_data to output",
      "behavior": "Reads processed_data, filters valid records, formats output, logs export",
      "boundary": {
        "in_scope": [
          "reading processed_data",
          "filtering valid",
          "formatting output",
          "logging"
        ],
        "out_of_scope": [
          "ingestion",
          "transformation",
          "validation"
        ]
      },
      "preconditions": [
        "input.action == 'export'",
        "processed_data contains valid records"
      ],
      "postconditions": [
        "output contains exported data"
      ],
      "guarantees": [
        "only valid records exported",
        "logs export details"
      ],
      "composition_role": "execute",
      "call_inputs": [
        {
          "name": "format",
          "type": "str",
          "description": "export format from parent input",
          "source": "parent input.format"
        }
      ],
      "internal_leaf_accesses": [
        {
          "resource": "processed_data",
          "op": "read",
          "reason": "read records to filter valid ones"
        }
      ],
      "outputs": [
        {
          "name": "export_result",
          "type": "dict",
          "description": "JSON with success, records_exported, errors, data",
          "consumer": "parent"
        }
      ],
      "signature": "def ExportResults(format: str) -> dict",
      "global_vars": [
        {
          "variable": "processed_data",
          "op": "read",
          "description": "read records to filter valid ones"
        }
      ],
      "data_operations": [
        {
          "source_name": "processed_data",
          "operation_type": "read",
          "description": "read records to filter valid ones"
        }
      ],
      "requested_capabilities": [
        "processed_data.read"
      ],
      "constraints": [
        {
          "constraint_id": "C-004",
          "description": "Export format must be supported"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-004",
          "description": "Only valid records are exported in the specified format"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-004"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": false,
      "stop_reason": ""
    }
  ],
  "governance_notes": "All children are atomic operations with direct resource access. No further decomposition needed. Constraints and acceptance criteria derived from preconditions/postconditions and functional requirements.",
  "resource_audit": {
