    "global_vars_data_operations_sync_detail": "global_vars and data_operations are fully synchronized for each child; each resource/op appears in both lists.",
    "coverage_detail": "All resources (raw_data, processed_data) are covered with appropriate operations per child. No missing or extra resources.",
    "final_status": "ok"
  }
