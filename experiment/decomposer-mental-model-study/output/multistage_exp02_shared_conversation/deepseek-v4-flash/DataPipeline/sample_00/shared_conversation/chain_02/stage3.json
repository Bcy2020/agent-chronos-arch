{
  "children": [
    {
      "name": "IngestData",
      "purpose": "Read raw data from source and store in raw_data store",
      "behavior": "Reads input source, parses data, writes to raw_data store, logs ingestion",
      "boundary": {
        "in_scope": [
          "reading source",
          "parsing",
          "storing raw data",
          "logging"
        ],
        "out_of_scope": [
          "transformation",
          "validation",
          "export"
        ]
      },
      "preconditions": [
        "input.action == 'ingest'"
      ],
      "postconditions": [
        "raw_data store contains ingested records"
      ],
      "guarantees": [
        "logs ingestion details"
      ],
      "composition_role": "execute",
      "call_inputs": [
        {
          "name": "source",
          "type": "str",
          "description": "source identifier from parent input",
          "source": "parent input"
        }
      ],
      "internal_leaf_accesses": [
        {
          "resource": "raw_data",
          "op": "write",
          "reason": "store ingested records"
        }
      ],
      "outputs": [
        {
          "name": "ingest_result",
          "type": "dict",
          "description": "JSON with success, records_ingested, errors",
          "consumer": "parent"
        }
      ],
      "signature": "def IngestData(source: str) -> dict",
      "global_vars": [
        {
          "variable": "raw_data",
          "op": "write",
          "description": "write ingested records to raw_data store"
        }
      ],
      "data_operations": [
        {
          "source_name": "raw_data",
          "operation_type": "write",
          "description": "store ingested records"
        }
      ],
      "requested_capabilities": [
        "raw_data.write"
      ],
      "constraints": [
        {
          "constraint_id": "C-001",
          "description": "source must be a valid URI or file path"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-001",
          "description": "records are successfully written to raw_data store"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-001"
        ]
      },
      "node_type": "pure_function",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "TransformData",
      "purpose": "Apply transformations to raw data and store in processed_data",
      "behavior": "Reads raw_data, applies transformation rules, writes to processed_data, logs transformation",
      "boundary": {
        "in_scope": [
          "reading raw_data",
          "transformation logic",
          "writing processed_data",
          "logging"
        ],
        "out_of_scope": [
          "ingestion",
          "validation",
          "export"
        ]
      },
      "preconditions": [
        "input.action == 'transform'",
        "raw_data store is populated"
      ],
      "postconditions": [
        "processed_data store contains transformed records"
      ],
      "guarantees": [
        "logs transformation details"
      ],
      "composition_role": "execute",
      "call_inputs": [
        {
          "name": "transform_params",
          "type": "dict",
          "description": "transformation parameters from parent input",
          "source": "parent input"
        }
      ],
      "internal_leaf_accesses": [
        {
          "resource": "raw_data",
          "op": "read",
          "reason": "read raw records for transformation"
        },
        {
          "resource": "processed_data",
          "op": "write",
          "reason": "store transformed records"
        }
      ],
      "outputs": [
        {
          "name": "transform_result",
          "type": "dict",
          "description": "JSON with success, records_transformed, errors",
          "consumer": "parent"
        }
      ],
      "signature": "def TransformData(transform_params: dict) -> dict",
      "global_vars": [
        {
          "variable": "raw_data",
          "op": "read",
          "description": "read raw records for transformation"
        },
        {
          "variable": "processed_data",
          "op": "write",
          "description": "write transformed records to processed_data store"
        }
      ],
      "data_operations": [
        {
          "source_name": "raw_data",
          "operation_type": "read",
          "description": "read raw records for transformation"
        },
        {
          "source_name": "processed_data",
          "operation_type": "write",
          "description": "store transformed records"
        }
      ],
      "requested_capabilities": [
        "raw_data.read",
        "processed_data.write"
      ],
      "constraints": [
        {
          "constraint_id": "C-002",
          "description": "transformation rules must be valid JSON"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-002",
          "description": "transformed records are written to processed_data store"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-002"
        ]
      },
      "node_type": "pure_function",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "ValidateData",
      "purpose": "Check quality of processed data and mark invalid records",
      "behavior": "Reads processed_data, applies validation rules, marks invalid records, logs validation",
      "boundary": {
        "in_scope": [
          "reading processed_data",
          "validation rules",
          "marking invalid records",
          "logging"
        ],
        "out_of_scope": [
          "ingestion",
          "transformation",
          "export"
        ]
      },
      "preconditions": [
        "input.action == 'validate'",
        "processed_data store is populated"
      ],
      "postconditions": [
        "processed_data store has validity flags"
      ],
      "guarantees": [
        "logs validation details"
      ],
      "composition_role": "validate",
      "call_inputs": [
        {
          "name": "validation_rules",
          "type": "dict",
          "description": "validation rules from parent input",
          "source": "parent input"
        }
      ],
      "internal_leaf_accesses": [
        {
          "resource": "processed_data",
          "op": "read_write",
          "reason": "read records and mark validity flags"
        }
      ],
      "outputs": [
        {
          "name": "validate_result",
          "type": "dict",
          "description": "JSON with success, records_valid, records_invalid, errors",
          "consumer": "parent"
        }
      ],
      "signature": "def ValidateData(validation_rules: dict) -> dict",
      "global_vars": [
        {
          "variable": "processed_data",
          "op": "read_write",
          "description": "read records and mark validity flags"
        }
      ],
      "data_operations": [
        {
          "source_name": "processed_data",
          "operation_type": "read_write",
          "description": "read records and mark validity flags"
        }
      ],
      "requested_capabilities": [
        "processed_data.read_write"
      ],
      "constraints": [
        {
          "constraint_id": "C-003",
          "description": "validation rules must be valid JSON"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-003",
          "description": "validity flags are set on processed_data records"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-003"
        ]
      },
      "node_type": "pure_function",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "ExportData",
      "purpose": "Export only valid records from processed_data to output",
      "behavior": "Reads processed_data, filters valid records, formats output, logs export",
      "boundary": {
        "in_scope": [
          "reading processed_data",
          "filtering valid records",
          "formatting output",
          "logging"
        ],
        "out_of_scope": [
          "ingestion",
          "transformation",
          "validation"
        ]
      },
      "preconditions": [
        "input.action == 'export'",
        "processed_data store has validity flags"
      ],
      "postconditions": [
        "output contains only valid records"
      ],
      "guarantees": [
        "logs export details"
      ],
      "composition_role": "execute",
      "call_inputs": [
        {
          "name": "export_format",
          "type": "str",
          "description": "desired output format from parent input",
          "source": "parent input"
        }
      ],
      "internal_leaf_accesses": [
        {
          "resource": "processed_data",
          "op": "read",
          "reason": "read processed records to filter valid ones"
        }
      ],
      "outputs": [
        {
          "name": "export_result",
          "type": "dict",
          "description": "JSON with success, records_exported, errors, data",
          "consumer": "parent"
        }
      ],
      "signature": "def ExportData(export_format: str) -> dict",
      "global_vars": [
        {
          "variable": "processed_data",
          "op": "read",
          "description": "read processed records to filter valid ones"
        }
      ],
      "data_operations": [
        {
          "source_name": "processed_data",
          "operation_type": "read",
          "description": "read processed records to filter valid ones"
        }
      ],
      "requested_capabilities": [
        "processed_data.read"
      ],
      "constraints": [
        {
          "constraint_id": "C-004",
          "description": "export_format must be a supported format string"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-004",
          "description": "output contains only valid records in the specified format"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-004"
        ]
      },
      "node_type": "pure_function",
      "stop_decompose": false,
      "stop_reason": ""
    }
  ],
  "governance_notes": "All children are pure functions with no side effects beyond the declared data stores. Constraints and acceptance criteria are derived from functional requirements and preconditions.",
  "resource_audit": {
    "signature_preservation_detail": "All signatures remain unchanged from Stage 2.",
    "internal_leaf_mapping_detail": "Each internal_leaf_accesses entry is directly mapped to a global_vars and data_operations entry with same resource and operation.",
    "global_vars_data_operations_sync_detail": "global_vars and data_operations are synchronized: each resource/op appears in both lists for each child.",
    "coverage_detail": "All resources (raw_data, processed_data) are covered by the children that access them. No resource is accessed by a child without being declared.",
    "final_status": "ok"
  }
}