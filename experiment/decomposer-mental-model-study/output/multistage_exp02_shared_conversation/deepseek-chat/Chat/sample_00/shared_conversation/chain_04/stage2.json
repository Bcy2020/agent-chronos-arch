{
  "interfaces": [
    {
      "child_name": "ParseCommand",
      "call_inputs": [
        {
          "name": "input",
          "type": "Any",
          "description": "Raw JSON input from parent containing command field",
          "source": "parent input"
        }
      ],
      "call_outputs": [
        {
          "name": "command",
          "type": "String",
          "description": "Validated command string (send/history/create_channel/join)",
          "consumer": "parent"
        },
        {
          "name": "payload",
          "type": "Any",
          "description": "Remaining JSON fields after command extraction",
          "consumer": "parent"
        }
      ],
      "internal_leaf_accesses": []
    },
    {
      "child_name": "SendMessage",
      "call_inputs": [
        {
          "name": "payload",
          "type": "Any",
          "description": "Contains channel, user, and message content",
          "source": "parent input (from ParseCommand)"
        }
      ],
      "call_outputs": [
        {
          "name": "result",
          "type": "Any",
          "description": "Success or error response",
          "consumer": "parent"
        }
      ],
      "internal_leaf_accesses": [
        {
          "data_store": "messages",
          "access_type": "read_write",
          "description": "Store new message with timestamp and user info"
        },
        {
          "data_store": "channels",
          "access_type": "read",
          "description": "Check user membership in the channel"
        }
      ]
    },
    {
      "child_name": "GetHistory",
      "call_inputs": [
        {
          "name": "payload",
          "type": "Any",
          "description": "Contains channel and user",
          "source": "parent input (from ParseCommand)"
        }
      ],
      "call_outputs": [
        {
          "name": "result",
          "type": "Any",
          "description": "List of messages or error",
          "consumer": "parent"
        }
      ],
      "internal_leaf_accesses": [
        {
          "data_store": "messages",
          "access_type": "read",
          "description": "Fetch last 100 messages for the channel"
        },
        {
          "data_store": "channels",
          "access_type": "read",
          "description": "Check user membership in the channel"
        }
      ]
    },
    {
      "child_name": "CreateChannel",
      "call_inputs": [
        {
          "name": "payload",
          "type": "Any",
          "description": "Contains channel name and creator user",
          "source": "parent input (from ParseCommand)"
        }
      ],
      "call_outputs": [
        {
          "name": "result",
          "type": "Any",
          "description": "Success or error response",
          "consumer": "parent"
        }
      ],
      "internal_leaf_accesses": [
        {
          "data_store": "channels",
          "access_type": "read_write",
          "description": "Check uniqueness and create new channel with initial member"
        }
      ]
    },
    {
      "child_name": "JoinChannel",
      "call_inputs": [
        {
          "name": "payload",
          "type": "Any",
          "description": "Contains channel name and user",
          "source": "parent input (from ParseCommand)"
        }
      ],
      "call_outputs": [
        {
          "name": "result",
          "type": "Any",
          "description": "Success or error response",
          "consumer": "parent"
        }
      ],
      "internal_leaf_accesses": [
        {
          "data_store": "channels",
          "access_type": "read_write",
          "description": "Check channel existence and user membership, then add user"
        }
      ]
    }
  ]
}