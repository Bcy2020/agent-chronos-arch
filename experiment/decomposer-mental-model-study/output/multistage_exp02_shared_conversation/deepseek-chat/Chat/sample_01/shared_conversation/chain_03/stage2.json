{
  "children": [
    {
      "name": "ParseCommand",
      "call_inputs": [
        {
          "name": "input",
          "type": "Any",
          "description": "Raw JSON input from parent containing the command field"
        }
      ],
      "call_outputs": [
        {
          "name": "command",
          "type": "string",
          "description": "Extracted command string (send/history/create_channel/join)"
        },
        {
          "name": "error",
          "type": "string",
          "description": "Error message if command missing or invalid"
        }
      ],
      "internal_leaf_accesses": []
    },
    {
      "name": "SendMessage",
      "call_inputs": [
        {
          "name": "input",
          "type": "Any",
          "description": "Original input JSON with send details (channel_id, message content, user_id)"
        }
      ],
      "call_outputs": [
        {
          "name": "result",
          "type": "Any",
          "description": "JSON with success, data, message for send operation"
        }
      ],
      "internal_leaf_accesses": [
        {
          "name": "channels",
          "type": "data_store",
          "access": "read",
          "description": "Read channel membership data"
        },
        {
          "name": "messages",
          "type": "data_store",
          "access": "write",
          "description": "Append new message"
        }
      ]
    },
    {
      "name": "GetHistory",
      "call_inputs": [
        {
          "name": "input",
          "type": "Any",
          "description": "Original input JSON with channel_id"
        }
      ],
      "call_outputs": [
        {
          "name": "result",
          "type": "Any",
          "description": "JSON with success, data (list of messages), message"
        }
      ],
      "internal_leaf_accesses": [
        {
          "name": "channels",
          "type": "data_store",
          "access": "read",
          "description": "Check channel existence"
        },
        {
          "name": "messages",
          "type": "data_store",
          "access": "read",
          "description": "Retrieve messages"
        }
      ]
    },
    {
      "name": "CreateChannel",
      "call_inputs": [
        {
          "name": "input",
          "type": "Any",
          "description": "Original input JSON with channel_name"
        }
      ],
      "call_outputs": [
        {
          "name": "result",
          "type": "Any",
          "description": "JSON with success, data (channel details), message"
        }
      ],
      "internal_leaf_accesses": [
        {
          "name": "channels",
          "type": "data_store",
          "access": "read_write",
          "description": "Check uniqueness and create channel"
        }
      ]
    },
    {
      "name": "JoinChannel",
      "call_inputs": [
        {
          "name": "input",
          "type": "Any",
          "description": "Original input JSON with channel_id and user_id"
        }
      ],
      "call_outputs": [
        {
          "name": "result",
          "type": "Any",
          "description": "JSON with success, data, message"
        }
      ],
      "internal_leaf_accesses": [
        {
          "name": "channels",
          "type": "data_store",
          "access": "read_write",
          "description": "Read channel members and add user"
        }
      ]
    }
  ]
}