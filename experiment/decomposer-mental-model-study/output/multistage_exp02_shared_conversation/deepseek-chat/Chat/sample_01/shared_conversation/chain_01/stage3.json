        "timeout_ms": 100,
        "access_control": "none"
      },
      "resource_requirements": {
        "compute": "minimal",
        "memory_mb": 1,
        "global_vars": [],
        "data_operations": []
      }
    },
    {
      "name": "SendMessage",
      "governance": {
        "error_handling": "If channel not found or user not a member, return error; if message store write fails, return error",
        "retry_policy": "none",
        "timeout_ms": 500,
        "access_control": "Must be a member of the target channel"
      },
      "resource_requirements": {
        "compute": "low",
        "memory_mb": 10,
        "global_vars": [],
        "data_operations": [
          {
            "type": "read",
            "target": "channels",
            "description": "Check channel existence and user membership"
          },
          {
            "type": "write",
            "target": "messages",
            "description": "Append new message with timestamp"
          }
        ]
      }
    },
    {
      "name": "GetHistory",
      "governance": {
        "error_handling": "If channel not found, return error; if message store read fails, return error",
        "retry_policy": "none",
        "timeout_ms": 500,
        "access_control": "none"
      },
      "resource_requirements": {
        "compute": "low",
        "memory_mb": 10,
        "global_vars": [],
        "data_operations": [
          {
            "type": "read",
            "target": "channels",
            "description": "Check channel existence"
          },
          {
            "type": "read",
            "target": "messages",
            "description": "Retrieve up to 100 most recent messages"
          }
        ]
      }
    },
    {
