{
  "children": [
    {
      "name": "IngestData",
      "purpose": "Read and store raw input data into raw_data store",
      "behavior": "Parse input JSON, extract source, read data from source, store in raw_data, log ingestion",
      "boundary": {
        "in_scope": [
          "reading input source",
          "storing raw data",
          "logging ingestion"
        ],
        "out_of_scope": [
          "transformation",
          "validation",
          "export"
        ]
      },
      "preconditions": [
        "input contains valid source"
      ],
      "postconditions": [
        "raw_data store populated"
      ],
      "guarantees": [
        "raw_data is stored for further processing"
      ],
      "composition_role": "transform",
      "call_inputs": [
        {
          "name": "input",
          "type": "dict",
          "description": "JSON with action and source",
          "source": "parent input"
        }
      ],
      "internal_leaf_accesses": [
        {
          "resource": "raw_data",
          "op": "write",
          "reason": "store ingested raw data for downstream processing"
        }
      ],
      "outputs": [
        {
          "name": "ingestion_result",
          "type": "dict",
          "description": "JSON with success status and records count",
          "consumer": "parent"
        }
      ],
      "signature": "def IngestData(input: dict) -> dict",
      "global_vars": [
        {
          "variable": "raw_data",
          "op": "write",
          "description": "store ingested raw data for downstream processing"
        }
      ],
      "data_operations": [
        {
          "source_name": "raw_data",
          "operation_type": "write",
          "description": "store ingested raw data for downstream processing"
        }
      ],
      "requested_capabilities": [
        "raw_data.write"
      ],
      "constraints": [
        {
          "constraint_id": "C-001",
          "description": "raw_data must be writable"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-001",
          "description": "raw_data is populated after ingestion"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-001"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "TransformData",
      "purpose": "Apply transformation rules to raw data and store in processed_data",
      "behavior": "Read raw_data, apply transformations (e.g., cleaning, mapping), write to processed_data, log transformation",
      "boundary": {
        "in_scope": [
          "reading raw_data",
          "applying transformations",
          "writing processed_data",
          "logging"
        ],
        "out_of_scope": [
          "ingestion",
          "validation",
          "export"
        ]
      },
      "preconditions": [
        "raw_data is available"
      ],
      "postconditions": [
        "processed_data store populated"
      ],
      "guarantees": [
        "transformed data is stored"
      ],
      "composition_role": "transform",
      "call_inputs": [
        {
          "name": "trigger",
          "type": "dict",
          "description": "signal to start transformation",
          "source": "parent"
        }
      ],
      "internal_leaf_accesses": [
        {
          "resource": "raw_data",
          "op": "read",
          "reason": "read raw data for transformation"
        },
        {
          "resource": "processed_data",
          "op": "write",
          "reason": "store transformed data for validation"
        }
      ],
      "outputs": [
        {
          "name": "transformation_result",
          "type": "dict",
          "description": "JSON with success status and records transformed",
          "consumer": "parent"
        }
      ],
      "signature": "def TransformData(trigger: dict) -> dict",
      "global_vars": [
        {
          "variable": "raw_data",
          "op": "read",
          "description": "read raw data for transformation"
        },
        {
          "variable": "processed_data",
          "op": "write",
          "description": "store transformed data for validation"
        }
      ],
      "data_operations": [
        {
          "source_name": "raw_data",
          "operation_type": "read",
          "description": "read raw data for transformation"
        },
        {
          "source_name": "processed_data",
          "operation_type": "write",
          "description": "store transformed data for validation"
        }
      ],
      "requested_capabilities": [
        "raw_data.read",
        "processed_data.write"
      ],
      "constraints": [
        {
          "constraint_id": "C-002",
          "description": "raw_data must be readable"
        },
        {
          "constraint_id": "C-003",
          "description": "processed_data must be writable"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-002",
          "description": "processed_data is populated after transformation"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-001"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "ValidateQuality",
      "purpose": "Check processed data for quality and filter valid records",
      "behavior": "Read processed_data, apply validation rules (e.g., schema, range), mark invalid records, log validation results",
      "boundary": {
        "in_scope": [
          "reading processed_data",
          "validating records",
          "filtering invalid",
          "logging"
        ],
        "out_of_scope": [
          "ingestion",
          "transformation",
          "export"
        ]
      },
      "preconditions": [
        "processed_data is available"
      ],
      "postconditions": [
        "valid records identified"
      ],
      "guarantees": [
        "invalid records are excluded from export"
      ],
      "composition_role": "validate",
      "call_inputs": [
        {
          "name": "trigger",
          "type": "dict",
          "description": "signal to start validation",
          "source": "parent"
        }
      ],
      "internal_leaf_accesses": [
        {
          "resource": "processed_data",
          "op": "read",
          "reason": "read processed data for validation"
        }
      ],
      "outputs": [
        {
          "name": "validation_result",
          "type": "dict",
          "description": "JSON with valid records count and errors list",
          "consumer": "parent"
        }
      ],
      "signature": "def ValidateQuality(trigger: dict) -> dict",
      "global_vars": [
        {
          "variable": "processed_data",
          "op": "read",
          "description": "read processed data for validation"
        }
      ],
      "data_operations": [
        {
          "source_name": "processed_data",
          "operation_type": "read",
          "description": "read processed data for validation"
        }
      ],
      "requested_capabilities": [
        "processed_data.read"
      ],
      "constraints": [
        {
          "constraint_id": "C-004",
          "description": "processed_data must be readable"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-003",
          "description": "validation results produced"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-001"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "ExportResults",
      "purpose": "Export only valid records to output",
      "behavior": "Read valid records from processed_data (based on validation), format output JSON with success, records_processed, errors, data, log export",
      "boundary": {
        "in_scope": [
          "reading valid records",
          "formatting output",
          "logging export"
        ],
        "out_of_scope": [
          "ingestion",
          "transformation",
          "validation"
        ]
      },
      "preconditions": [
        "validation completed"
      ],
      "postconditions": [
        "output is produced"
      ],
      "guarantees": [
        "only valid records are exported"
      ],
      "composition_role": "execute",
      "call_inputs": [
        {
          "name": "validation_result",
          "type": "dict",
          "description": "validation results containing valid records info",
          "source": "ValidateQuality output"
        }
      ],
      "internal_leaf_accesses": [
        {
          "resource": "processed_data",
          "op": "read",
          "reason": "read processed data to extract valid records for export"
        }
      ],
      "outputs": [
        {
          "name": "output",
          "type": "dict",
          "description": "Final JSON with success, records_processed, errors, data",
          "consumer": "parent"
        }
      ],
      "signature": "def ExportResults(validation_result: dict) -> dict",
      "global_vars": [
        {
          "variable": "processed_data",
          "op": "read",
          "description": "read processed data to extract valid records for export"
        }
      ],
      "data_operations": [
        {
          "source_name": "processed_data",
          "operation_type": "read",
          "description": "read processed data to extract valid records for export"
        }
      ],
      "requested_capabilities": [
        "processed_data.read"
      ],
      "constraints": [
        {
          "constraint_id": "C-005",
          "description": "processed_data must be readable"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-004",
          "description": "output is produced with valid records"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-001"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": false,
      "stop_reason": ""
    }
  ],
  "governance_notes": "All children derive global_vars and data_operations directly from internal_leaf_accesses. Each resource operation in internal_leaf_accesses has a corresponding entry in both global_vars and data_operations. No exceptions needed. Capabilities are derived as resource.operation. Constraints enforce resource availability. Acceptance criteria verify resource state changes.",
  "resource_audit": {
