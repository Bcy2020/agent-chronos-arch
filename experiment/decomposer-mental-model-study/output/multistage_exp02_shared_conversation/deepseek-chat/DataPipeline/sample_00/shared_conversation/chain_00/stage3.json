{
  "children": [
    {
      "name": "IngestData",
      "governance": {
        "error_handling": {
          "on_failure": "log error and return failure in ingestion_result",
          "retry_policy": "none"
        },
        "logging": {
          "level": "info",
          "events": [
            "ingestion_start",
            "ingestion_complete",
            "ingestion_failed"
          ]
        },
        "security": {
          "input_validation": "validate source format before processing"
        }
      },
      "resources": {
        "global_vars": [],
        "data_operations": [
          {
            "store": "raw_data",
            "access": "read_write",
            "description": "Store raw ingested data"
          }
        ]
      }
    },
    {
      "name": "TransformData",
      "governance": {
        "error_handling": {
          "on_failure": "log error and return failure in transformation_result",
          "retry_policy": "none"
        },
        "logging": {
          "level": "info",
          "events": [
            "transformation_start",
            "transformation_complete",
            "transformation_failed"
          ]
        },
        "security": {
          "data_integrity": "ensure no data loss during transformation"
        }
      },
      "resources": {
        "global_vars": [],
        "data_operations": [
          {
            "store": "raw_data",
            "access": "read",
            "description": "Read raw data for transformation"
          },
          {
            "store": "processed_data",
            "access": "write",
            "description": "Write transformed data"
          }
        ]
      }
    },
    {
      "name": "ValidateQuality",
      "governance": {
        "error_handling": {
          "on_failure": "log error and return failure in validation_result",
          "retry_policy": "none"
        },
        "logging": {
          "level": "info",
          "events": [
            "validation_start",
            "validation_complete",
            "validation_failed"
          ]
        },
        "security": {
          "data_quality": "apply schema and range checks"
        }
      },
      "resources": {
        "global_vars": [],
        "data_operations": [
          {
            "store": "processed_data",
            "access": "read",
            "description": "Read processed data for validation"
          }
        ]
      }
    },
    {
      "name": "ExportResults",
      "governance": {
        "error_handling": {
          "on_failure": "log error and return failure in output",
          "retry_policy": "none"
        },
        "logging": {
          "level": "info",
          "events": [
            "export_start",
            "export_complete",
            "export_failed"
          ]
        },
        "security": {
          "output_sanitization": "ensure only valid records are included"
        }
      },
      "resources": {
        "global_vars": [],
        "data_operations": [
          {
            "store": "processed_data",
            "access": "read",
            "description": "Read processed data to export valid records"
          }
        ]
      }
    }
  ]
}