{
  "children": [
    {
      "name": "IngestData",
      "call_inputs": [
        {
          "name": "input",
          "type": "Any",
          "description": "JSON with action and source",
          "source": "parent input"
        }
      ],
      "internal_leaf_accesses": [
        {
          "name": "raw_data",
          "type": "memory",
          "access": "read_write",
          "description": "Store raw ingested data"
        }
      ],
      "call_outputs": [
        {
          "name": "ingestion_result",
          "type": "Any",
          "description": "JSON with success status and records count"
        }
      ]
    },
    {
      "name": "TransformData",
      "call_inputs": [],
      "internal_leaf_accesses": [
        {
          "name": "raw_data",
          "type": "memory",
          "access": "read",
          "description": "Read raw data for transformation"
        },
        {
          "name": "processed_data",
          "type": "memory",
          "access": "write",
          "description": "Write transformed data"
        }
      ],
      "call_outputs": [
        {
          "name": "transformation_result",
          "type": "Any",
          "description": "JSON with success status and records transformed"
        }
      ]
    },
    {
      "name": "ValidateQuality",
      "call_inputs": [],
      "internal_leaf_accesses": [
        {
          "name": "processed_data",
          "type": "memory",
          "access": "read",
          "description": "Read processed data for validation"
        }
      ],
      "call_outputs": [
        {
          "name": "validation_result",
          "type": "Any",
          "description": "JSON with valid records count and errors list"
        }
      ]
    },
    {
      "name": "ExportResults",
      "call_inputs": [
        {
          "name": "validation_result",
          "type": "Any",
          "description": "Validation results including valid records info",
          "source": "ValidateQuality output"
        }
      ],
      "internal_leaf_accesses": [
        {
          "name": "processed_data",
          "type": "memory",
          "access": "read",
          "description": "Read processed data to export valid records"
        }
      ],
      "call_outputs": [
        {
          "name": "output",
          "type": "Any",
          "description": "Final JSON with success, records_processed, errors, data"
        }
      ]
    }
  ]
}