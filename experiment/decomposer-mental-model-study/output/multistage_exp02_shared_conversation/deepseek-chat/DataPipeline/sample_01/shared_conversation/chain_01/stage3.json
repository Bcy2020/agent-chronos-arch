{
  "children": [
    {
      "name": "IngestData",
      "governance": {
        "max_retries": 3,
        "timeout_seconds": 30,
        "logging_level": "INFO",
        "error_handling": "fail_fast"
      },
      "resources": {
        "global_vars": [
          {
            "name": "raw_data",
            "type": "memory_store",
            "access": "write",
            "description": "Write ingested records to raw_data store"
          }
        ],
        "data_operations": [
          {
            "operation": "write",
            "store": "raw_data",
            "description": "Write ingested records to raw_data store"
          }
        ]
      }
    },
    {
      "name": "TransformData",
      "governance": {
        "max_retries": 3,
        "timeout_seconds": 60,
        "logging_level": "INFO",
        "error_handling": "fail_fast"
      },
      "resources": {
        "global_vars": [
          {
            "name": "raw_data",
            "type": "memory_store",
            "access": "read",
            "description": "Read raw data for transformation"
          },
          {
            "name": "processed_data",
            "type": "memory_store",
            "access": "write",
            "description": "Write transformed records to processed_data store"
          }
        ],
        "data_operations": [
          {
            "operation": "read",
            "store": "raw_data",
            "description": "Read raw data for transformation"
          },
          {
            "operation": "write",
            "store": "processed_data",
            "description": "Write transformed records to processed_data store"
          }
        ]
      }
    },
    {
      "name": "ValidateQuality",
      "governance": {
        "max_retries": 3,
        "timeout_seconds": 60,
        "logging_level": "INFO",
        "error_handling": "fail_fast"
      },
      "resources": {
        "global_vars": [
          {
            "name": "processed_data",
            "type": "memory_store",
            "access": "read_write",
            "description": "Read and update processed_data with validity flags"
          }
        ],
        "data_operations": [
          {
            "operation": "read",
            "store": "processed_data",
            "description": "Read processed_data for validation"
          },
          {
            "operation": "write",
            "store": "processed_data",
            "description": "Update processed_data with validity flags"
          }
        ]
      }
    },
    {
      "name": "ExportResults",
      "governance": {
        "max_retries": 3,
        "timeout_seconds": 30,
        "logging_level": "INFO",
        "error_handling": "fail_fast"
      },
      "resources": {
        "global_vars": [
          {
            "name": "processed_data",
            "type": "memory_store",
            "access": "read",
            "description": "Read processed_data to filter valid records for export"
          }
        ],
        "data_operations": [
          {
            "operation": "read",
            "store": "processed_data",
            "description": "Read processed_data to filter valid records for export"
          }
        ]
      }
    }
  ]
}