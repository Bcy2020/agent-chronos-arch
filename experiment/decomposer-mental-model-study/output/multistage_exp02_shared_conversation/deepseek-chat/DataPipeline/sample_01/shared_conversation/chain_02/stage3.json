{
  "children": [
    {
      "name": "IngestData",
      "governance": {
        "execution_mode": "synchronous",
        "retry_policy": {
          "max_retries": 3,
          "backoff_ms": 1000
        },
        "timeout_ms": 30000,
        "logging_level": "info",
        "error_handling": "fail_fast"
      },
      "resources": {
        "global_vars": [
          {
            "name": "raw_data",
            "type": "memory_store",
            "access": "write",
            "description": "Write ingested records to raw_data store"
          }
        ],
        "data_operations": [
          {
            "operation": "write",
            "target": "raw_data",
            "description": "Write ingested records to raw_data store"
          }
        ]
      }
    },
    {
      "name": "TransformData",
      "governance": {
        "execution_mode": "synchronous",
        "retry_policy": {
          "max_retries": 3,
          "backoff_ms": 1000
        },
        "timeout_ms": 60000,
        "logging_level": "info",
        "error_handling": "fail_fast"
      },
      "resources": {
        "global_vars": [
          {
            "name": "raw_data",
            "type": "memory_store",
            "access": "read",
            "description": "Read raw data for transformation"
          },
          {
            "name": "processed_data",
            "type": "memory_store",
            "access": "write",
            "description": "Write transformed records to processed_data store"
          }
        ],
        "data_operations": [
          {
            "operation": "read",
            "target": "raw_data",
            "description": "Read raw data for transformation"
          },
          {
            "operation": "write",
            "target": "processed_data",
            "description": "Write transformed records to processed_data store"
          }
        ]
      }
    },
    {
      "name": "ValidateQuality",
      "governance": {
        "execution_mode": "synchronous",
        "retry_policy": {
          "max_retries": 3,
          "backoff_ms": 1000
        },
        "timeout_ms": 60000,
        "logging_level": "info",
        "error_handling": "fail_fast"
      },
      "resources": {
        "global_vars": [
          {
            "name": "processed_data",
            "type": "memory_store",
            "access": "read_write",
            "description": "Read processed data, update with validity flags"
          }
        ],
        "data_operations": [
          {
            "operation": "read",
            "target": "processed_data",
            "description": "Read processed data for validation"
          },
          {
            "operation": "write",
            "target": "processed_data",
            "description": "Update processed_data with validity flags"
          }
        ]
      }
    },
    {
      "name": "ExportResults",
      "governance": {
        "execution_mode": "synchronous",
        "retry_policy": {
          "max_retries": 3,
          "backoff_ms": 1000
        },
        "timeout_ms": 30000,
        "logging_level": "info",
        "error_handling": "fail_fast"
      },
      "resources": {
        "global_vars": [
          {
            "name": "processed_data",
            "type": "memory_store",
            "access": "read",
            "description": "Read processed data to filter valid records for export"
          }
        ],
        "data_operations": [
          {
            "operation": "read",
            "target": "processed_data",
            "description": "Read processed data to filter valid records for export"
          }
        ]
      }
    }
  ]
}