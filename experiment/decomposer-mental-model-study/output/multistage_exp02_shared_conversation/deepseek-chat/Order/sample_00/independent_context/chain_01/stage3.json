      "global_vars": [
        {
          "variable": "orders",
          "op": "read_write",
          "description": "Check order status and update to cancelled"
        },
        {
          "variable": "payments",
          "op": "write",
          "description": "Process refund"
        },
        {
          "variable": "inventory",
          "op": "write",
          "description": "Restore items to inventory"
        }
      ],
      "data_operations": [
        {
          "source_name": "orders",
          "operation_type": "read_write",
          "description": "Check order status and update to cancelled"
        },
        {
          "source_name": "payments",
          "operation_type": "write",
          "description": "Process refund"
        },
        {
          "source_name": "inventory",
          "operation_type": "write",
          "description": "Restore items to inventory"
