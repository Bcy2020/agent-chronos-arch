    {
      "name": "PlaceOrder",
      "purpose": "Execute the place order workflow",
      "behavior": "Reserve inventory, process payment, create order record, return success with order_id",
      "boundary": {
        "in_scope": [
          "Inventory reservation",
          "Payment processing",
          "Order creation"
        ],
        "out_of_scope": [
          "Cancellation",
          "Tracking"
        ]
      },
      "preconditions": [
        "Inventory available",
        "Payment method valid"
      ],
      "postconditions": [
        "Order created in orders store",
        "Inventory decremented",
        "Payment recorded"
      ],
      "guarantees": [
        "Atomic operation: all or nothing"
      ],
      "composition_role": "execute",
      "call_inputs": [
        {
          "name": "order_data",
          "type": "dict",
          "description": "Order details including items and customer info",
          "source": "ParseCommand output"
        }
      ],
      "internal_leaf_accesses": [
        {
          "resource": "inventory",
          "op": "read_write",
          "reason": "Reserve items for the order"
        },
        {
          "resource": "payments",
          "op": "write",
          "reason": "Record payment transaction"
        },
        {
          "resource": "orders",
          "op": "write",
          "reason": "Create new order record"
        }
      ],
      "outputs": [
        {
          "name": "result",
          "type": "dict",
          "description": "JSON with success, order_id, status, message",
          "consumer": "parent"
        }
      ],
      "signature": "def PlaceOrder(order_data: dict) -> dict",
      "global_vars": [
        {
          "variable": "inventory",
          "op": "read_write",
          "description": "Reserve items for the order"
        },
        {
          "variable": "payments",
          "op": "write",
          "description": "Record payment transaction"
        },
        {
          "variable": "orders",
          "op": "write",
          "description": "Create new order record"
        }
      ],
      "data_operations": [
        {
          "source_name": "inventory",
          "operation_type": "read_write",
          "description": "Reserve items for the order"
        },
        {
          "source_name": "payments",
          "operation_type": "write",
          "description": "Record payment transaction"
        },
        {
          "source_name": "orders",
          "operation_type": "write",
          "description": "Create new order record"
        }
      ],
      "requested_capabilities": [
        "inventory.read_write",
        "payments.write",
        "orders.write"
      ],
      "constraints": [
        {
          "constraint_id": "C-003",
          "description": "Inventory must have sufficient quantity"
        },
        {
          "constraint_id": "C-004",
          "description": "Payment must be processed successfully"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-004",
          "description": "Given valid order_data with available inventory, returns success with order_id"
        },
        {
          "ac_id": "AC-005",
          "description": "Given insufficient inventory, returns error"
        },
        {
          "ac_id": "AC-006",
          "description": "Given payment failure, returns error and no order created"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-002"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": false,
      "stop_reason": "Can be further decomposed into sub-steps"
