        {
          "variable": "payments",
          "op": "write",
          "description": "Record payment transaction"
        },
        {
          "variable": "orders",
          "op": "write",
          "description": "Create new order record"
        }
      ],
      "data_operations": [
        {
          "source_name": "inventory",
          "operation_type": "read_write",
          "description": "Reserve items for the order"
        },
        {
          "source_name": "payments",
          "operation_type": "write",
          "description": "Record payment transaction"
        },
        {
          "source_name": "orders",
          "operation_type": "write",
          "description": "Create new order record"
        }
      ],
      "requested_capabilities": [
        "inventory.read_write",
        "payments.write",
        "orders.write"
