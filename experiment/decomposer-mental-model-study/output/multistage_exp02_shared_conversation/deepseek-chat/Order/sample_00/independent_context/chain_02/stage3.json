          "Payment processing",
          "Order creation"
        ],
        "out_of_scope": [
          "Cancellation",
          "Tracking"
        ]
      },
      "preconditions": [
        "Inventory available",
        "Payment method valid"
      ],
      "postconditions": [
        "Order created in orders store",
        "Inventory decremented",
        "Payment recorded"
      ],
      "guarantees": [
        "Atomic operation: all or nothing"
      ],
      "composition_role": "execute",
      "call_inputs": [
        {
          "name": "order_data",
