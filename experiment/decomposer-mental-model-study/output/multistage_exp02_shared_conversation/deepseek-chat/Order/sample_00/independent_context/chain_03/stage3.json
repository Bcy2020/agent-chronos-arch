{
  "children": [
    {
      "name": "ParseCommand",
      "purpose": "Extract and validate the command type from the input JSON",
      "behavior": "Parse the input JSON to extract the 'command' field and validate it is one of 'place', 'cancel', 'track'",
      "boundary": {
        "in_scope": [
          "Parsing JSON",
          "Validating command value"
        ],
        "out_of_scope": [
          "Processing order data",
          "Accessing data stores"
        ]
      },
      "preconditions": [
        "Input is valid JSON"
      ],
      "postconditions": [
        "Command is one of 'place', 'cancel', 'track'"
      ],
      "guarantees": [
        "Returns error if command is missing or invalid"
      ],
      "composition_role": "validate",
      "call_inputs": [
        {
          "name": "input",
          "type": "dict",
          "description": "Raw JSON input from parent",
          "source": "parent input"
        }
      ],
      "internal_leaf_accesses": [],
      "outputs": [
        {
          "name": "command",
          "type": "str",
          "description": "Validated command string",
          "consumer": "parent"
        },
        {
          "name": "order_data",
          "type": "dict",
          "description": "Remaining JSON data after command extraction",
          "consumer": "parent"
        }
      ],
      "signature": "def ParseCommand(input: dict) -> tuple[str, dict]",
      "global_vars": [],
      "data_operations": [],
      "requested_capabilities": [],
      "constraints": [
        {
          "constraint_id": "C-001",
          "description": "Input must be valid JSON"
        },
        {
          "constraint_id": "C-002",
          "description": "Command must be one of 'place', 'cancel', 'track'"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-001",
          "description": "Given valid JSON with command 'place', returns ('place', order_data)"
        },
        {
          "ac_id": "AC-002",
          "description": "Given invalid JSON, returns error"
        },
        {
          "ac_id": "AC-003",
          "description": "Given valid JSON with invalid command, returns error"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-001"
        ]
      },
      "node_type": "pure_function",
      "stop_decompose": false,
      "stop_reason": ""
