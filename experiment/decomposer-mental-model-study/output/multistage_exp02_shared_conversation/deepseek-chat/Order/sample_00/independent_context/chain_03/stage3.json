    {
      "name": "PlaceOrder",
      "purpose": "Execute the place order workflow",
      "behavior": "Reserve inventory, process payment, create order record, return success with order_id",
      "boundary": {
        "in_scope": [
          "Inventory reservation",
          "Payment processing",
          "Order creation"
        ],
        "out_of_scope": [
          "Cancellation",
          "Tracking"
        ]
      },
      "preconditions": [
        "Inventory available",
        "Payment method valid"
      ],
      "postconditions": [
        "Order created in orders store",
        "Inventory decremented",
        "Payment recorded"
      ],
      "guarantees": [
        "Atomic operation: all or nothing"
      ],
      "composition_role": "execute",
      "call_inputs": [
        {
          "name": "order_data",
          "type": "dict",
          "description": "Order details including items and customer info",
          "source": "ParseCommand output"
        }
      ],
      "internal_leaf_accesses": [
        {
          "resource": "inventory",
          "op": "read_write",
          "reason": "Reserve items for the order"
        },
        {
          "resource": "payments",
          "op": "read_write",
          "reason": "Process payment for the order"
        },
        {
          "resource": "orders",
          "op": "read_write",
          "reason": "Create order record"
        }
      ],
      "outputs": [
        {
          "name": "result",
          "type": "dict",
          "description": "JSON with success, order_id, status, message",
          "consumer": "parent"
        }
      ],
      "signature": "def PlaceOrder(order_data: dict) -> dict",
      "global_vars": [
        {
          "variable": "inventory",
          "op": "read_write",
          "description": "Reserve items for the order"
        },
        {
          "variable": "payments",
          "op": "read_write",
          "description": "Process payment for the order"
        },
        {
          "variable": "orders",
          "op": "read_write",
          "description": "Create order record"
        }
      ],
      "data_operations": [
        {
          "source_name": "inventory",
          "operation_type": "read_write",
          "description": "Reserve items for the order"
        },
        {
          "source_name": "payments",
          "operation_type": "read_write",
          "description": "Process payment for the order"
        },
        {
          "source_name": "orders",
          "operation_type": "read_write",
          "description": "Create order record"
        }
      ],
      "requested_capabilities": [
        "inventory.read_write",
        "payments.read_write",
        "orders.read_write"
      ],
      "constraints": [
        {
          "constraint_id": "C-003",
          "description": "Must have sufficient inventory before reserving"
        },
        {
          "constraint_id": "C-004",
          "description": "Payment must be processed before order creation"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-004",
          "description": "Given valid order_data with sufficient inventory and valid payment, returns success with order_id"
        },
        {
          "ac_id": "AC-005",
          "description": "Given insufficient inventory, returns failure without creating order"
        },
        {
          "ac_id": "AC-006",
          "description": "Given payment failure, returns failure without creating order"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-001"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "CancelOrder",
      "purpose": "Execute the cancel order workflow",
      "behavior": "Check order status, if not shipped, cancel order, refund payment, restore inventory",
