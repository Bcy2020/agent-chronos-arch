          "op": "read_write",
          "reason": "Refund payment for the order"
        },
        {
          "resource": "inventory",
          "op": "read_write",
          "reason": "Restore inventory items"
        }
      ],
      "outputs": [
        {
          "name": "result",
          "type": "dict",
          "description": "JSON with success, order_id, status, message",
          "consumer": "parent"
        }
      ],
      "signature": "def CancelOrder(order_data: dict) -> dict",
      "global_vars": [
        {
          "variable": "orders",
          "op": "read_write",
          "description": "Check order status and update to cancelled"
        },
        {
          "variable": "payments",
          "op": "read_write",
          "description": "Refund payment for the order"
        },
        {
          "variable": "inventory",
          "op": "read_write",
          "description": "Restore inventory items"
        }
      ],
      "data_operations": [
        {
          "source_name": "orders",
          "operation_type": "read_write",
          "description": "Check order status and update to cancelled"
        },
        {
          "source_name": "payments",
          "operation_type": "read_write",
          "description": "Refund payment for the order"
        },
        {
          "source_name": "inventory",
          "operation_type": "read_write",
          "description": "Restore inventory items"
        }
      ],
      "requested_capabilities": [
        "orders.read_write",
        "payments.read_write",
        "inventory.read_write"
