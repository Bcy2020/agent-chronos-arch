      "acceptance_criteria": [
        {
          "ac_id": "AC-007",
          "description": "Given valid order_id for an unshipped order, returns success with cancellation confirmation"
        },
        {
          "ac_id": "AC-008",
          "description": "Given order_id for a shipped order, returns failure"
        },
        {
          "ac_id": "AC-009",
          "description": "Given non-existent order_id, returns failure"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-001"
        ]
      },
