{
  "children": [
    {
      "name": "ParseCommand",
      "governance": {
        "execution_mode": "synchronous",
        "retry_policy": "none",
        "timeout_ms": 100,
        "error_handling": "fail_fast"
      },
      "global_vars": [],
      "data_operations": []
    },
    {
      "name": "PlaceOrder",
      "governance": {
        "execution_mode": "synchronous",
        "retry_policy": "exponential_backoff",
        "timeout_ms": 5000,
        "error_handling": "rollback_all"
      },
      "global_vars": [
        {
          "name": "orders",
          "type": "memory",
          "access": "read_write",
          "purpose": "Create order record"
        },
        {
          "name": "inventory",
          "type": "memory",
          "access": "read_write",
          "purpose": "Reserve items for the order"
        },
        {
          "name": "payments",
          "type": "memory",
          "access": "read_write",
          "purpose": "Process payment for the order"
        }
      ],
      "data_operations": [
        {
          "operation": "read",
          "store": "inventory",
          "description": "Check item availability"
        },
        {
          "operation": "write",
          "store": "inventory",
          "description": "Decrement reserved items"
        },
        {
          "operation": "write",
          "store": "payments",
          "description": "Record payment transaction"
        },
        {
          "operation": "write",
          "store": "orders",
          "description": "Insert new order record"
        }
      ]
    },
    {
      "name": "CancelOrder",
      "governance": {
        "execution_mode": "synchronous",
        "retry_policy": "exponential_backoff",
        "timeout_ms": 5000,
        "error_handling": "rollback_all"
      },
      "global_vars": [
        {
          "name": "orders",
          "type": "memory",
          "access": "read_write",
          "purpose": "Check order status and update to cancelled"
        },
        {
          "name": "payments",
          "type": "memory",
          "access": "read_write",
          "purpose": "Process refund for cancelled order"
        },
        {
          "name": "inventory",
          "type": "memory",
          "access": "read_write",
          "purpose": "Restore inventory for cancelled order"
        }
      ],
      "data_operations": [
        {
          "operation": "read",
          "store": "orders",
          "description": "Retrieve order status to verify not shipped"
        },
        {
          "operation": "write",
          "store": "orders",
          "description": "Update order status to cancelled"
        },
        {
          "operation": "write",
          "store": "payments",
          "description": "Process refund transaction"
        },
        {
          "operation": "write",
          "store": "inventory",
          "description": "Restore items to inventory"
        }
      ]
    },
    {
      "name": "TrackOrder",
      "governance": {
        "execution_mode": "synchronous",
        "retry_policy": "simple",
        "timeout_ms": 2000,
        "error_handling": "fail_fast"
      },
      "global_vars": [
        {
          "name": "orders",
          "type": "memory",
          "access": "read",
          "purpose": "Retrieve order status and tracking details"
        }
      ],
      "data_operations": [
        {
          "operation": "read",
          "store": "orders",
          "description": "Fetch order record by order_id"
        }
      ]
    }
  ]
}