{
  "children": [
    {
      "name": "ParseCommand",
      "call_inputs": [
        {
          "name": "input",
          "type": "Any",
          "description": "Raw JSON input from parent"
        }
      ],
      "call_outputs": [
        {
          "name": "command",
          "type": "String",
          "description": "Validated command string"
        },
        {
          "name": "order_data",
          "type": "Any",
          "description": "Remaining JSON data after command extraction"
        }
      ],
      "internal_leaf_accesses": []
    },
    {
      "name": "PlaceOrder",
      "call_inputs": [
        {
          "name": "order_data",
          "type": "Any",
          "description": "Order details including items and customer info"
        }
      ],
      "call_outputs": [
        {
          "name": "result",
          "type": "Any",
          "description": "JSON with success, order_id, status, message"
        }
      ],
      "internal_leaf_accesses": [
        {
          "store": "orders",
          "access": "read_write"
        },
        {
          "store": "inventory",
          "access": "read_write"
        },
        {
          "store": "payments",
          "access": "read_write"
        }
      ]
    },
    {
      "name": "CancelOrder",
      "call_inputs": [
        {
          "name": "order_data",
          "type": "Any",
          "description": "Contains order_id to cancel"
        }
      ],
      "call_outputs": [
        {
          "name": "result",
          "type": "Any",
          "description": "JSON with success, order_id, status, message"
        }
      ],
      "internal_leaf_accesses": [
        {
          "store": "orders",
          "access": "read_write"
        },
        {
          "store": "inventory",
          "access": "read_write"
        },
        {
          "store": "payments",
          "access": "read_write"
        }
      ]
    },
    {
      "name": "TrackOrder",
      "call_inputs": [
        {
          "name": "order_data",
          "type": "Any",
          "description": "Contains order_id to track"
        }
      ],
      "call_outputs": [
        {
          "name": "result",
          "type": "Any",
          "description": "JSON with success, order_id, status, message, tracking_info"
        }
      ],
      "internal_leaf_accesses": [
        {
          "store": "orders",
          "access": "read_write"
        }
      ]
    }
  ]
}