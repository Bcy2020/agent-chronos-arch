{
  "children": [
    {
      "name": "ParseCommand",
      "call_inputs": [
        {
          "name": "input",
          "type": "Any",
          "description": "JSON with command and order_data",
          "source": "parent input"
        }
      ],
      "call_outputs": [
        {
          "name": "command",
          "type": "String",
          "description": "Validated command string (place/cancel/track)",
          "consumer": "parent"
        },
        {
          "name": "order_data",
          "type": "Any",
          "description": "Parsed order data object",
          "consumer": "parent"
        }
      ],
      "internal_leaf_accesses": [],
      "governance": {
        "atomicity": "required",
        "retry_policy": "none",
        "timeout_ms": 1000,
        "error_handling": "return error message to parent"
      },
      "global_vars": [],
      "data_operations": []
    },
    {
      "name": "PlaceOrder",
      "call_inputs": [
        {
          "name": "order_data",
          "type": "Any",
          "description": "Order details including items and payment info",
          "source": "ParseCommand output"
        }
      ],
      "call_outputs": [
        {
          "name": "order_id",
          "type": "String",
          "description": "Generated unique order ID",
          "consumer": "parent"
        },
        {
          "name": "status",
          "type": "String",
          "description": "Order status after placement",
          "consumer": "parent"
        },
        {
          "name": "message",
          "type": "String",
          "description": "Success or error message",
          "consumer": "parent"
        }
      ],
      "internal_leaf_accesses": [
        {
          "store": "orders",
          "access": "read_write",
          "description": "Create new order record"
        },
        {
          "store": "inventory",
          "access": "read_write",
          "description": "Decrement inventory for ordered items"
        },
        {
          "store": "payments",
          "access": "read_write",
          "description": "Process payment transaction"
        }
      ],
      "governance": {
        "atomicity": "required",
        "retry_policy": "exponential_backoff, max 3 retries",
        "timeout_ms": 5000,
        "error_handling": "rollback all changes on failure, return error message to parent"
      },
      "global_vars": [
        {
          "name": "orders",
          "type": "memory",
          "access": "read_write",
          "description": "Order records store"
        },
        {
          "name": "inventory",
          "type": "memory",
          "access": "read_write",
          "description": "Inventory items store"
        },
        {
          "name": "payments",
          "type": "memory",
          "access": "read_write",
          "description": "Payment transactions store"
        }
      ],
      "data_operations": [
        {
          "operation": "create",
          "store": "orders",
          "description": "Insert new order record with status 'placed'"
        },
        {
          "operation": "update",
          "store": "inventory",
          "description": "Decrement quantity for each item in order"
        },
        {
          "operation": "create",
          "store": "payments",
          "description": "Record payment transaction"
        }
      ]
    },
    {
      "name": "CancelOrder",
      "call_inputs": [
        {
          "name": "order_data",
          "type": "Any",
          "description": "Contains order_id to cancel",
          "source": "ParseCommand output"
        }
      ],
      "call_outputs": [
        {
          "name": "order_id",
          "type": "String",
          "description": "ID of cancelled order",
          "consumer": "parent"
        },
        {
          "name": "status",
          "type": "String",
          "description": "New status after cancellation",
          "consumer": "parent"
        },
        {
          "name": "message",
          "type": "String",
          "description": "Success or error message",
          "consumer": "parent"
        }
      ],
      "internal_leaf_accesses": [
        {
          "store": "orders",
          "access": "read_write",
          "description": "Read order status and update to cancelled"
        },
        {
          "store": "inventory",
          "access": "read_write",
          "description": "Restore inventory for cancelled items"
        },
        {
          "store": "payments",
          "access": "read_write",
          "description": "Process refund"
        }
      ],
      "governance": {
        "atomicity": "required",
        "retry_policy": "exponential_backoff, max 3 retries",
        "timeout_ms": 5000,
        "error_handling": "rollback all changes on failure, return error message to parent"
      },
      "global_vars": [
        {
          "name": "orders",
          "type": "memory",
          "access": "read_write",
          "description": "Order records store"
        },
        {
          "name": "inventory",
          "type": "memory",
          "access": "read_write",
          "description": "Inventory items store"
        },
        {
          "name": "payments",
          "type": "memory",
          "access": "read_write",
          "description": "Payment transactions store"
        }
      ],
      "data_operations": [
        {
          "operation": "read",
          "store": "orders",
          "description": "Retrieve order record by order_id"
        },
        {
          "operation": "update",
          "store": "orders",
          "description": "Set order status to 'cancelled'"
        },
        {
          "operation": "update",
          "store": "inventory",
          "description": "Restore quantity for each item in order"
        },
        {
          "operation": "create",
          "store": "payments",
          "description": "Record refund transaction"
        }
      ]
    },
    {
      "name": "TrackOrder",
      "call_inputs": [
        {
          "name": "order_data",
          "type": "Any",
          "description": "Contains order_id to track",
          "source": "ParseCommand output"
        }
      ],
      "call_outputs": [
        {
          "name": "order_id",
          "type": "String",
          "description": "ID of tracked order",
          "consumer": "parent"
        },
        {
          "name": "status",
          "type": "String",
          "description": "Current order status",
          "consumer": "parent"
        },
        {
          "name": "message",
          "type": "String",
          "description": "Order details or error",
          "consumer": "parent"
        }
      ],
      "internal_leaf_accesses": [
        {
          "store": "orders",
          "access": "read_write",
          "description": "Read order status and details"
        }
      ],
      "governance": {
        "atomicity": "not_required",
        "retry_policy": "simple, max 2 retries",
        "timeout_ms": 2000,
        "error_handling": "return error message to parent"
      },
      "global_vars": [
        {
          "name": "orders",
          "type": "memory",
          "access": "read_write",
          "description": "Order records store"
        }
      ],
      "data_operations": [
        {
          "operation": "read",
          "store": "orders",
          "description": "Retrieve order record by order_id"
        }
      ]
    }
  ]
}