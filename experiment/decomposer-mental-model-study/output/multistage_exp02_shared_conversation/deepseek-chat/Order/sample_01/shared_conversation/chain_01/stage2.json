{
  "children": [
    {
      "name": "ParseCommand",
      "call_inputs": [
        {
          "name": "input",
          "type": "Any",
          "description": "JSON with command and order_data",
          "source": "parent input"
        }
      ],
      "call_outputs": [
        {
          "name": "command",
          "type": "String",
          "description": "Validated command string (place/cancel/track)"
        },
        {
          "name": "order_data",
          "type": "Any",
          "description": "Parsed order data object"
        }
      ],
      "internal_leaf_accesses": []
    },
    {
      "name": "PlaceOrder",
      "call_inputs": [
        {
          "name": "order_data",
          "type": "Any",
          "description": "Order details including items and payment info",
          "source": "ParseCommand output"
        }
      ],
      "call_outputs": [
        {
          "name": "order_id",
          "type": "String",
          "description": "Generated unique order ID"
        },
        {
          "name": "status",
          "type": "String",
          "description": "Order status after placement"
        },
        {
          "name": "message",
          "type": "String",
          "description": "Success or error message"
        }
      ],
      "internal_leaf_accesses": [
        {
          "store": "orders",
          "access": "read_write"
        },
        {
          "store": "inventory",
          "access": "read_write"
        },
        {
          "store": "payments",
          "access": "read_write"
        }
      ]
    },
    {
      "name": "CancelOrder",
      "call_inputs": [
        {
          "name": "order_data",
          "type": "Any",
          "description": "Contains order_id to cancel",
          "source": "ParseCommand output"
        }
      ],
      "call_outputs": [
        {
          "name": "order_id",
          "type": "String",
          "description": "ID of cancelled order"
        },
        {
          "name": "status",
          "type": "String",
          "description": "New status after cancellation"
        },
        {
          "name": "message",
          "type": "String",
          "description": "Success or error message"
        }
      ],
      "internal_leaf_accesses": [
        {
          "store": "orders",
          "access": "read_write"
        },
        {
          "store": "inventory",
          "access": "read_write"
        },
        {
          "store": "payments",
          "access": "read_write"
        }
      ]
    },
    {
      "name": "TrackOrder",
      "call_inputs": [
        {
          "name": "order_data",
          "type": "Any",
          "description": "Contains order_id to track",
          "source": "ParseCommand output"
        }
      ],
      "call_outputs": [
        {
          "name": "order_id",
          "type": "String",
          "description": "ID of tracked order"
        },
        {
          "name": "status",
          "type": "String",
          "description": "Current order status"
        },
        {
          "name": "message",
          "type": "String",
          "description": "Order details or error"
        }
      ],
      "internal_leaf_accesses": [
        {
          "store": "orders",
          "access": "read_only"
        }
      ]
    }
  ]
}