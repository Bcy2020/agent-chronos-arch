        "in_scope": [
          "Checking order status",
          "Updating order status",
          "Restoring inventory",
          "Processing refund"
        ],
        "out_of_scope": [
          "Placing orders",
          "Tracking orders"
        ]
      },
      "preconditions": [
        "Order exists",
        "Order status is not 'shipped'"
      ],
      "postconditions": [
        "Order status changed to 'cancelled'",
        "Inventory restored",
        "Payment refunded"
      ],
      "guarantees": [
        "Cannot cancel shipped orders",
        "Atomic operation"
      ],
      "composition_role": "execute",
      "call_inputs": [
        {
          "name": "order_data",
          "type": "dict",
          "description": "Contains order_id to cancel",
          "source": "ParseCommand output"
        }
      ],
      "internal_leaf_accesses": [
        {
          "resource": "orders",
          "op": "read_write",
          "reason": "Read current status and update to cancelled"
        },
        {
          "resource": "inventory",
          "op": "write",
          "reason": "Restore stock for cancelled items"
        },
        {
          "resource": "payments",
          "op": "write",
          "reason": "Process refund transaction"
        }
      ],
      "outputs": [
        {
          "name": "result",
          "type": "dict",
          "description": "Contains order_id, status, message",
          "consumer": "parent"
        }
      ],
      "signature": "def CancelOrder(order_data: dict) -> dict",
      "global_vars": [
        {
          "variable": "orders",
          "op": "read_write",
          "description": "Read current status and update to cancelled"
        },
        {
          "variable": "inventory",
          "op": "write",
          "description": "Restore stock for cancelled items"
        },
        {
          "variable": "payments",
          "op": "write",
          "description": "Process refund transaction"
        }
      ],
      "data_operations": [
        {
          "source_name": "orders",
          "operation_type": "read_write",
          "description": "Read current status and update to cancelled"
        },
        {
          "source_name": "inventory",
          "operation_type": "write",
          "description": "Restore stock for cancelled items"
        },
        {
          "source_name": "payments",
          "operation_type": "write",
          "description": "Process refund transaction"
        }
      ],
      "requested_capabilities": [
        "orders.read",
        "orders.write",
        "inventory.write",
        "payments.write"
      ],
      "constraints": [
        {
          "constraint_id": "C-001",
          "description": "Must verify order exists before updating"
        },
        {
          "constraint_id": "C-002",
          "description": "Must check order status is not 'shipped' before cancelling"
        },
        {
          "constraint_id": "C-003",
          "description": "All writes must be atomic (all succeed or all rollback)"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-001",
          "description": "Given valid order_id for non-shipped order, CancelOrder updates status to 'cancelled', restores inventory, processes refund, returns success"
        },
        {
          "ac_id": "AC-002",
          "description": "Given order_id for shipped order, CancelOrder returns error and does not modify any store"
        },
        {
          "ac_id": "AC-003",
          "description": "Given non-existent order_id, CancelOrder returns error"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-001"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "TrackOrder",
      "purpose": "Retrieve and return the current status and details of an order.",
      "behavior": "Look up order by order_id from orders store, return status and relevant details.",
      "boundary": {
        "in_scope": [
          "Reading order status",
          "Returning order details"
