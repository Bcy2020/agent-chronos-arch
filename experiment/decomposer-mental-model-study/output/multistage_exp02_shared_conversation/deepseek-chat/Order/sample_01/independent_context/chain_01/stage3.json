      "purpose": "Extract and validate the command type and order data from the input JSON.",
      "behavior": "Parse the input JSON to extract 'command' and 'order_data' fields, validate that command is one of 'place', 'cancel', 'track'.",
      "boundary": {
        "in_scope": [
          "Parsing JSON",
          "Validating command type"
        ],
        "out_of_scope": [
          "Executing any order operation",
          "Accessing data stores"
        ]
      },
      "preconditions": [
        "Input is valid JSON"
      ],
      "postconditions": [
        "Command is one of place/cancel/track",
        "order_data is extracted"
      ],
      "guarantees": [
        "Returns error if command invalid"
      ],
      "composition_role": "transform",
      "call_inputs": [
        {
          "name": "input",
          "type": "dict",
          "description": "JSON with command and order_data",
          "source": "parent input"
        }
      ],
      "internal_leaf_accesses": [],
      "outputs": [
        {
          "name": "command",
          "type": "str",
          "description": "Validated command string (place/cancel/track)",
          "consumer": "parent"
        },
        {
          "name": "order_data",
          "type": "dict",
          "description": "Parsed order data object",
          "consumer": "parent"
        }
      ],
      "signature": "def ParseCommand(input: dict) -> tuple[str, dict]",
      "global_vars": [],
      "data_operations": [],
      "requested_capabilities": [],
      "constraints": [
        {
          "constraint_id": "C-001",
          "description": "Input must be valid JSON"
        },
        {
          "constraint_id": "C-002",
          "description": "Command must be one of: place, cancel, track"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-001",
          "description": "Given valid JSON with command 'place', returns command='place' and order_data"
        },
        {
          "ac_id": "AC-002",
          "description": "Given invalid command, returns error"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-001"
        ]
      },
      "node_type": "pure_function",
      "stop_decompose": false,
      "stop_reason": ""
