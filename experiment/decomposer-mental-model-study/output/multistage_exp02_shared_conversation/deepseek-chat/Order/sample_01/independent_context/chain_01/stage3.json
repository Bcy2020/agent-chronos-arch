          "consumer": "parent"
        },
        {
          "name": "status",
          "type": "str",
          "description": "Order status after placement",
          "consumer": "parent"
        },
        {
          "name": "message",
          "type": "str",
          "description": "Success or error message",
          "consumer": "parent"
        }
      ],
      "signature": "def PlaceOrder(order_data: dict) -> tuple[str, str, str]",
      "global_vars": [
        {
          "variable": "orders",
          "op": "write",
          "description": "Store new order record"
        },
        {
          "variable": "inventory",
          "op": "write",
          "description": "Decrement stock for ordered items"
        },
        {
          "variable": "payments",
          "op": "write",
          "description": "Process payment transaction"
        }
      ],
      "data_operations": [
        {
          "source_name": "orders",
          "operation_type": "write",
          "description": "Store new order record"
        },
        {
          "source_name": "inventory",
          "operation_type": "write",
          "description": "Decrement stock for ordered items"
        },
        {
          "source_name": "payments",
          "operation_type": "write",
          "description": "Process payment transaction"
