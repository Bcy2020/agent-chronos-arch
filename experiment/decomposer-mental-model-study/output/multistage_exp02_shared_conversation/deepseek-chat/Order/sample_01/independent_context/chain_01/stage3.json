          "variable": "orders",
          "op": "read_write",
          "description": "Look up order status and update to cancelled"
        },
        {
          "variable": "inventory",
          "op": "write",
          "description": "Restore stock for cancelled items"
        },
        {
          "variable": "payments",
          "op": "write",
          "description": "Process refund transaction"
