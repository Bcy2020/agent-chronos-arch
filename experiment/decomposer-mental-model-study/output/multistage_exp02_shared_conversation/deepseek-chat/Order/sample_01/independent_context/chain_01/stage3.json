          "description": "Must check inventory sufficiency before placing order"
        },
        {
          "constraint_id": "C-004",
          "description": "Must process payment before finalizing order"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-003",
          "description": "Given valid order_data with sufficient inventory, order is created with status 'placed'"
        },
        {
          "ac_id": "AC-004",
          "description": "Given insufficient inventory, returns error and no order created"
        }
