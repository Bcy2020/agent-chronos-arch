{
  "governance_and_resources": [
    {
      "child_name": "RegisterPatient",
      "global_vars": [
        {
          "name": "patients",
          "type": "memory",
          "access": "read_write",
          "description": "Data store for patient records"
        }
      ],
      "data_operations": [
        {
          "operation": "create",
          "target": "patients",
          "description": "Insert new patient record with unique ID"
        }
      ],
      "error_handling": [
        {
          "condition": "duplicate patient data",
          "action": "return error with message 'Patient already exists'"
        },
        {
          "condition": "invalid input format",
          "action": "return error with message 'Invalid registration data'"
        }
      ],
      "rate_limits": [
        {
          "scope": "per patient",
          "limit": "1 registration per unique identity"
        }
      ],
      "audit_logging": [
        {
          "event": "patient_registered",
          "details": "log patient ID and timestamp"
        }
      ]
    },
    {
      "child_name": "BookAppointment",
      "global_vars": [
        {
          "name": "patients",
          "type": "memory",
          "access": "read",
          "description": "Data store for patient records (read-only for existence check)"
        },
        {
          "name": "appointments",
          "type": "memory",
          "access": "read_write",
          "description": "Data store for appointments"
        }
      ],
      "data_operations": [
        {
          "operation": "read",
          "target": "patients",
          "description": "Verify patient exists by ID"
        },
        {
          "operation": "create",
          "target": "appointments",
          "description": "Insert new appointment record"
        }
      ],
      "error_handling": [
        {
          "condition": "patient not found",
          "action": "return error with message 'Patient not registered'"
        },
        {
          "condition": "slot unavailable",
          "action": "return error with message 'Appointment slot not available'"
        },
        {
          "condition": "invalid appointment data",
          "action": "return error with message 'Invalid booking details'"
        }
      ],
      "rate_limits": [
        {
          "scope": "per patient per day",
          "limit": "5 appointments"
        }
      ],
      "audit_logging": [
        {
          "event": "appointment_booked",
          "details": "log patient ID, appointment ID, and timestamp"
        }
      ]
    },
    {
      "child_name": "GetRecords",
      "global_vars": [
        {
          "name": "patients",
          "type": "memory",
          "access": "read",
          "description": "Data store for patient records (read-only)"
        }
      ],
      "data_operations": [
        {
          "operation": "read",
          "target": "patients",
          "description": "Fetch patient records by ID"
        }
      ],
      "error_handling": [
        {
          "condition": "patient not found",
          "action": "return error with message 'Patient not registered'"
        },
        {
          "condition": "no records available",
          "action": "return empty records with success status"
        }
      ],
      "rate_limits": [
        {
          "scope": "per patient per minute",
          "limit": "10 requests"
        }
      ],
      "audit_logging": [
        {
          "event": "records_retrieved",
          "details": "log patient ID and timestamp"
        }
      ]
    },
    {
      "child_name": "UpdateProfile",
      "global_vars": [
        {
          "name": "patients",
          "type": "memory",
          "access": "read_write",
          "description": "Data store for patient records"
        }
      ],
      "data_operations": [
        {
          "operation": "read",
          "target": "patients",
          "description": "Read current patient profile"
        },
        {
          "operation": "update",
          "target": "patients",
          "description": "Update specified fields in patient profile"
        }
      ],
      "error_handling": [
        {
          "condition": "patient not found",
          "action": "return error with message 'Patient not registered'"
        },
        {
          "condition": "invalid update fields",
          "action": "return error with message 'Invalid profile data'"
        }
      ],
      "rate_limits": [
        {
          "scope": "per patient per hour",
          "limit": "3 profile updates"
        }
      ],
      "audit_logging": [
        {
          "event": "profile_updated",
          "details": "log patient ID, changed fields, and timestamp"
        }
      ]
    }
  ]
}