{
  "governance": [
    {
      "child_name": "RegisterPatient",
      "global_vars": [],
      "data_operations": [
        {
          "data_store": "patients",
          "operation": "read",
          "purpose": "Check if patient already exists"
        },
        {
          "data_store": "patients",
          "operation": "write",
          "purpose": "Create new patient record"
        }
      ],
      "error_handling": [
        {
          "condition": "Patient already exists",
          "action": "Return error with message 'Patient already registered'"
        },
        {
          "condition": "Invalid or missing registration data",
          "action": "Return error with message 'Invalid registration data'"
        }
      ],
      "security": [
        {
          "requirement": "Ensure patient data is not duplicated",
          "mechanism": "Check uniqueness before write"
        }
      ],
      "observability": [
        {
          "metric": "registration_count",
          "type": "counter",
          "description": "Number of successful registrations"
        },
        {
          "metric": "registration_errors",
          "type": "counter",
          "description": "Number of failed registration attempts"
        }
      ]
    },
