{
  "children": [
    {
      "name": "ParseInput",
      "call_inputs": [
        {
          "name": "input",
          "type": "Any",
          "description": "Raw JSON input from parent"
        }
      ],
      "call_outputs": [
        {
          "name": "action_request",
          "type": "Any",
          "description": "Parsed and validated action, repo, branch"
        }
      ],
      "internal_leaf_accesses": []
    },
    {
      "name": "TriggerBuild",
      "call_inputs": [
        {
          "name": "repo",
          "type": "String",
          "description": "Repository name"
        },
        {
          "name": "branch",
          "type": "String",
          "description": "Branch name"
        }
      ],
      "call_outputs": [
        {
          "name": "build_result",
          "type": "Any",
          "description": "Success status and build_id or error"
        }
      ],
      "internal_leaf_accesses": [
        {
          "store": "builds",
          "access": "read_write",
          "description": "Check for existing active build and create new build entry"
        },
        {
          "store": "artifacts",
          "access": "read_write",
          "description": "Initialize empty log for new build"
        }
      ]
    },
    {
      "name": "CheckBuildStatus",
      "call_inputs": [
        {
          "name": "build_id",
          "type": "String",
          "description": "Identifier of the build"
        }
      ],
      "call_outputs": [
        {
          "name": "status_result",
          "type": "Any",
          "description": "Build status and logs"
        }
      ],
      "internal_leaf_accesses": [
        {
          "store": "builds",
          "access": "read",
          "description": "Look up build by build_id"
        },
        {
          "store": "artifacts",
          "access": "read",
          "description": "Retrieve build logs"
        }
      ]
    },
    {
      "name": "ListBuilds",
      "call_inputs": [
        {
          "name": "repo",
          "type": "String",
          "description": "Optional filter by repository"
        },
        {
          "name": "branch",
          "type": "String",
          "description": "Optional filter by branch"
        }
      ],
      "call_outputs": [
        {
          "name": "builds_list",
          "type": "Any",
          "description": "List of build summaries"
        }
      ],
      "internal_leaf_accesses": [
        {
          "store": "builds",
          "access": "read",
          "description": "Query builds store with optional filters"
        }
      ]
    },
    {
      "name": "CancelBuild",
      "call_inputs": [
        {
          "name": "build_id",
          "type": "String",
          "description": "Identifier of the build to cancel"
        }
      ],
      "call_outputs": [
        {
          "name": "cancel_result",
          "type": "Any",
          "description": "Success or error"
        }
      ],
      "internal_leaf_accesses": [
        {
          "store": "builds",
          "access": "read_write",
          "description": "Find build and update status to cancelled"
        }
      ]
    },
    {
      "name": "FormatResponse",
      "call_inputs": [
        {
          "name": "child_result",
          "type": "Any",
          "description": "Result from the executed child action"
        }
      ],
      "call_outputs": [
        {
          "name": "output",
          "type": "Any",
          "description": "Final JSON response"
        }
      ],
      "internal_leaf_accesses": []
    }
  ]
}