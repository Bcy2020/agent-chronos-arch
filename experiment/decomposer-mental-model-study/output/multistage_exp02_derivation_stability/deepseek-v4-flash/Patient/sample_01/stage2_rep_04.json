{
  "children": [
    {
      "name": "RegisterPatient",
      "purpose": "Register a new patient in the system",
      "behavior": "Extract patient details from input, validate uniqueness, and store in patients data store",
      "boundary": {
        "in_scope": [
          "patient registration",
          "input validation",
          "data store write"
        ],
        "out_of_scope": [
          "appointment booking",
          "record retrieval",
          "profile updates"
        ]
      },
      "semantic_inputs": [
        "patient details (name, age, contact, etc.)"
      ],
      "semantic_outputs": [
        "success status, patient ID, message"
      ],
      "preconditions": [
        "input contains valid patient data",
        "patient does not already exist"
      ],
      "postconditions": [
        "patient record created in patients data store"
      ],
      "guarantees": [
        "patient ID is unique",
        "registration is atomic"
      ],
      "composition_role": "execute",
      "stop_decompose": false,
      "stop_reason": "",
      "inputs": [
        {
          "name": "patient_details",
          "type": "dict",
          "description": "Patient registration details (name, age, contact, etc.)",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "registration_result",
          "type": "dict",
          "description": "Result containing success status, patient ID, and message",
          "consumer": "parent"
        }
      ],
      "signature": "def RegisterPatient(patient_details: dict) -> dict"
    },
    {
      "name": "BookAppointment",
      "purpose": "Book an appointment for a registered patient",
      "behavior": "Validate patient exists, check appointment slot availability, and store appointment in appointments data store",
      "boundary": {
        "in_scope": [
          "appointment booking",
          "patient existence check",
          "slot validation"
        ],
        "out_of_scope": [
          "patient registration",
          "record retrieval",
          "profile updates"
        ]
      },
      "semantic_inputs": [
        "patient ID, appointment date/time, doctor details"
      ],
      "semantic_outputs": [
        "success status, appointment ID, message"
      ],
      "preconditions": [
        "patient is registered",
        "appointment slot is available"
      ],
      "postconditions": [
        "appointment record created in appointments data store"
      ],
      "guarantees": [
        "appointment ID is unique",
        "booking is atomic"
      ],
      "composition_role": "execute",
      "stop_decompose": false,
      "stop_reason": "",
      "inputs": [
        {
          "name": "appointment_details",
          "type": "dict",
          "description": "Appointment details (patient_id, date_time, doctor)",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "booking_result",
          "type": "dict",
          "description": "Result containing success status, appointment ID, and message",
          "consumer": "parent"
        }
      ],
      "signature": "def BookAppointment(appointment_details: dict) -> dict"
    },
    {
      "name": "GetRecords",
      "purpose": "Retrieve medical records for a registered patient",
      "behavior": "Validate patient exists, fetch records from patients data store (append-only), and return them",
      "boundary": {
        "in_scope": [
          "record retrieval",
          "patient existence check",
          "data store read"
        ],
        "out_of_scope": [
          "registration",
          "appointment booking",
          "profile updates"
        ]
      },
      "semantic_inputs": [
        "patient ID"
      ],
      "semantic_outputs": [
        "success status, records data, message"
      ],
      "preconditions": [
        "patient is registered"
      ],
      "postconditions": [
        "records are returned without modification"
      ],
      "guarantees": [
        "records are append-only, no deletion"
      ],
      "composition_role": "query",
      "stop_decompose": false,
      "stop_reason": "",
      "inputs": [
        {
          "name": "patient_id",
          "type": "str",
          "description": "Unique identifier for the patient",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "records_result",
          "type": "dict",
          "description": "Result containing success status, records data, and message",
          "consumer": "parent"
        }
      ],
      "signature": "def GetRecords(patient_id: str) -> dict"
    },
    {
      "name": "UpdateProfile",
      "purpose": "Update profile information for a registered patient",
      "behavior": "Validate patient exists, update patient profile fields in patients data store",
      "boundary": {
        "in_scope": [
          "profile update",
          "patient existence check",
          "data store write"
        ],
        "out_of_scope": [
          "registration",
          "appointment booking",
          "record retrieval"
        ]
      },
      "semantic_inputs": [
        "patient ID, updated profile fields"
      ],
      "semantic_outputs": [
        "success status, updated profile, message"
      ],
      "preconditions": [
        "patient is registered",
        "input contains valid profile fields"
      ],
      "postconditions": [
        "patient profile updated in patients data store"
      ],
      "guarantees": [
        "update is atomic",
        "only specified fields are changed"
      ],
      "composition_role": "execute",
      "stop_decompose": false,
      "stop_reason": "",
      "inputs": [
        {
          "name": "profile_update",
          "type": "dict",
          "description": "Patient ID and updated profile fields",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "update_result",
          "type": "dict",
          "description": "Result containing success status, updated profile, and message",
          "consumer": "parent"
        }
      ],
      "signature": "def UpdateProfile(profile_update: dict) -> dict"
    }
  ],
  "interface_preservation": {
    "parent_inputs_covered_by": {
      "input": "RegisterPatient, BookAppointment, GetRecords, UpdateProfile"
    },
    "parent_outputs_produced_by": {
      "output": "RegisterPatient, BookAppointment, GetRecords, UpdateProfile"
    }
  },
  "dataflow_edges": [
    {
      "from_node": "parent",
      "from_output": "input",
      "to_node": "RegisterPatient",
      "to_input": "patient_details",
      "note": "Parent routes registration command to RegisterPatient"
    },
    {
      "from_node": "parent",
      "from_output": "input",
      "to_node": "BookAppointment",
      "to_input": "appointment_details",
      "note": "Parent routes booking command to BookAppointment"
    },
    {
      "from_node": "parent",
      "from_output": "input",
      "to_node": "GetRecords",
      "to_input": "patient_id",
      "note": "Parent routes records command to GetRecords"
    },
    {
      "from_node": "parent",
      "from_output": "input",
      "to_node": "UpdateProfile",
      "to_input": "profile_update",
      "note": "Parent routes update command to UpdateProfile"
    },
    {
      "from_node": "RegisterPatient",
      "from_output": "registration_result",
      "to_node": "parent",
      "to_input": "output",
      "note": "RegisterPatient returns result to parent"
    },
    {
      "from_node": "BookAppointment",
      "from_output": "booking_result",
      "to_node": "parent",
      "to_input": "output",
      "note": "BookAppointment returns result to parent"
    },
    {
      "from_node": "GetRecords",
      "from_output": "records_result",
      "to_node": "parent",
      "to_input": "output",
      "note": "GetRecords returns result to parent"
    },
    {
      "from_node": "UpdateProfile",
      "from_output": "update_result",
      "to_node": "parent",
      "to_input": "output",
      "note": "UpdateProfile returns result to parent"
    }
  ]
}