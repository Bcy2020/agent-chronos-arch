{
  "children": [
    {
      "name": "RegisterPatient",
      "purpose": "Register a new patient in the system",
      "behavior": "Extract patient details from input, validate uniqueness, and store in patients data store",
      "boundary": {
        "in_scope": [
          "patient registration",
          "input validation",
          "data store write"
        ],
        "out_of_scope": [
          "appointment booking",
          "record retrieval",
          "profile updates"
        ]
      },
      "preconditions": [
        "input contains valid patient data",
        "patient does not already exist"
      ],
      "postconditions": [
        "patient record created in patients data store"
      ],
      "guarantees": [
        "patient ID is unique",
        "registration is atomic"
      ],
      "composition_role": "execute",
      "inputs": [
        {
          "name": "patient_data",
          "type": "dict",
          "description": "Patient details including name, age, contact, medical_history",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "result",
          "type": "dict",
          "description": "JSON with success status, patient_id, and message",
          "consumer": "parent"
        }
      ],
      "signature": "def RegisterPatient(patient_data: dict) -> dict",
      "global_vars": [
        {
          "variable": "patients",
          "op": "write",
          "description": "write new patient record"
        }
      ],
      "data_operations": [
        {
          "source_name": "patients",
          "operation_type": "write",
          "description": "insert new patient record"
        }
      ],
      "requested_capabilities": [
        "patients.write"
      ],
      "constraints": [
        {
          "constraint_id": "C-001",
          "description": "patient_data must contain name, age, contact, medical_history"
        },
        {
          "constraint_id": "C-002",
          "description": "patient_id must be unique across all patients"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-001",
          "description": "Given valid patient_data, a new patient record is created in patients data store"
        },
        {
          "ac_id": "AC-002",
          "description": "Given duplicate patient_id, registration fails with appropriate error"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-001"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "BookAppointment",
      "purpose": "Book an appointment for a registered patient",
      "behavior": "Validate patient exists, check appointment slot availability, and store appointment in appointments data store",
      "boundary": {
        "in_scope": [
          "appointment booking",
          "patient existence check",
          "slot validation"
        ],
        "out_of_scope": [
          "patient registration",
          "record retrieval",
          "profile updates"
        ]
      },
      "preconditions": [
        "patient is registered",
        "appointment slot is available"
      ],
      "postconditions": [
        "appointment record created in appointments data store"
      ],
      "guarantees": [
        "appointment ID is unique",
        "booking is atomic"
      ],
      "composition_role": "execute",
      "inputs": [
        {
          "name": "appointment_data",
          "type": "dict",
          "description": "Appointment details including patient_id, doctor, date, time",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "result",
          "type": "dict",
          "description": "JSON with success status, appointment_id, and message",
          "consumer": "parent"
        }
      ],
      "signature": "def BookAppointment(appointment_data: dict) -> dict",
      "global_vars": [
        {
          "variable": "patients",
          "op": "read",
          "description": "check patient existence"
        },
        {
          "variable": "appointments",
          "op": "read_write",
          "description": "check slot availability and write new appointment"
        }
      ],
      "data_operations": [
        {
          "source_name": "patients",
          "operation_type": "read",
          "description": "verify patient exists"
        },
        {
          "source_name": "appointments",
          "operation_type": "read",
          "description": "check slot availability"
        },
        {
          "source_name": "appointments",
          "operation_type": "write",
          "description": "insert new appointment record"
        }
      ],
      "requested_capabilities": [
        "patients.read",
        "appointments.read",
        "appointments.write"
      ],
      "constraints": [
        {
          "constraint_id": "C-003",
          "description": "appointment_data must contain patient_id, doctor, date, time"
        },
        {
          "constraint_id": "C-004",
          "description": "slot must not be already booked for same doctor, date, time"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-003",
          "description": "Given valid appointment_data and available slot, appointment is created"
        },
        {
          "ac_id": "AC-004",
          "description": "Given non-existent patient_id, booking fails with error"
        },
        {
          "ac_id": "AC-005",
          "description": "Given already booked slot, booking fails with error"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-002"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "GetRecords",
      "purpose": "Retrieve medical records for a registered patient",
      "behavior": "Validate patient exists, fetch records from patients data store (append-only), and return them",
      "boundary": {
        "in_scope": [
          "record retrieval",
          "patient existence check",
          "data store read"
        ],
        "out_of_scope": [
          "registration",
          "appointment booking",
          "profile updates"
        ]
      },
      "preconditions": [
        "patient is registered"
      ],
      "postconditions": [
        "records are returned without modification"
      ],
      "guarantees": [
        "records are append-only, no deletion"
      ],
      "composition_role": "query",
      "inputs": [
        {
          "name": "patient_id",
          "type": "str",
          "description": "Unique identifier of the patient",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "result",
          "type": "dict",
          "description": "JSON with success status, records list, and message",
          "consumer": "parent"
        }
      ],
      "signature": "def GetRecords(patient_id: str) -> dict",
      "global_vars": [
        {
          "variable": "patients",
          "op": "read",
          "description": "fetch patient records"
        }
      ],
      "data_operations": [
        {
          "source_name": "patients",
          "operation_type": "read",
          "description": "retrieve medical records for patient"
        }
      ],
      "requested_capabilities": [
        "patients.read"
      ],
      "constraints": [
        {
          "constraint_id": "C-005",
          "description": "patient_id must be a valid registered patient"
        },
        {
          "constraint_id": "C-006",
          "description": "records must be returned in append-only order"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-006",
          "description": "Given valid patient_id, returns records list"
        },
        {
          "ac_id": "AC-007",
          "description": "Given non-existent patient_id, returns error"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-003"
        ]
      },
      "node_type": "pure_function",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "UpdateProfile",
      "purpose": "Update profile information for a registered patient",
      "behavior": "Validate patient exists, update patient profile fields in patients data store",
      "boundary": {
        "in_scope": [
          "profile update",
          "patient existence check",
          "data store write"
        ],
        "out_of_scope": [
          "registration",
          "appointment booking",
          "record retrieval"
        ]
      },
      "preconditions": [
        "patient is registered",
        "input contains valid profile fields"
      ],
      "postconditions": [
        "patient profile updated in patients data store"
      ],
      "guarantees": [
        "update is atomic",
        "only specified fields are changed"
      ],
      "composition_role": "execute",
      "inputs": [
        {
          "name": "update_data",
          "type": "dict",
          "description": "JSON with patient_id and fields to update (e.g., contact, address)",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "result",
          "type": "dict",
          "description": "JSON with success status, updated profile, and message",
          "consumer": "parent"
        }
      ],
      "signature": "def UpdateProfile(update_data: dict) -> dict",
      "global_vars": [
        {
          "variable": "patients",
          "op": "read_write",
          "description": "read patient profile and write updates"
        }
      ],
      "data_operations": [
        {
          "source_name": "patients",
          "operation_type": "read",
          "description": "verify patient exists and fetch current profile"
        },
        {
          "source_name": "patients",
          "operation_type": "write",
          "description": "update patient profile fields"
        }
      ],
      "requested_capabilities": [
        "patients.read",
        "patients.write"
      ],
      "constraints": [
        {
          "constraint_id": "C-007",
          "description": "update_data must contain patient_id and at least one field to update"
        },
        {
          "constraint_id": "C-008",
          "description": "only allowed fields (contact, address, etc.) can be updated"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-008",
          "description": "Given valid update_data, patient profile is updated"
        },
        {
          "ac_id": "AC-009",
          "description": "Given non-existent patient_id, update fails with error"
        },
        {
          "ac_id": "AC-010",
          "description": "Given invalid field name, update fails with error"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-004"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": false,
      "stop_reason": ""
    }
  ],
  "governance_notes": "All children operate on patients or appointments data stores. RegisterPatient and UpdateProfile require write access to patients. BookAppointment requires read access to patients and read/write to appointments. GetRecords requires read access to patients. No child requires capabilities beyond these data stores. Constraints ensure data integrity and validation. Acceptance criteria cover happy path and error cases."
}