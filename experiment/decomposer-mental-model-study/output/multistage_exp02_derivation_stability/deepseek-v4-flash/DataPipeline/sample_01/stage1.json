{
  "children": [
    {
      "name": "IngestData",
      "purpose": "Read and parse input data from source, store raw data in raw_data store",
      "behavior": "Extract source from input, read data, parse into records, store in raw_data, return count and errors",
      "boundary": {
        "in_scope": [
          "reading source",
          "parsing data",
          "storing raw records"
        ],
        "out_of_scope": [
          "transformation",
          "validation",
          "export"
        ]
      },
      "semantic_inputs": [
        {
          "name": "input",
          "description": "JSON with action and source",
          "source": "parent input"
        }
      ],
      "semantic_outputs": [
        {
          "name": "ingest_result",
          "description": "JSON with records_ingested, errors",
          "consumer": "parent"
        }
      ],
      "preconditions": [
        "input contains valid source"
      ],
      "postconditions": [
        "raw_data populated with records"
      ],
      "guarantees": [
        "logs each step",
        "returns count of ingested records"
      ],
      "composition_role": "transform",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "TransformData",
      "purpose": "Apply transformations to raw data and store in processed_data",
      "behavior": "Read raw_data, apply transformation rules (e.g., mapping, cleaning), write to processed_data, return count and errors",
      "boundary": {
        "in_scope": [
          "transformation logic",
          "data cleaning",
          "mapping"
        ],
        "out_of_scope": [
          "ingestion",
          "validation",
          "export"
        ]
      },
      "semantic_inputs": [
        {
          "name": "transform_config",
          "description": "Transformation rules (implicit from parent)",
          "source": "parent input"
        },
        {
          "name": "raw_data",
          "description": "Records from raw_data store",
          "source": "internal leaf access"
        }
      ],
      "semantic_outputs": [
        {
          "name": "transform_result",
          "description": "JSON with records_transformed, errors",
          "consumer": "parent"
        }
      ],
      "preconditions": [
        "raw_data is populated"
      ],
      "postconditions": [
        "processed_data contains transformed records"
      ],
      "guarantees": [
        "logs each step",
        "returns count of transformed records"
      ],
      "composition_role": "transform",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "ValidateQuality",
      "purpose": "Check quality of transformed data, mark invalid records",
      "behavior": "Read processed_data, apply validation rules (e.g., schema, range, completeness), mark invalid records, return validation summary",
      "boundary": {
        "in_scope": [
          "validation rules",
          "quality checks"
        ],
        "out_of_scope": [
          "transformation",
          "export"
        ]
      },
      "semantic_inputs": [
        {
          "name": "validation_rules",
          "description": "Rules for quality checks",
          "source": "parent input"
        },
        {
          "name": "processed_data",
          "description": "Transformed records",
          "source": "internal leaf access"
        }
      ],
      "semantic_outputs": [
        {
          "name": "validation_result",
          "description": "JSON with valid_count, invalid_count, errors",
          "consumer": "parent"
        }
      ],
      "preconditions": [
        "processed_data is populated"
      ],
      "postconditions": [
        "valid records are marked, invalid records are flagged"
      ],
      "guarantees": [
        "logs each step",
        "returns validation summary"
      ],
      "composition_role": "validate",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "ExportResults",
      "purpose": "Export only valid records to output destination",
      "behavior": "Read processed_data, filter valid records, write to output destination (e.g., file, API), return export summary",
      "boundary": {
        "in_scope": [
          "filtering valid records",
          "writing to destination"
        ],
        "out_of_scope": [
          "ingestion",
          "transformation",
          "validation"
        ]
      },
      "semantic_inputs": [
        {
          "name": "export_destination",
          "description": "Target for export (from parent input)",
          "source": "parent input"
        },
        {
          "name": "processed_data",
          "description": "Transformed records with validity flags",
          "source": "internal leaf access"
        }
      ],
      "semantic_outputs": [
        {
          "name": "export_result",
          "description": "JSON with records_exported, errors",
          "consumer": "parent"
        }
      ],
      "preconditions": [
        "processed_data has validity flags"
      ],
      "postconditions": [
        "valid records are exported"
      ],
      "guarantees": [
        "logs each step",
        "only exports valid records"
      ],
      "composition_role": "execute",
      "stop_decompose": false,
      "stop_reason": ""
    }
  ],
  "decomposition_rationale": "The four children correspond directly to the four functional requirements, each handling a distinct phase of the ETL pipeline. They are at the same abstraction level and do not overlap. The parent orchestrates them in sequence based on the action in the input.",
  "orchestration_model": "conditional sequence",
  "dataflow_sketch": [
    {
      "from": "parent",
      "to": "IngestData",
      "data": "input",
      "note": "action=ingest triggers this child"
    },
    {
      "from": "IngestData",
      "to": "parent",
      "data": "ingest_result",
      "note": "returns count and errors"
    },
    {
      "from": "parent",
      "to": "TransformData",
      "data": "input (transform config)",
      "note": "action=transform triggers this child"
    },
    {
      "from": "TransformData",
      "to": "parent",
      "data": "transform_result",
      "note": "returns count and errors"
    },
    {
      "from": "parent",
      "to": "ValidateQuality",
      "data": "input (validation rules)",
      "note": "action=validate triggers this child"
    },
    {
      "from": "ValidateQuality",
      "to": "parent",
      "data": "validation_result",
      "note": "returns summary"
    },
    {
      "from": "parent",
      "to": "ExportResults",
      "data": "input (export destination)",
      "note": "action=export triggers this child"
    },
    {
      "from": "ExportResults",
      "to": "parent",
      "data": "export_result",
      "note": "returns export summary"
    }
  ]
}