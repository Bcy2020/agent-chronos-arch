{
  "children": [
    {
      "name": "IngestData",
      "purpose": "Read data from external source and store in raw_data",
      "behavior": "Reads input source, parses data, writes to raw_data store, logs ingestion",
      "boundary": {
        "in_scope": [
          "reading source",
          "parsing",
          "writing to raw_data",
          "logging"
        ],
        "out_of_scope": [
          "transformation",
          "validation",
          "export"
        ]
      },
      "preconditions": [
        "input contains valid source"
      ],
      "postconditions": [
        "raw_data contains ingested records"
      ],
      "guarantees": [
        "logs ingestion details"
      ],
      "composition_role": "transform",
      "inputs": [
        {
          "name": "input",
          "type": "dict",
          "description": "JSON with action and source",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "ingestion_result",
          "type": "dict",
          "description": "JSON with success, records_ingested, errors",
          "consumer": "parent"
        }
      ],
      "signature": "def IngestData(input: dict) -> dict",
      "global_vars": [
        {
          "variable": "raw_data",
          "op": "write",
          "description": "write ingested records to raw_data store"
        }
      ],
      "data_operations": [
        {
          "source_name": "raw_data",
          "operation_type": "write",
          "description": "write ingested records to raw_data store"
        }
      ],
      "requested_capabilities": [
        "data_store.raw_data.write",
        "logging.info"
      ],
      "constraints": [
        {
          "constraint_id": "C-001",
          "description": "IngestData must handle malformed source gracefully without crashing"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-001",
          "description": "Given valid source, IngestData writes records to raw_data and returns success"
        },
        {
          "ac_id": "AC-002",
          "description": "Given invalid source, IngestData returns error without writing to raw_data"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-001"
        ]
      },
      "node_type": "pure_function",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "TransformData",
      "purpose": "Apply transformations to raw data and store in processed_data",
      "behavior": "Reads raw_data, applies transformation rules, writes to processed_data, logs transformation",
      "boundary": {
        "in_scope": [
          "reading raw_data",
          "transforming",
          "writing to processed_data",
          "logging"
        ],
        "out_of_scope": [
          "ingestion",
          "validation",
          "export"
        ]
      },
      "preconditions": [
        "raw_data is populated"
      ],
      "postconditions": [
        "processed_data contains transformed records"
      ],
      "guarantees": [
        "logs transformation details"
      ],
      "composition_role": "transform",
      "inputs": [
        {
          "name": "transform_config",
          "type": "dict",
          "description": "Transformation rules from parent",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "transformation_result",
          "type": "dict",
          "description": "JSON with success, records_transformed, errors",
          "consumer": "parent"
        }
      ],
      "signature": "def TransformData(transform_config: dict) -> dict",
      "global_vars": [
        {
          "variable": "raw_data",
          "op": "read",
          "description": "read raw_data for transformation"
        },
        {
          "variable": "processed_data",
          "op": "write",
          "description": "write transformed records to processed_data"
        }
      ],
      "data_operations": [
        {
          "source_name": "raw_data",
          "operation_type": "read",
          "description": "read raw_data for transformation"
        },
        {
          "source_name": "processed_data",
          "operation_type": "write",
          "description": "write transformed records to processed_data"
        }
      ],
      "requested_capabilities": [
        "data_store.raw_data.read",
        "data_store.processed_data.write",
        "logging.info"
      ],
      "constraints": [
        {
          "constraint_id": "C-002",
          "description": "TransformData must preserve record count unless transformation rules explicitly merge/split"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-003",
          "description": "Given valid transform_config and populated raw_data, TransformData writes transformed records to processed_data and returns success"
        },
        {
          "ac_id": "AC-004",
          "description": "Given empty raw_data, TransformData returns success with zero records_transformed"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-002"
        ]
      },
      "node_type": "pure_function",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "ValidateQuality",
      "purpose": "Check quality of processed data and mark invalid records",
      "behavior": "Reads processed_data, applies validation rules, marks invalid records, logs validation",
      "boundary": {
        "in_scope": [
          "reading processed_data",
          "validating",
          "marking invalid records",
          "logging"
        ],
        "out_of_scope": [
          "ingestion",
          "transformation",
          "export"
        ]
      },
      "preconditions": [
        "processed_data is populated"
      ],
      "postconditions": [
        "processed_data has validity flags"
      ],
      "guarantees": [
        "logs validation details"
      ],
      "composition_role": "validate",
      "inputs": [
        {
          "name": "validation_rules",
          "type": "dict",
          "description": "Quality criteria from parent",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "validation_result",
          "type": "dict",
          "description": "JSON with success, valid_count, invalid_count, errors",
          "consumer": "parent"
        }
      ],
      "signature": "def ValidateQuality(validation_rules: dict) -> dict",
      "global_vars": [
        {
          "variable": "processed_data",
          "op": "read_write",
          "description": "read processed_data for validation and write validity flags"
        }
      ],
      "data_operations": [
        {
          "source_name": "processed_data",
          "operation_type": "read_write",
          "description": "read processed_data for validation and write validity flags"
        }
      ],
      "requested_capabilities": [
        "data_store.processed_data.read",
        "data_store.processed_data.write",
        "logging.info"
      ],
      "constraints": [
        {
          "constraint_id": "C-003",
          "description": "ValidateQuality must not modify record content beyond adding validity flags"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-005",
          "description": "Given valid validation_rules and populated processed_data, ValidateQuality marks invalid records and returns success with counts"
        },
        {
          "ac_id": "AC-006",
          "description": "Given empty processed_data, ValidateQuality returns success with zero counts"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-003"
        ]
      },
      "node_type": "pure_function",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "ExportResults",
      "purpose": "Export only valid records from processed_data to output",
      "behavior": "Reads processed_data, filters valid records, formats output, logs export",
      "boundary": {
        "in_scope": [
          "reading processed_data",
          "filtering valid records",
          "formatting output",
          "logging"
        ],
        "out_of_scope": [
          "ingestion",
          "transformation",
          "validation"
        ]
      },
      "preconditions": [
        "processed_data has validity flags"
      ],
      "postconditions": [
        "output contains only valid records"
      ],
      "guarantees": [
        "logs export details",
        "exports only valid records"
      ],
      "composition_role": "execute",
      "inputs": [
        {
          "name": "export_format",
          "type": "dict",
          "description": "Output format specification",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "export_result",
          "type": "dict",
          "description": "JSON with success, records_exported, errors, data",
          "consumer": "parent"
        }
      ],
      "signature": "def ExportResults(export_format: dict) -> dict",
      "global_vars": [
        {
          "variable": "processed_data",
          "op": "read",
          "description": "read processed_data to filter valid records"
        }
      ],
      "data_operations": [
        {
          "source_name": "processed_data",
          "operation_type": "read",
          "description": "read processed_data to filter valid records"
        }
      ],
      "requested_capabilities": [
        "data_store.processed_data.read",
        "logging.info"
      ],
      "constraints": [
        {
          "constraint_id": "C-004",
          "description": "ExportResults must not modify processed_data"
        },
        {
          "constraint_id": "C-005",
          "description": "ExportResults must only export records marked as valid"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-007",
          "description": "Given valid export_format and processed_data with validity flags, ExportResults returns only valid records in specified format"
        },
        {
          "ac_id": "AC-008",
          "description": "Given no valid records, ExportResults returns success with zero records_exported and empty data"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-004"
        ]
      },
      "node_type": "pure_function",
      "stop_decompose": false,
      "stop_reason": ""
    }
  ],
  "governance_notes": "All children are pure functions with no side effects beyond data store operations. Each child's global_vars are a subset of parent's available stores (raw_data, processed_data). Data operations cover parent's data needs: raw_data written by IngestData, read by TransformData; processed_data written by TransformData, read/written by ValidateQuality, read by ExportResults. No child has overlapping write responsibilities to avoid conflicts. Logging is treated as a capability rather than a data operation."
}