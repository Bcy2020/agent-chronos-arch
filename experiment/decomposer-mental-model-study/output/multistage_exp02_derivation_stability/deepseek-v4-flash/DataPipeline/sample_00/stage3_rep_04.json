{
  "children": [
    {
      "name": "IngestData",
      "purpose": "Read data from external source and store in raw_data",
      "behavior": "Reads input source, parses data, writes to raw_data store, logs ingestion",
      "boundary": {
        "in_scope": [
          "reading source",
          "parsing",
          "writing to raw_data",
          "logging"
        ],
        "out_of_scope": [
          "transformation",
          "validation",
          "export"
        ]
      },
      "preconditions": [
        "input contains valid source"
      ],
      "postconditions": [
        "raw_data contains ingested records"
      ],
      "guarantees": [
        "logs ingestion details"
      ],
      "composition_role": "transform",
      "inputs": [
        {
          "name": "input",
          "type": "dict",
          "description": "JSON with action and source",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "ingestion_result",
          "type": "dict",
          "description": "JSON with success, records_ingested, errors",
          "consumer": "parent"
        }
      ],
      "signature": "def IngestData(input: dict) -> dict",
      "global_vars": [
        {
          "variable": "raw_data",
          "op": "write",
          "description": "Write ingested records to raw_data store"
        }
      ],
      "data_operations": [
        {
          "source_name": "raw_data",
          "operation_type": "write",
          "description": "Store ingested records"
        }
      ],
      "requested_capabilities": [
        "data_store.raw_data.write",
        "logging.info"
      ],
      "constraints": [
        {
          "constraint_id": "C-001",
          "description": "Must handle empty source gracefully"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-001",
          "description": "Records are written to raw_data"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-001"
        ]
      },
      "node_type": "pure_function",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "TransformData",
      "purpose": "Apply transformations to raw data and store in processed_data",
      "behavior": "Reads raw_data, applies transformation rules, writes to processed_data, logs transformation",
      "boundary": {
        "in_scope": [
          "reading raw_data",
          "transforming",
          "writing to processed_data",
          "logging"
        ],
        "out_of_scope": [
          "ingestion",
          "validation",
          "export"
        ]
      },
      "preconditions": [
        "raw_data is populated"
      ],
      "postconditions": [
        "processed_data contains transformed records"
      ],
      "guarantees": [
        "logs transformation details"
      ],
      "composition_role": "transform",
      "inputs": [
        {
          "name": "transform_config",
          "type": "dict",
          "description": "Transformation rules from parent",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "transformation_result",
          "type": "dict",
          "description": "JSON with success, records_transformed, errors",
          "consumer": "parent"
        }
      ],
      "signature": "def TransformData(transform_config: dict) -> dict",
      "global_vars": [
        {
          "variable": "raw_data",
          "op": "read",
          "description": "Read raw data for transformation"
        },
        {
          "variable": "processed_data",
          "op": "write",
          "description": "Write transformed records to processed_data store"
        }
      ],
      "data_operations": [
        {
          "source_name": "raw_data",
          "operation_type": "read",
          "description": "Read raw data for transformation"
        },
        {
          "source_name": "processed_data",
          "operation_type": "write",
          "description": "Store transformed records"
        }
      ],
      "requested_capabilities": [
        "data_store.raw_data.read",
        "data_store.processed_data.write",
        "logging.info"
      ],
      "constraints": [
        {
          "constraint_id": "C-002",
          "description": "Must handle empty raw_data gracefully"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-002",
          "description": "Records are written to processed_data"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-002"
        ]
      },
      "node_type": "pure_function",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "ValidateQuality",
      "purpose": "Check quality of processed data and mark invalid records",
      "behavior": "Reads processed_data, applies validation rules, marks invalid records, logs validation",
      "boundary": {
        "in_scope": [
          "reading processed_data",
          "validating",
          "marking invalid records",
          "logging"
        ],
        "out_of_scope": [
          "ingestion",
          "transformation",
          "export"
        ]
      },
      "preconditions": [
        "processed_data is populated"
      ],
      "postconditions": [
        "processed_data has validity flags"
      ],
      "guarantees": [
        "logs validation details"
      ],
      "composition_role": "validate",
      "inputs": [
        {
          "name": "validation_rules",
          "type": "dict",
          "description": "Quality criteria from parent",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "validation_result",
          "type": "dict",
          "description": "JSON with success, valid_count, invalid_count, errors",
          "consumer": "parent"
        }
      ],
      "signature": "def ValidateQuality(validation_rules: dict) -> dict",
      "global_vars": [
        {
          "variable": "processed_data",
          "op": "read_write",
          "description": "Read processed_data for validation and write validity flags"
        }
      ],
      "data_operations": [
        {
          "source_name": "processed_data",
          "operation_type": "read_write",
          "description": "Read processed_data for validation and write validity flags"
        }
      ],
      "requested_capabilities": [
        "data_store.processed_data.read",
        "data_store.processed_data.write",
        "logging.info"
      ],
      "constraints": [
        {
          "constraint_id": "C-003",
          "description": "Must handle empty processed_data gracefully"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-003",
          "description": "Validity flags are set in processed_data"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-003"
        ]
      },
      "node_type": "pure_function",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "ExportResults",
      "purpose": "Export only valid records from processed_data to output",
      "behavior": "Reads processed_data, filters valid records, formats output, logs export",
      "boundary": {
        "in_scope": [
          "reading processed_data",
          "filtering valid records",
          "formatting output",
          "logging"
        ],
        "out_of_scope": [
          "ingestion",
          "transformation",
          "validation"
        ]
      },
      "preconditions": [
        "processed_data has validity flags"
      ],
      "postconditions": [
        "output contains only valid records"
      ],
      "guarantees": [
        "logs export details",
        "exports only valid records"
      ],
      "composition_role": "execute",
      "inputs": [
        {
          "name": "export_format",
          "type": "dict",
          "description": "Output format specification",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "export_result",
          "type": "dict",
          "description": "JSON with success, records_exported, errors, data",
          "consumer": "parent"
        }
      ],
      "signature": "def ExportResults(export_format: dict) -> dict",
      "global_vars": [
        {
          "variable": "processed_data",
          "op": "read",
          "description": "Read processed_data to filter valid records"
        }
      ],
      "data_operations": [
        {
          "source_name": "processed_data",
          "operation_type": "read",
          "description": "Read processed_data to filter valid records"
        }
      ],
      "requested_capabilities": [
        "data_store.processed_data.read",
        "logging.info"
      ],
      "constraints": [
        {
          "constraint_id": "C-004",
          "description": "Must handle empty processed_data gracefully"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-004",
          "description": "Output contains only valid records"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-004"
        ]
      },
      "node_type": "pure_function",
      "stop_decompose": false,
      "stop_reason": ""
    }
  ],
  "governance_notes": "All children are pure functions with no side effects beyond data stores. Data operations cover parent's data needs: IngestData writes to raw_data, TransformData reads raw_data and writes to processed_data, ValidateQuality reads/writes processed_data, ExportResults reads processed_data. Global vars are subsets of parent's global_vars (raw_data, processed_data). No child has stop_decompose=true."
}