{
  "children": [
    {
      "name": "ParseCommand",
      "purpose": "Parse the incoming JSON input to extract the command type and parameters",
      "behavior": "Extract command field from input JSON and validate its presence",
      "boundary": {
        "in_scope": [
          "JSON parsing",
          "command extraction"
        ],
        "out_of_scope": [
          "command execution",
          "data validation"
        ]
      },
      "preconditions": [
        "input is valid JSON"
      ],
      "postconditions": [
        "command is one of the four allowed values"
      ],
      "guarantees": [
        "Returns error if command missing or invalid"
      ],
      "composition_role": "transform",
      "inputs": [
        {
          "name": "input",
          "type": "dict",
          "description": "Raw JSON input from user containing command and parameters",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "command",
          "type": "str",
          "description": "Parsed command string (send/history/create_channel/join)",
          "consumer": "parent"
        },
        {
          "name": "params",
          "type": "dict",
          "description": "Remaining parameters from input after extracting command",
          "consumer": "parent"
        }
      ],
      "signature": "def ParseCommand(input: dict) -> tuple[str, dict]",
      "global_vars": [],
      "data_operations": [],
      "requested_capabilities": [],
      "constraints": [
        {
          "constraint_id": "C-001",
          "description": "Input must be valid JSON"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-001",
          "description": "Returns command and params for valid JSON input"
        },
        {
          "ac_id": "AC-002",
          "description": "Returns error for invalid JSON input"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-001"
        ]
      },
      "node_type": "pure_function",
      "stop_decompose": false,
      "stop_reason": ""
