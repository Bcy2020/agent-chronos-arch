      "signature": "def ValidateSendMessage(params: dict, channels: dict) -> tuple[bool, str]",
      "global_vars": [],
      "data_operations": [
        {
          "source_name": "channels",
          "operation_type": "read",
          "description": "Read channel data to check membership"
