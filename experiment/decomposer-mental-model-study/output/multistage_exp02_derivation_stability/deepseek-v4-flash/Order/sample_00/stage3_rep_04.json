      "behavior": "Parse the input JSON, validate its structure, and return the command and order_data fields",
      "boundary": {
        "in_scope": [
          "JSON parsing",
          "input validation",
          "extraction of command and order_data"
        ],
        "out_of_scope": [
          "Business logic",
          "Data store access"
        ]
      },
      "preconditions": [
        "Input is valid JSON"
      ],
      "postconditions": [
        "Command and order_data are extracted"
      ],
      "guarantees": [
        "Returns error if input is malformed"
      ],
      "composition_role": "transform",
      "inputs": [
        {
          "name": "input",
          "type": "Any",
          "description": "Raw JSON input from parent",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "command",
          "type": "str",
          "description": "The command string (place/cancel/track)",
          "consumer": "parent"
        },
        {
          "name": "order_data",
          "type": "dict",
          "description": "The order data object",
          "consumer": "parent"
        }
      ],
      "signature": "def ParseInput(input: Any) -> tuple[str, dict]",
      "global_vars": [],
      "data_operations": [],
      "requested_capabilities": [],
      "constraints": [
        {
          "constraint_id": "C-001",
          "description": "Input must be valid JSON"
        },
        {
          "constraint_id": "C-002",
          "description": "command field must be one of: place, cancel, track"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-001",
          "description": "Valid JSON input returns (command, order_data) tuple"
        },
        {
          "ac_id": "AC-002",
          "description": "Invalid JSON input raises ValueError"
        },
        {
          "ac_id": "AC-003",
          "description": "Missing command field raises KeyError"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-001"
        ]
      },
      "node_type": "pure_function",
      "stop_decompose": true,
      "stop_reason": "Leaf node - pure parsing logic, no further decomposition needed"
