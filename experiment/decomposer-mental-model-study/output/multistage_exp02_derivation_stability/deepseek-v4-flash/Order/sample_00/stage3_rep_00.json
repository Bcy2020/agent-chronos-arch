          "description": "command field must be one of: place, cancel, track"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-001",
          "description": "Given valid JSON input, returns command and order_data"
        },
        {
          "ac_id": "AC-002",
          "description": "Given invalid JSON, returns error"
        },
        {
          "ac_id": "AC-003",
          "description": "Given missing command field, returns error"
        }
