{
  "children": [
    {
      "name": "ParseCommand",
      "purpose": "Extract and validate the command and order data from the input JSON",
      "behavior": "Parse the input JSON to extract the command field and order_data, validate that command is one of 'place', 'cancel', 'track'",
      "boundary": {
        "in_scope": [
          "Input validation",
          "Command extraction"
        ],
        "out_of_scope": [
          "Order processing",
          "Data store access"
        ]
      },
      "preconditions": [
        "Input is valid JSON"
      ],
      "postconditions": [
        "Command is one of 'place', 'cancel', 'track'"
      ],
      "guarantees": [
        "Returns error if command is invalid"
      ],
      "composition_role": "validate",
      "inputs": [
        {
          "name": "input",
          "type": "Any",
          "description": "Raw input JSON from parent",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "command",
          "type": "str",
          "description": "Validated command string",
          "consumer": "parent"
        },
        {
          "name": "order_data",
          "type": "dict",
          "description": "Parsed order data object",
          "consumer": "parent"
        }
      ],
      "signature": "def ParseCommand(input: Any) -> tuple[str, dict]",
      "global_vars": [],
      "data_operations": [],
      "requested_capabilities": [],
      "constraints": [
        {
          "constraint_id": "C-001",
          "description": "Input must be valid JSON"
        },
        {
          "constraint_id": "C-002",
          "description": "Command must be one of 'place', 'cancel', 'track'"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-001",
          "description": "Valid input returns command and order_data"
        },
        {
          "ac_id": "AC-002",
          "description": "Invalid command returns error"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-001"
        ]
      },
      "node_type": "pure_function",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "PlaceOrder",
      "purpose": "Create a new order, update inventory, and initiate payment",
      "behavior": "Generate order ID, store order in orders with status 'placed', decrement inventory, create payment record",
      "boundary": {
        "in_scope": [
          "Order creation",
          "Inventory update",
          "Payment initiation"
        ],
        "out_of_scope": [
          "Cancellation",
          "Tracking"
        ]
      },
      "preconditions": [
        "Inventory has sufficient stock",
        "Payment method is valid"
      ],
      "postconditions": [
        "Order exists in orders with status 'placed'",
        "Inventory decremented",
        "Payment record created"
      ],
      "guarantees": [
        "Atomic operation: all or nothing"
      ],
      "composition_role": "execute",
      "inputs": [
        {
          "name": "order_data",
          "type": "dict",
          "description": "Order details including items and customer info",
          "source": "parent input via ParseCommand"
        }
      ],
      "outputs": [
        {
          "name": "order_id",
          "type": "str",
          "description": "Generated unique order ID",
          "consumer": "parent"
        },
        {
          "name": "status",
          "type": "str",
          "description": "Order status after placement",
          "consumer": "parent"
        },
        {
          "name": "message",
          "type": "str",
          "description": "Success or error message",
          "consumer": "parent"
        }
      ],
      "signature": "def PlaceOrder(order_data: dict) -> tuple[str, str, str]",
      "global_vars": [],
      "data_operations": [
        {
          "source_name": "orders",
          "operation_type": "write",
          "description": "Create new order record with status 'placed'"
        },
        {
          "source_name": "inventory",
          "operation_type": "write",
          "description": "Decrement stock for ordered items"
        },
        {
          "source_name": "payments",
          "operation_type": "write",
          "description": "Create payment record for the order"
        }
      ],
      "requested_capabilities": [
        "orders.write",
        "inventory.write",
        "payments.write"
      ],
      "constraints": [
        {
          "constraint_id": "C-003",
          "description": "Must check inventory sufficiency before decrement"
        },
        {
          "constraint_id": "C-004",
          "description": "All writes must be atomic (all succeed or all rollback)"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-003",
          "description": "Order is created with unique order_id and status 'placed'"
        },
        {
          "ac_id": "AC-004",
          "description": "Inventory is decremented by ordered quantities"
        },
        {
          "ac_id": "AC-005",
          "description": "Payment record is created"
        },
        {
          "ac_id": "AC-006",
          "description": "Insufficient inventory returns error without side effects"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-002"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "CancelOrder",
      "purpose": "Cancel an existing order if not shipped, restore inventory, and void payment",
      "behavior": "Check order status, if not shipped, update status to 'cancelled', restore inventory, void payment",
      "boundary": {
        "in_scope": [
          "Order cancellation",
          "Inventory restoration",
          "Payment void"
        ],
        "out_of_scope": [
          "Order placement",
          "Tracking"
        ]
      },
      "preconditions": [
        "Order exists",
        "Order status is not 'shipped'"
      ],
      "postconditions": [
        "Order status is 'cancelled'",
        "Inventory restored",
        "Payment voided"
      ],
      "guarantees": [
        "Atomic operation: all or nothing",
        "Cannot cancel shipped orders"
      ],
      "composition_role": "execute",
      "inputs": [
        {
          "name": "order_data",
          "type": "dict",
          "description": "Contains order_id to cancel",
          "source": "parent input via ParseCommand"
        }
      ],
      "outputs": [
        {
          "name": "order_id",
          "type": "str",
          "description": "ID of cancelled order",
          "consumer": "parent"
        },
        {
          "name": "status",
          "type": "str",
          "description": "New status after cancellation",
          "consumer": "parent"
        },
        {
          "name": "message",
          "type": "str",
          "description": "Success or error message",
          "consumer": "parent"
        }
      ],
      "signature": "def CancelOrder(order_data: dict) -> tuple[str, str, str]",
      "global_vars": [],
      "data_operations": [
        {
          "source_name": "orders",
          "operation_type": "read_write",
          "description": "Read current order status, then update to 'cancelled'"
        },
        {
          "source_name": "inventory",
          "operation_type": "write",
          "description": "Restore stock for cancelled order items"
        },
        {
          "source_name": "payments",
          "operation_type": "write",
          "description": "Void payment record for the order"
        }
      ],
      "requested_capabilities": [
        "orders.read",
        "orders.write",
        "inventory.write",
        "payments.write"
      ],
      "constraints": [
        {
          "constraint_id": "C-005",
          "description": "Must check order status before cancellation"
        },
        {
          "constraint_id": "C-006",
          "description": "All writes must be atomic (all succeed or all rollback)"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-007",
          "description": "Order status is updated to 'cancelled'"
        },
        {
          "ac_id": "AC-008",
          "description": "Inventory is restored to previous levels"
        },
        {
          "ac_id": "AC-009",
          "description": "Payment is voided"
        },
        {
          "ac_id": "AC-010",
          "description": "Shipped orders cannot be cancelled"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-003"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "TrackOrder",
      "purpose": "Retrieve and return the current status and details of an order",
      "behavior": "Look up order by ID in orders store, return status and relevant details",
      "boundary": {
        "in_scope": [
          "Order lookup",
          "Status retrieval"
        ],
        "out_of_scope": [
          "Order modification",
          "Inventory or payment changes"
        ]
      },
      "preconditions": [
        "Order exists"
      ],
      "postconditions": [
        "Order data is read, not modified"
      ],
      "guarantees": [
        "Read-only operation"
      ],
      "composition_role": "query",
      "inputs": [
        {
          "name": "order_data",
          "type": "dict",
          "description": "Contains order_id to track",
          "source": "parent input via ParseCommand"
        }
      ],
      "outputs": [
        {
          "name": "order_id",
          "type": "str",
          "description": "ID of tracked order",
          "consumer": "parent"
        },
        {
          "name": "status",
          "type": "str",
          "description": "Current order status",
          "consumer": "parent"
        },
        {
          "name": "message",
          "type": "str",
          "description": "Details or error message",
          "consumer": "parent"
        }
      ],
      "signature": "def TrackOrder(order_data: dict) -> tuple[str, str, str]",
      "global_vars": [],
      "data_operations": [
        {
          "source_name": "orders",
          "operation_type": "read",
          "description": "Read order record by order_id"
        }
      ],
      "requested_capabilities": [
        "orders.read"
      ],
      "constraints": [
        {
          "constraint_id": "C-007",
          "description": "Must not modify any data store"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-011",
          "description": "Returns current order status and details"
        },
        {
          "ac_id": "AC-012",
          "description": "Non-existent order returns error"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-004"
        ]
      },
      "node_type": "pure_function",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "FormatResponse",
      "purpose": "Assemble the final output JSON from the results of the executed command",
      "behavior": "Combine order_id, status, and message into a JSON object with success flag",
      "boundary": {
        "in_scope": [
          "Response formatting"
        ],
        "out_of_scope": [
          "Business logic",
          "Data store access"
        ]
      },
      "preconditions": [
        "Results from command execution are available"
      ],
      "postconditions": [
        "Output is valid JSON"
      ],
      "guarantees": [
        "Consistent response format"
      ],
      "composition_role": "aggregate",
      "inputs": [
        {
          "name": "order_id",
          "type": "str",
          "description": "Order ID from command execution",
          "source": "PlaceOrder or CancelOrder or TrackOrder"
        },
        {
          "name": "status",
          "type": "str",
          "description": "Status from command execution",
          "source": "PlaceOrder or CancelOrder or TrackOrder"
        },
        {
          "name": "message",
          "type": "str",
          "description": "Message from command execution",
          "source": "PlaceOrder or CancelOrder or TrackOrder"
        }
      ],
      "outputs": [
        {
          "name": "output",
          "type": "Any",
          "description": "Final JSON response",
          "consumer": "parent"
        }
      ],
      "signature": "def FormatResponse(order_id: str, status: str, message: str) -> Any",
      "global_vars": [],
      "data_operations": [],
      "requested_capabilities": [],
      "constraints": [
        {
          "constraint_id": "C-008",
          "description": "Output must be valid JSON"
        },
        {
          "constraint_id": "C-009",
          "description": "Response must include success, order_id, status, message fields"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-013",
          "description": "Output is valid JSON with required fields"
        },
        {
          "ac_id": "AC-014",
          "description": "Success flag is true for successful operations, false for errors"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-005"
        ]
      },
      "node_type": "pure_function",
      "stop_decompose": false,
      "stop_reason": ""
    }
  ],
  "governance_notes": "All children are pure functions except PlaceOrder and CancelOrder which are atomic operations requiring transactional writes. No child uses global_vars. Data operations are limited to the three specified stores (orders, inventory, payments). Constraints ensure data integrity and atomicity. Acceptance criteria verify correct behavior for both success and error cases."
}