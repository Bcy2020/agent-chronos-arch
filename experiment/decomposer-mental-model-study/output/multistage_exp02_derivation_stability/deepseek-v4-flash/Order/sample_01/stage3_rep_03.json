{
  "children": [
    {
      "name": "ParseCommand",
      "purpose": "Extract and validate the command and order data from the input JSON",
      "behavior": "Parse the input JSON to extract the command field and order_data, validate that command is one of 'place', 'cancel', 'track'",
      "boundary": {
        "in_scope": [
          "Input validation",
          "Command extraction"
        ],
        "out_of_scope": [
          "Order processing",
          "Data store access"
        ]
      },
      "preconditions": [
        "Input is valid JSON"
      ],
      "postconditions": [
        "Command is one of 'place', 'cancel', 'track'"
      ],
      "guarantees": [
        "Returns error if command is invalid"
      ],
      "composition_role": "validate",
      "inputs": [
        {
          "name": "input",
          "type": "Any",
          "description": "Raw input JSON from parent",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "command",
          "type": "str",
          "description": "Validated command string",
          "consumer": "parent"
        },
        {
          "name": "order_data",
          "type": "dict",
          "description": "Parsed order data object",
          "consumer": "parent"
        }
      ],
      "signature": "def ParseCommand(input: Any) -> tuple[str, dict]",
      "global_vars": [],
      "data_operations": [],
      "requested_capabilities": [],
      "constraints": [
        {
          "constraint_id": "C-001",
          "description": "Input must be valid JSON"
        },
        {
          "constraint_id": "C-002",
          "description": "Command must be one of 'place', 'cancel', 'track'"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-001",
          "description": "Returns command and order_data for valid input"
        },
        {
          "ac_id": "AC-002",
          "description": "Returns error for invalid JSON"
        },
        {
          "ac_id": "AC-003",
          "description": "Returns error for invalid command"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-001"
        ]
      },
      "node_type": "pure_function",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "PlaceOrder",
      "purpose": "Create a new order, update inventory, and initiate payment",
      "behavior": "Generate order ID, store order in orders with status 'placed', decrement inventory, create payment record",
      "boundary": {
        "in_scope": [
          "Order creation",
          "Inventory update",
          "Payment initiation"
        ],
        "out_of_scope": [
          "Cancellation",
          "Tracking"
        ]
      },
      "preconditions": [
        "Inventory has sufficient stock",
        "Payment method is valid"
      ],
      "postconditions": [
        "Order exists in orders with status 'placed'",
        "Inventory decremented",
        "Payment record created"
      ],
      "guarantees": [
        "Atomic operation: all or nothing"
      ],
      "composition_role": "execute",
      "inputs": [
        {
          "name": "order_data",
          "type": "dict",
          "description": "Order details including items and customer info",
          "source": "parent input via ParseCommand"
        }
      ],
      "outputs": [
        {
          "name": "order_id",
          "type": "str",
          "description": "Generated unique order ID",
          "consumer": "parent"
        },
        {
          "name": "status",
          "type": "str",
          "description": "Order status after placement",
          "consumer": "parent"
        },
        {
          "name": "message",
          "type": "str",
          "description": "Success or error message",
          "consumer": "parent"
        }
      ],
      "signature": "def PlaceOrder(order_data: dict) -> tuple[str, str, str]",
      "global_vars": [],
      "data_operations": [
        {
          "source_name": "orders",
          "operation_type": "write",
          "description": "Create new order record"
        },
        {
          "source_name": "inventory",
          "operation_type": "write",
          "description": "Decrement stock for ordered items"
        },
        {
          "source_name": "payments",
          "operation_type": "write",
          "description": "Create payment record"
        }
      ],
      "requested_capabilities": [
        "orders.write",
        "inventory.write",
        "payments.write"
      ],
      "constraints": [
        {
          "constraint_id": "C-003",
          "description": "Must check inventory before decrementing"
        },
        {
          "constraint_id": "C-004",
          "description": "Must generate unique order ID"
        },
        {
          "constraint_id": "C-005",
          "description": "All writes must be atomic"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-004",
          "description": "Order is created with status 'placed'"
        },
        {
          "ac_id": "AC-005",
          "description": "Inventory is decremented correctly"
        },
        {
          "ac_id": "AC-006",
          "description": "Payment record is created"
        },
        {
          "ac_id": "AC-007",
          "description": "Returns error if insufficient inventory"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-002",
          "FR-003"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "CancelOrder",
      "purpose": "Cancel an existing order if not shipped, restore inventory, and void payment",
      "behavior": "Check order status, if not shipped, update status to 'cancelled', restore inventory, void payment",
      "boundary": {
        "in_scope": [
          "Order cancellation",
          "Inventory restoration",
          "Payment void"
        ],
        "out_of_scope": [
          "Order placement",
          "Tracking"
        ]
      },
      "preconditions": [
        "Order exists",
        "Order status is not 'shipped'"
      ],
      "postconditions": [
        "Order status is 'cancelled'",
        "Inventory restored",
        "Payment voided"
      ],
      "guarantees": [
        "Atomic operation: all or nothing",
        "Cannot cancel shipped orders"
      ],
      "composition_role": "execute",
      "inputs": [
        {
          "name": "order_data",
          "type": "dict",
          "description": "Contains order_id to cancel",
          "source": "parent input via ParseCommand"
        }
      ],
      "outputs": [
        {
          "name": "order_id",
          "type": "str",
          "description": "ID of cancelled order",
          "consumer": "parent"
        },
        {
          "name": "status",
          "type": "str",
          "description": "New status after cancellation",
          "consumer": "parent"
        },
        {
          "name": "message",
          "type": "str",
          "description": "Success or error message",
          "consumer": "parent"
        }
      ],
      "signature": "def CancelOrder(order_data: dict) -> tuple[str, str, str]",
      "global_vars": [],
      "data_operations": [
        {
          "source_name": "orders",
          "operation_type": "read_write",
          "description": "Read order status and update to cancelled"
        },
        {
          "source_name": "inventory",
          "operation_type": "write",
          "description": "Restore stock for cancelled order items"
        },
        {
          "source_name": "payments",
          "operation_type": "write",
          "description": "Void payment record"
        }
      ],
      "requested_capabilities": [
        "orders.read",
        "orders.write",
        "inventory.write",
        "payments.write"
      ],
      "constraints": [
        {
          "constraint_id": "C-006",
          "description": "Must check order status before cancelling"
        },
        {
          "constraint_id": "C-007",
          "description": "Cannot cancel shipped orders"
        },
        {
          "constraint_id": "C-008",
          "description": "All writes must be atomic"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-008",
          "description": "Order status is updated to 'cancelled'"
        },
        {
          "ac_id": "AC-009",
          "description": "Inventory is restored correctly"
        },
        {
          "ac_id": "AC-010",
          "description": "Payment is voided"
        },
        {
          "ac_id": "AC-011",
          "description": "Returns error if order is already shipped"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-004"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "TrackOrder",
