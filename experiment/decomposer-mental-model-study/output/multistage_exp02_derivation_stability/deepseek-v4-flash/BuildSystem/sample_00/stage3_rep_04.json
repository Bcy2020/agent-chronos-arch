{
  "children": [
    {
      "name": "ParseInput",
      "purpose": "Parse and validate the input JSON to extract action, repo, and branch",
      "behavior": "Extract action, repo, branch from input; validate required fields and action enum",
      "boundary": {
        "in_scope": [
          "input parsing",
          "validation of required fields",
          "action enum check"
        ],
        "out_of_scope": [
          "build logic",
          "data store access"
        ]
      },
      "preconditions": [
        "input is valid JSON"
      ],
      "postconditions": [
        "action, repo, branch are extracted and validated"
      ],
      "guarantees": [
        "Returns error if input missing required fields or invalid action"
      ],
      "composition_role": "transform",
      "inputs": [
        {
          "name": "input",
          "type": "dict",
          "description": "Raw JSON input from parent",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "parsed_action",
          "type": "str",
          "description": "Validated action string",
          "consumer": "parent"
        },
        {
          "name": "parsed_repo",
          "type": "str",
          "description": "Validated repo string",
          "consumer": "parent"
        },
        {
          "name": "parsed_branch",
          "type": "str",
          "description": "Validated branch string",
          "consumer": "parent"
        }
      ],
      "signature": "def ParseInput(input: dict) -> tuple[str, str, str]",
      "global_vars": [],
      "data_operations": [],
      "requested_capabilities": [],
      "constraints": [
        {
          "constraint_id": "C-001",
          "description": "Input must be valid JSON"
        },
        {
          "constraint_id": "C-002",
          "description": "Action must be one of: trigger, status, list, cancel"
        },
        {
          "constraint_id": "C-003",
          "description": "repo and branch must be non-empty strings"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-001",
          "description": "Given valid JSON with all required fields, returns parsed action, repo, branch"
        },
        {
          "ac_id": "AC-002",
          "description": "Given invalid JSON, returns error"
        },
        {
          "ac_id": "AC-003",
          "description": "Given missing required fields, returns error"
        },
        {
          "ac_id": "AC-004",
          "description": "Given invalid action, returns error"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-001"
        ]
      },
      "node_type": "pure_function",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "CheckExistingBuild",
      "purpose": "Check if a build already exists for the given repo and branch",
      "behavior": "Query builds data store for existing build with matching repo and branch",
      "boundary": {
        "in_scope": [
          "data store query",
          "build existence check"
        ],
        "out_of_scope": [
          "build creation",
          "status updates"
        ]
      },
      "preconditions": [
        "builds data store is accessible"
      ],
      "postconditions": [
        "Returns existing build or null"
      ],
      "guarantees": [
        "Does not modify data store"
      ],
      "composition_role": "query",
      "inputs": [
        {
          "name": "repo",
          "type": "str",
          "description": "Repository name",
          "source": "parent input"
        },
        {
          "name": "branch",
          "type": "str",
          "description": "Branch name",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "existing_build",
          "type": "Optional[dict]",
          "description": "Existing build record or null",
          "consumer": "parent"
        }
      ],
      "signature": "def CheckExistingBuild(repo: str, branch: str) -> Optional[dict]",
      "global_vars": [],
      "data_operations": [
        {
          "source_name": "builds",
          "operation_type": "read",
          "description": "Query builds store for existing build by repo and branch"
        }
      ],
      "requested_capabilities": [
        "builds.read"
      ],
      "constraints": [
        {
          "constraint_id": "C-004",
          "description": "Must query builds store by repo and branch"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-005",
          "description": "Given repo and branch, returns existing build record if found"
        },
        {
          "ac_id": "AC-006",
          "description": "Given repo and branch with no existing build, returns null"
        },
        {
          "ac_id": "AC-007",
          "description": "Does not modify builds store"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-002"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "TriggerBuild",
      "purpose": "Create a new build record and initiate build process",
      "behavior": "Generate build_id, create build record in builds store, set status to running, start log collection",
      "boundary": {
        "in_scope": [
          "build record creation",
          "build_id generation",
          "status initialization"
        ],
        "out_of_scope": [
          "cancellation",
          "status checking"
        ]
      },
      "preconditions": [
        "No existing build for repo+branch",
        "builds data store writable"
      ],
      "postconditions": [
        "New build record created in builds store"
      ],
      "guarantees": [
        "Build ID is unique",
        "Status set to running"
      ],
      "composition_role": "execute",
      "inputs": [
        {
          "name": "repo",
          "type": "str",
          "description": "Repository name",
          "source": "parent input"
        },
        {
          "name": "branch",
          "type": "str",
          "description": "Branch name",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "build_id",
          "type": "str",
          "description": "Newly created build ID",
          "consumer": "parent"
        },
        {
          "name": "status",
          "type": "str",
          "description": "Initial build status (running)",
          "consumer": "parent"
        }
      ],
      "signature": "def TriggerBuild(repo: str, branch: str) -> tuple[str, str]",
      "global_vars": [],
      "data_operations": [
        {
          "source_name": "builds",
          "operation_type": "write",
          "description": "Create new build record in builds store"
        }
      ],
      "requested_capabilities": [
        "builds.write"
      ],
      "constraints": [
        {
          "constraint_id": "C-005",
          "description": "Must generate unique build_id"
        },
        {
          "constraint_id": "C-006",
          "description": "Must set initial status to 'running'"
        },
        {
          "constraint_id": "C-007",
          "description": "Must not create duplicate build for same repo+branch"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-008",
          "description": "Given repo and branch, creates new build record with unique build_id"
        },
        {
          "ac_id": "AC-009",
          "description": "New build record has status 'running'"
        },
        {
          "ac_id": "AC-010",
          "description": "Returns build_id and status"
        },
        {
          "ac_id": "AC-011",
          "description": "Fails if build already exists for repo+branch"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-003"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "CheckBuildStatus",
