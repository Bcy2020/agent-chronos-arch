{
  "children": [
    {
      "name": "ParseInput",
      "purpose": "Parse and validate the input JSON to extract action, repo, and branch",
      "behavior": "Extract action, repo, branch from input; validate required fields and action enum",
      "boundary": {
        "in_scope": [
          "input parsing",
          "validation of required fields",
          "action enum check"
        ],
        "out_of_scope": [
          "build logic",
          "data store access"
        ]
      },
      "preconditions": [
        "input is valid JSON"
      ],
      "postconditions": [
        "action, repo, branch are extracted and validated"
      ],
      "guarantees": [
        "Returns error if input missing required fields or invalid action"
      ],
      "composition_role": "transform",
      "inputs": [
        {
          "name": "input",
          "type": "dict",
          "description": "Raw JSON input from parent",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "parsed_action",
          "type": "str",
          "description": "Validated action string",
          "consumer": "parent"
        },
        {
          "name": "parsed_repo",
          "type": "str",
          "description": "Validated repo string",
          "consumer": "parent"
        },
        {
          "name": "parsed_branch",
          "type": "str",
          "description": "Validated branch string",
          "consumer": "parent"
        }
      ],
      "signature": "def ParseInput(input: dict) -> tuple[str, str, str]",
      "global_vars": [],
      "data_operations": [],
      "requested_capabilities": [],
      "constraints": [
        {
          "constraint_id": "C-001",
          "description": "Input must be valid JSON"
        },
        {
          "constraint_id": "C-002",
          "description": "Action must be one of: trigger, status, list, cancel"
        },
        {
          "constraint_id": "C-003",
          "description": "repo and branch must be non-empty strings"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-001",
          "description": "Given valid JSON with all required fields, returns parsed action, repo, branch"
        },
        {
          "ac_id": "AC-002",
          "description": "Given invalid JSON, returns error"
        },
        {
          "ac_id": "AC-003",
          "description": "Given missing required field, returns error"
        },
        {
          "ac_id": "AC-004",
          "description": "Given invalid action, returns error"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-001"
        ]
      },
      "node_type": "pure_function",
      "stop_decompose": false,
      "stop_reason": ""
