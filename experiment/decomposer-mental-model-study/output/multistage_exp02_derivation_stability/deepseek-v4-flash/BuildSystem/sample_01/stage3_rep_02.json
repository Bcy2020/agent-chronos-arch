{
  "children": [
    {
      "name": "ParseAndValidateInput",
      "purpose": "Parse the input JSON and validate that it contains required fields (action, repo, branch) and that action is one of the allowed values.",
      "behavior": "Extract action, repo, branch from input; validate presence and action enum; return parsed fields or error.",
      "boundary": {
        "in_scope": [
          "input parsing",
          "field validation",
          "action enum check"
        ],
        "out_of_scope": [
          "build logic",
          "data store access"
        ]
      },
      "preconditions": [
        "input is valid JSON"
      ],
      "postconditions": [
        "parsed_input has action, repo, branch"
      ],
      "guarantees": [
        "Returns error for invalid action or missing fields"
      ],
      "composition_role": "validate",
      "inputs": [
        {
          "name": "input",
          "type": "dict",
          "description": "Raw JSON input from parent",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "parsed_input",
          "type": "dict",
          "description": "Validated action, repo, branch",
          "consumer": "parent"
        },
        {
          "name": "error",
          "type": "Optional[str]",
          "description": "Validation error if any",
          "consumer": "parent"
        }
      ],
      "signature": "def ParseAndValidateInput(input: dict) -> Tuple[Optional[dict], Optional[str]]",
      "global_vars": [],
      "data_operations": [],
      "requested_capabilities": [],
      "constraints": [
        {
          "constraint_id": "C-001",
          "description": "Input must be valid JSON"
        },
        {
          "constraint_id": "C-002",
          "description": "Action must be one of: trigger, status, list, cancel"
        },
        {
          "constraint_id": "C-003",
          "description": "repo and branch fields are required"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-001",
          "description": "Returns parsed_input with action, repo, branch for valid input"
        },
        {
          "ac_id": "AC-002",
          "description": "Returns error for missing fields"
        },
        {
          "ac_id": "AC-003",
          "description": "Returns error for invalid action"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-001"
        ]
      },
      "node_type": "pure_function",
      "stop_decompose": true,
      "stop_reason": "Pure function, no side effects"
    },
    {
      "name": "CheckBuildExists",
      "purpose": "Check if a build already exists for the given repo and branch in the builds store.",
      "behavior": "Query builds store by repo and branch; return boolean and existing build_id if found.",
      "boundary": {
        "in_scope": [
          "builds store query",
          "repo+branch lookup"
        ],
        "out_of_scope": [
          "triggering",
          "cancelling",
          "listing"
        ]
      },
      "preconditions": [
        "builds store is accessible"
      ],
      "postconditions": [
        "No side effects on builds store"
      ],
      "guarantees": [
        "Returns accurate existence status"
      ],
      "composition_role": "query",
      "inputs": [
        {
          "name": "repo",
          "type": "str",
          "description": "Repository name",
          "source": "ParseAndValidateInput output"
        },
        {
          "name": "branch",
          "type": "str",
          "description": "Branch name",
          "source": "ParseAndValidateInput output"
        }
      ],
      "outputs": [
        {
          "name": "exists",
          "type": "bool",
          "description": "True if build exists",
          "consumer": "parent"
        },
        {
          "name": "existing_build_id",
          "type": "Optional[str]",
          "description": "Build ID if exists",
          "consumer": "parent"
        }
      ],
      "signature": "def CheckBuildExists(repo: str, branch: str) -> Tuple[bool, Optional[str]]",
      "global_vars": [],
      "data_operations": [
        {
          "source_name": "builds",
          "operation_type": "read",
          "description": "Query builds store by repo and branch"
        }
      ],
      "requested_capabilities": [
        "builds.read"
      ],
      "constraints": [
        {
          "constraint_id": "C-004",
          "description": "Builds store must be accessible"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-004",
          "description": "Returns exists=True and existing_build_id for existing builds"
        },
        {
          "ac_id": "AC-005",
          "description": "Returns exists=False and existing_build_id=None for non-existing builds"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-002"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": true,
      "stop_reason": "Atomic data store query"
    },
    {
      "name": "TriggerBuild",
      "purpose": "Create a new build record in the builds store and return build_id.",
      "behavior": "Generate unique build_id, create build record with status 'running', store in builds store, return build_id.",
      "boundary": {
        "in_scope": [
          "build creation",
          "build_id generation",
          "status initialization"
        ],
        "out_of_scope": [
          "cancelling",
          "listing",
          "status checking"
        ]
      },
      "preconditions": [
        "No existing build for repo+branch",
        "builds store writable"
      ],
      "postconditions": [
        "New build record exists in builds store"
      ],
      "guarantees": [
        "Build status is 'running'",
        "build_id is unique"
      ],
      "composition_role": "execute",
      "inputs": [
        {
          "name": "repo",
          "type": "str",
          "description": "Repository name",
          "source": "ParseAndValidateInput output"
        },
        {
          "name": "branch",
          "type": "str",
          "description": "Branch name",
          "source": "ParseAndValidateInput output"
        }
      ],
      "outputs": [
        {
          "name": "build_id",
          "type": "str",
          "description": "Newly created build ID",
          "consumer": "parent"
        }
      ],
      "signature": "def TriggerBuild(repo: str, branch: str) -> str",
      "global_vars": [],
      "data_operations": [
        {
          "source_name": "builds",
          "operation_type": "write",
          "description": "Create new build record with status 'running'"
        }
      ],
      "requested_capabilities": [
        "builds.write"
      ],
      "constraints": [
        {
          "constraint_id": "C-005",
          "description": "No existing build for same repo+branch"
        },
        {
          "constraint_id": "C-006",
          "description": "build_id must be unique"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-006",
          "description": "Returns a unique build_id"
        },
        {
          "ac_id": "AC-007",
          "description": "Build record is created with status 'running'"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-003"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": true,
      "stop_reason": "Atomic write operation"
    },
    {
      "name": "GetBuildStatus",
      "purpose": "Retrieve the current status of a build from the builds store.",
      "behavior": "Query builds store by build_id; return status and logs.",
      "boundary": {
        "in_scope": [
          "build status retrieval",
          "log retrieval"
        ],
        "out_of_scope": [
          "triggering",
          "cancelling",
          "listing"
        ]
      },
      "preconditions": [
        "build_id exists in builds store"
      ],
      "postconditions": [
        "No side effects"
      ],
      "guarantees": [
        "Returns accurate status and logs"
      ],
      "composition_role": "query",
      "inputs": [
        {
          "name": "build_id",
          "type": "str",
          "description": "Build ID to check",
          "source": "parent input (from parsed_input or existing_build_id)"
        }
      ],
      "outputs": [
        {
          "name": "status",
          "type": "str",
          "description": "Current build status",
          "consumer": "parent"
        },
        {
          "name": "logs",
          "type": "List[str]",
          "description": "Build logs",
          "consumer": "parent"
        }
      ],
      "signature": "def GetBuildStatus(build_id: str) -> Tuple[str, List[str]]",
      "global_vars": [],
      "data_operations": [
        {
          "source_name": "builds",
          "operation_type": "read",
          "description": "Query builds store by build_id"
        }
      ],
      "requested_capabilities": [
        "builds.read"
      ],
      "constraints": [
        {
          "constraint_id": "C-007",
          "description": "build_id must exist in builds store"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-008",
          "description": "Returns status and logs for existing build_id"
        },
        {
          "ac_id": "AC-009",
          "description": "Returns error for non-existing build_id"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-004"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": true,
      "stop_reason": "Atomic data store query"
    },
    {
      "name": "ListBuilds",
      "purpose": "List all builds from the builds store, optionally filtered by repo and branch.",
      "behavior": "Query builds store; if repo and branch provided, filter; return list of builds with status and logs.",
      "boundary": {
        "in_scope": [
          "build listing",
          "filtering"
        ],
        "out_of_scope": [
          "triggering",
          "cancelling",
          "status checking"
        ]
      },
      "preconditions": [
        "builds store is accessible"
      ],
      "postconditions": [
        "No side effects"
      ],
      "guarantees": [
        "Returns all matching builds"
      ],
      "composition_role": "query",
      "inputs": [
        {
          "name": "repo",
          "type": "Optional[str]",
          "description": "Optional repository filter",
          "source": "ParseAndValidateInput output"
        },
        {
          "name": "branch",
          "type": "Optional[str]",
          "description": "Optional branch filter",
          "source": "ParseAndValidateInput output"
        }
      ],
      "outputs": [
        {
          "name": "builds_list",
          "type": "List[dict]",
          "description": "List of builds with details",
          "consumer": "parent"
        }
      ],
      "signature": "def ListBuilds(repo: Optional[str], branch: Optional[str]) -> List[dict]",
      "global_vars": [],
      "data_operations": [
        {
          "source_name": "builds",
          "operation_type": "read",
          "description": "Query builds store with optional filters"
        }
      ],
      "requested_capabilities": [
        "builds.read"
      ],
      "constraints": [
        {
          "constraint_id": "C-008",
          "description": "Builds store must be accessible"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-010",
          "description": "Returns all builds when no filters provided"
        },
        {
          "ac_id": "AC-011",
          "description": "Returns filtered builds when repo and/or branch provided"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-005"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": true,
      "stop_reason": "Atomic data store query"
    },
    {
      "name": "CancelBuild",
      "purpose": "Cancel a running build by updating its status to 'cancelled' in the builds store.",
      "behavior": "Update build record status to 'cancelled' in builds store; return success.",
      "boundary": {
        "in_scope": [
          "build cancellation",
          "status update"
        ],
        "out_of_scope": [
          "triggering",
          "listing",
          "status checking"
        ]
      },
      "preconditions": [
        "build_id exists in builds store",
        "build status is 'running'"
      ],
      "postconditions": [
        "Build status is 'cancelled'"
      ],
      "guarantees": [
        "Only cancels running builds"
      ],
      "composition_role": "execute",
      "inputs": [
        {
          "name": "build_id",
          "type": "str",
          "description": "Build ID to cancel",
          "source": "parent input (from parsed_input or existing_build_id)"
        }
      ],
      "outputs": [
        {
          "name": "success",
          "type": "bool",
          "description": "True if cancelled",
          "consumer": "parent"
        }
      ],
      "signature": "def CancelBuild(build_id: str) -> bool",
      "global_vars": [],
      "data_operations": [
        {
          "source_name": "builds",
          "operation_type": "write",
          "description": "Update build status to 'cancelled'"
        }
      ],
      "requested_capabilities": [
        "builds.write"
      ],
      "constraints": [
        {
          "constraint_id": "C-009",
          "description": "build_id must exist in builds store"
        },
        {
          "constraint_id": "C-010",
          "description": "Build must be in 'running' status to cancel"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-012",
          "description": "Returns True and updates status to 'cancelled' for running builds"
        },
        {
          "ac_id": "AC-013",
          "description": "Returns False for non-running or non-existing builds"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-006"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": true,
      "stop_reason": "Atomic write operation"
    },
    {
      "name": "FormatOutput",
