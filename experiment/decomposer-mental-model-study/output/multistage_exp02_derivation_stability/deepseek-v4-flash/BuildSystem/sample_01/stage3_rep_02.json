          "type": "dict",
          "description": "Final JSON response",
          "consumer": "parent"
        }
      ],
      "signature": "def FormatOutput(action: str, build_id: Optional[str], status: Optional[str], logs: Optional[List[str]], builds_list: Optional[List[dict]], error: Optional[str]) -> dict",
      "global_vars": [],
      "data_operations": [],
      "requested_capabilities": [],
      "constraints": [
        {
          "constraint_id": "C-011",
          "description": "Output must be valid JSON"
        },
        {
          "constraint_id": "C-012",
          "description": "Output must contain success field"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-014",
          "description": "Returns JSON with success=true and relevant fields for successful operations"
        },
        {
          "ac_id": "AC-015",
          "description": "Returns JSON with success=false and error message for failed operations"
        }
