          "source_name": "books",
          "operation_type": "read_write",
          "description": "Add new book entry"
        },
        {
          "source_name": "next_id",
          "operation_type": "read_write",
          "description": "Read and increment ID counter"
        }
      ],
      "constraints": [
        {
          "constraint_id": "C-001",
          "description": "Book ID must be unique and auto-incremented"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-001",
          "description": "Book is added with unique ID and status 'available'",
          "verification_method": "automated_test"
        }
      ],
      "global_vars": [
        {
          "variable": "books",
          "op": "read_write",
          "description": "Add new book entry"
        },
        {
          "variable": "next_id",
