{
  "children": [
    {
      "name": "AddBook",
      "purpose": "Adds a new book to the library with a unique ID and default status 'available'",
      "inputs": [
        {
          "name": "title",
          "type": "str",
          "description": "Title of the book to add",
          "source": "parent book_data.title"
        },
        {
          "name": "author",
          "type": "str",
          "description": "Author of the book to add",
          "source": "parent book_data.author"
        }
      ],
      "outputs": [
        {
          "name": "result",
          "type": "dict",
          "description": "Result with success, message, and data containing book_id",
          "consumer": "parent"
        }
      ],
      "boundary": {
        "in_scope": [
          "Add book with title and author",
          "Assign unique ID",
          "Set status to available"
        ],
        "out_of_scope": [
          "List, borrow, return, remove operations",
          "Status filtering",
          "Duplicate title detection"
        ]
      },
      "preconditions": [
        "Title and author are non-empty strings"
      ],
      "postconditions": [
        "Book is added to books dict with unique ID",
        "next_id is incremented"
      ],
      "behavior": "Generates a new book_id using next_id, creates book entry with title, author, and status='available', increments next_id, returns success result with book_id",
      "signature": "def AddBook(title: str, author: str) -> dict",
      "stop_decompose": false,
      "stop_reason": "",
      "node_type": "atomic_operation",
      "data_operations": [
