{
  "children": [
    {
      "name": "ParseCommand",
      "purpose": "Validate and parse the command string to determine the operation type.",
      "behavior": "Check that command is one of 'place', 'cancel', 'track'. If invalid, return error.",
      "boundary": {
        "in_scope": [
          "command validation",
          "command type extraction"
        ],
        "out_of_scope": [
          "order data validation",
          "execution of command logic"
        ]
      },
      "preconditions": [
        "command is a string"
      ],
      "postconditions": [
        "parsed_command is one of 'place', 'cancel', 'track' or error is set"
      ],
      "guarantees": [
        "Returns error for invalid command"
      ],
      "composition_role": "validate",
      "stop_decompose": true,
      "stop_reason": "Pure validation function",
      "inputs": [
        {
          "name": "command",
          "type": "str",
          "description": "Order command string",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "parsed_command",
          "type": "str",
          "description": "Validated command type ('place', 'cancel', 'track')",
          "consumer": "parent"
        },
        {
          "name": "error",
          "type": "Optional[str]",
          "description": "Error message if command invalid, None otherwise",
          "consumer": "parent"
        }
      ],
      "signature": "def ParseCommand(command: str) -> tuple[str, Optional[str]]"
    },
    {
      "name": "PlaceOrder",
      "purpose": "Execute the 'place' command: validate items, charge payment, reserve inventory, create order, send notification.",
      "behavior": "Sequentially call child functions for each step; if any fails, rollback previous steps.",
      "boundary": {
        "in_scope": [
          "item validation",
          "payment charging",
          "inventory reservation",
          "order creation",
          "notification"
        ],
        "out_of_scope": [
          "cancel logic",
          "track logic"
        ]
      },
      "preconditions": [
        "command is 'place'",
        "order_data contains required fields"
      ],
      "postconditions": [
        "If success, order created and payment charged; if fail, all changes rolled back"
      ],
      "guarantees": [
        "Atomic execution with rollback"
      ],
      "composition_role": "execute",
      "stop_decompose": false,
      "stop_reason": "Complex multi-step operation",
      "inputs": [
        {
          "name": "order_data",
          "type": "dict",
          "description": "Order payload with items (list), payment_method (str), shipping_address (dict)",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "order_result",
          "type": "dict",
          "description": "Result with success (bool), order_id (str), status (str), message (str)",
          "consumer": "parent"
        }
      ],
      "signature": "def PlaceOrder(order_data: dict) -> dict"
    },
    {
      "name": "CancelOrder",
      "purpose": "Execute the 'cancel' command: verify order exists and not shipped, refund payment, restore inventory, update status.",
      "behavior": "Sequentially call child functions; rollback on failure.",
      "boundary": {
        "in_scope": [
          "order existence check",
          "shipped status check",
          "payment refund",
          "inventory restoration",
          "status update"
        ],
        "out_of_scope": [
          "place logic",
          "track logic"
        ]
      },
      "preconditions": [
        "command is 'cancel'",
        "order_data contains order_id"
      ],
      "postconditions": [
        "If success, order cancelled and refunded; if fail, no changes"
      ],
      "guarantees": [
        "Atomic execution with rollback"
      ],
      "composition_role": "execute",
      "stop_decompose": false,
      "stop_reason": "Complex multi-step operation",
      "inputs": [
        {
          "name": "order_data",
          "type": "dict",
          "description": "Order payload with order_id (str)",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "order_result",
          "type": "dict",
          "description": "Result with success (bool), order_id (str), status (str), message (str)",
          "consumer": "parent"
        }
      ],
      "signature": "def CancelOrder(order_data: dict) -> dict"
    },
    {
      "name": "TrackOrder",
      "purpose": "Execute the 'track' command: retrieve order status and estimated delivery time.",
      "behavior": "Query orders database for order_id, return status and delivery estimate.",
      "boundary": {
        "in_scope": [
          "order status retrieval",
          "delivery time estimation"
        ],
        "out_of_scope": [
          "place logic",
          "cancel logic"
        ]
      },
      "preconditions": [
        "command is 'track'",
        "order_data contains order_id"
      ],
      "postconditions": [
        "Order status and delivery time returned"
      ],
      "guarantees": [
        "Read-only operation, no side effects"
      ],
      "composition_role": "query",
      "stop_decompose": false,
      "stop_reason": "Simple query but may involve multiple data sources",
      "inputs": [
        {
          "name": "order_data",
          "type": "dict",
          "description": "Order payload with order_id (str)",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "order_result",
          "type": "dict",
          "description": "Result with success (bool), order_id (str), status (str), message (str, includes delivery time)",
          "consumer": "parent"
        }
      ],
      "signature": "def TrackOrder(order_data: dict) -> dict"
    }
  ],
  "interface_preservation": {
    "parent_inputs_covered_by": {
      "command": "ParseCommand.inputs[0]",
      "order_data": "PlaceOrder.inputs[0], CancelOrder.inputs[0], TrackOrder.inputs[0]"
    },
    "parent_outputs_produced_by": {
      "order_result": "PlaceOrder.outputs[0], CancelOrder.outputs[0], TrackOrder.outputs[0]"
    }
  },
  "dataflow_edges": [
    {
      "from_node": "parent",
      "from_output": "command",
      "to_node": "ParseCommand",
      "to_input": "command",
      "note": "Pass command for validation"
    },
    {
      "from_node": "ParseCommand",
      "from_output": "parsed_command",
      "to_node": "parent",
      "to_input": "",
      "note": "Return validated command type"
    },
    {
      "from_node": "ParseCommand",
      "from_output": "error",
      "to_node": "parent",
      "to_input": "",
      "note": "Return error if invalid"
    },
    {
      "from_node": "parent",
      "from_output": "order_data",
      "to_node": "PlaceOrder",
      "to_input": "order_data",
      "note": "Pass order data for place operation"
    },
    {
      "from_node": "parent",
      "from_output": "order_data",
      "to_node": "CancelOrder",
      "to_input": "order_data",
      "note": "Pass order data for cancel operation"
    },
    {
      "from_node": "parent",
      "from_output": "order_data",
      "to_node": "TrackOrder",
      "to_input": "order_data",
      "note": "Pass order data for track operation"
    },
    {
      "from_node": "PlaceOrder",
      "from_output": "order_result",
      "to_node": "parent",
      "to_input": "",
      "note": "Return result of place operation"
    },
    {
      "from_node": "CancelOrder",
      "from_output": "order_result",
      "to_node": "parent",
      "to_input": "",
      "note": "Return result of cancel operation"
    },
    {
      "from_node": "TrackOrder",
      "from_output": "order_result",
      "to_node": "parent",
      "to_input": "",
      "note": "Return result of track operation"
    }
  ]
}