      "Creator is member"
    ],
    "guarantees": [
      "Channel name is unique"
    ],
    "composition_role": "mutate",
    "stop_decompose": false,
    "stop_reason": "",
    "inputs": [
      {
        "name": "message_data",
        "type": "dict",
        "description": "Contains channel_name, user_id",
        "source": "parent input"
      },
      {
        "name": "channels",
        "type": "Database",
        "description": "Read/write access",
        "source": "internal leaf access"
      }
    ],
    "outputs": [
      {
        "name": "create_result",
        "type": "dict",
        "description": "Success flag and new channel_id",
        "consumer": "parent"
      }
    ],
    "signature": "def CreateChannel(message_data: dict, channels: Database) -> dict",
    "global_vars": [
      {
        "variable": "channels",
        "op": "read_write",
        "description": "Check name uniqueness and store new channel"
      }
    ],
    "data_operations": [
      {
        "source_name": "channels",
        "operation_type": "read",
        "description": "Check if channel name already exists"
      },
      {
        "source_name": "channels",
        "operation_type": "write",
        "description": "Insert new channel record"
      }
    ],
    "requested_capabilities": [
      "channels.read",
      "channels.write"
