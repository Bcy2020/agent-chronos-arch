        "ac_id": "AC-008",
        "description": "New channel created with unique name"
      },
      {
        "ac_id": "AC-009",
        "description": "Creator added as first member"
      },
      {
        "ac_id": "AC-010",
        "description": "Returns error if channel name already exists"
      }
    ],
    "traceability": {
      "parent_requirement_ids": [
        "FR-001",
        "FR-004"
      ]
    },
    "node_type": "atomic_operation"
  },
  {
