[
  {
    "name": "ValidateCommand",
    "purpose": "Check that the command is one of the allowed four and that required fields in message_data are present",
    "behavior": "If command is not in ['send','history','create_channel','join'], return error. For each command, verify necessary fields exist in message_data.",
    "boundary": {
      "in_scope": [
        "command validation",
        "required field presence"
      ],
      "out_of_scope": [
        "business logic",
        "data access"
      ]
    },
    "semantic_inputs": [
      {
        "name": "command",
        "description": "chat command string",
        "source": "parent input"
      },
      {
        "name": "message_data",
        "description": "payload with content, channel_id, user_id, channel_name",
        "source": "parent input"
      }
    ],
    "semantic_outputs": [
      {
        "name": "validation_result",
        "description": "success flag and error message if invalid",
        "consumer": "parent"
      }
    ],
    "preconditions": [
      "command and message_data are provided"
    ],
    "postconditions": [
      "If invalid, parent returns error immediately"
    ],
    "guarantees": [
      "Only valid commands and complete data proceed"
    ],
    "composition_role": "validate",
    "stop_decompose": false,
    "stop_reason": "",
    "inputs": [
      {
        "name": "command",
        "type": "str",
        "description": "Chat command to validate",
        "source": "parent input"
      },
      {
        "name": "message_data",
        "type": "dict",
        "description": "Message payload with content, channel_id, user_id, channel_name",
        "source": "parent input"
      }
    ],
    "outputs": [
      {
        "name": "validation_result",
        "type": "dict",
        "description": "Contains success (bool) and error (str, optional)",
        "consumer": "parent"
      }
    ],
    "signature": "def ValidateCommand(command: str, message_data: dict) -> dict",
    "global_vars": [],
    "data_operations": [],
    "requested_capabilities": [],
    "constraints": [
      {
        "constraint_id": "C-001",
        "description": "Must not modify any data store"
      }
    ],
    "acceptance_criteria": [
      {
        "ac_id": "AC-001",
        "description": "Returns error for invalid commands"
      },
      {
        "ac_id": "AC-002",
        "description": "Returns error for missing required fields"
      }
    ],
    "traceability": {
      "parent_requirement_ids": [
        "FR-001"
      ]
    },
    "node_type": "pure_function"
  },
  {
    "name": "SendMessage",
    "purpose": "Execute the 'send' command: validate membership, store message, update last_seen, notify members",
    "behavior": "Check user is member of channel via channels store. If not, return error. Store message in messages store with timestamp. Update user's last_seen in users store. Retrieve channel members and prepare notification data (message details).",
    "boundary": {
      "in_scope": [
        "membership check",
        "message storage",
        "last_seen update",
        "notification preparation"
      ],
      "out_of_scope": [
        "actual notification sending",
        "history retrieval"
      ]
    },
    "semantic_inputs": [
      {
        "name": "message_data",
        "description": "contains user_id, channel_id, content",
        "source": "parent input"
      },
      {
        "name": "channels",
        "description": "read access to check membership",
        "source": "internal leaf access"
      },
      {
        "name": "messages",
        "description": "write access to store message",
        "source": "internal leaf access"
      },
      {
        "name": "users",
        "description": "write access to update last_seen",
        "source": "internal leaf access"
      }
    ],
    "semantic_outputs": [
      {
        "name": "send_result",
        "description": "success flag, message data, and list of members to notify",
        "consumer": "parent"
      }
    ],
    "preconditions": [
      "command is 'send'",
      "user is member of channel"
    ],
    "postconditions": [
      "Message stored",
      "last_seen updated",
      "notification data prepared"
    ],
    "guarantees": [
      "Message is persisted",
      "Only members are notified"
    ],
    "composition_role": "execute",
    "stop_decompose": false,
    "stop_reason": "",
    "inputs": [
      {
        "name": "message_data",
        "type": "dict",
        "description": "Contains user_id, channel_id, content",
        "source": "parent input"
      },
      {
        "name": "channels",
        "type": "Database",
        "description": "Read access to check membership",
        "source": "internal leaf access"
      },
      {
        "name": "messages",
        "type": "Database",
        "description": "Write access to store message",
        "source": "internal leaf access"
      }
    ],
    "outputs": [
      {
        "name": "send_result",
        "type": "dict",
        "description": "Success flag, message data, and list of members to notify",
        "consumer": "parent"
      }
    ],
    "signature": "def SendMessage(message_data: dict, channels: Database, messages: Database) -> dict",
    "global_vars": [
      {
        "variable": "messages",
        "op": "write",
        "description": "Store new message"
      },
      {
        "variable": "users",
        "op": "write",
        "description": "Update last_seen for user"
      },
      {
        "variable": "channels",
        "op": "read",
        "description": "Check membership and get member list"
      }
    ],
    "data_operations": [
      {
        "source_name": "messages",
        "operation_type": "write",
        "description": "Insert new message record"
      },
      {
        "source_name": "users",
        "operation_type": "write",
        "description": "Update user's last_seen timestamp"
      },
      {
        "source_name": "channels",
        "operation_type": "read",
        "description": "Read channel members for membership check and notification"
      }
    ],
    "requested_capabilities": [
      "messages.write",
      "users.write",
      "channels.read"
    ],
    "constraints": [
      {
        "constraint_id": "C-002",
        "description": "Must verify user is member of channel before storing message"
      }
    ],
    "acceptance_criteria": [
      {
        "ac_id": "AC-003",
        "description": "Message stored with correct channel_id, user_id, content, timestamp"
      },
      {
        "ac_id": "AC-004",
        "description": "User's last_seen updated after message stored"
      },
      {
        "ac_id": "AC-005",
        "description": "Returns error if user not in channel"
      }
    ],
    "traceability": {
      "parent_requirement_ids": [
        "FR-001",
        "FR-002"
      ]
    },
    "node_type": "atomic_operation"
  },
  {
    "name": "GetHistory",
    "purpose": "Execute the 'history' command: retrieve last 100 messages from a channel sorted by timestamp descending",
    "behavior": "Query messages store for all messages with given channel_id, sort by timestamp descending, limit to 100, return list.",
    "boundary": {
      "in_scope": [
        "message retrieval",
        "sorting",
        "limiting"
      ],
      "out_of_scope": [
        "membership check",
        "other commands"
      ]
    },
    "semantic_inputs": [
      {
        "name": "message_data",
        "description": "contains channel_id",
        "source": "parent input"
      },
      {
        "name": "messages",
        "description": "read access to query messages",
        "source": "internal leaf access"
      }
    ],
    "semantic_outputs": [
      {
        "name": "history_result",
        "description": "list of up to 100 messages with content, user_id, timestamp",
        "consumer": "parent"
      }
    ],
    "preconditions": [
      "command is 'history'",
      "channel_id is provided"
    ],
    "postconditions": [
      "Messages returned sorted by time"
    ],
    "guarantees": [
      "Returns at most 100 messages"
    ],
    "composition_role": "query",
    "stop_decompose": false,
    "stop_reason": "",
    "inputs": [
      {
        "name": "message_data",
        "type": "dict",
        "description": "Contains channel_id",
        "source": "parent input"
      },
      {
        "name": "messages",
        "type": "Database",
        "description": "Read access to query messages",
        "source": "internal leaf access"
      }
    ],
    "outputs": [
      {
        "name": "history_result",
        "type": "dict",
        "description": "List of up to 100 messages with content, user_id, timestamp",
        "consumer": "parent"
      }
    ],
    "signature": "def GetHistory(message_data: dict, messages: Database) -> dict",
    "global_vars": [
      {
        "variable": "messages",
        "op": "read",
        "description": "Query messages by channel_id"
      }
    ],
    "data_operations": [
      {
        "source_name": "messages",
        "operation_type": "read",
        "description": "Retrieve messages filtered by channel_id"
      }
    ],
    "requested_capabilities": [
      "messages.read"
    ],
    "constraints": [
      {
        "constraint_id": "C-003",
        "description": "Must return at most 100 messages"
      }
    ],
    "acceptance_criteria": [
      {
        "ac_id": "AC-006",
        "description": "Returns up to 100 messages sorted by timestamp descending"
      },
      {
        "ac_id": "AC-007",
        "description": "Returns empty list if no messages in channel"
      }
    ],
    "traceability": {
      "parent_requirement_ids": [
        "FR-001",
        "FR-003"
      ]
    },
    "node_type": "pure_function"
  },
  {
    "name": "CreateChannel",
    "purpose": "Execute the 'create_channel' command: create new channel with unique name, set creator as first member",
    "behavior": "Check if channel name already exists in channels store. If yes, return error. Generate new channel_id, store channel with name, members=[user_id], created_by=user_id.",
    "boundary": {
      "in_scope": [
        "name uniqueness check",
        "channel creation",
        "member initialization"
      ],
      "out_of_scope": [
        "other commands",
        "message storage"
      ]
    },
    "semantic_inputs": [
      {
        "name": "message_data",
        "description": "contains channel_name, user_id",
        "source": "parent input"
      },
      {
        "name": "channels",
        "description": "read/write access",
        "source": "internal leaf access"
      }
    ],
    "semantic_outputs": [
      {
        "name": "create_result",
        "description": "success flag and new channel_id",
        "consumer": "parent"
      }
    ],
    "preconditions": [
