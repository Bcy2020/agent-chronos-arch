{
  "children": [
    {
      "name": "ValidateCommand",
      "purpose": "Check that the command is one of the allowed four and that required fields in message_data are present",
      "behavior": "If command is not in ['send','history','create_channel','join'], return error. For each command, verify necessary fields exist in message_data.",
      "boundary": {
        "in_scope": [
          "command validation",
          "required field presence"
        ],
        "out_of_scope": [
          "business logic",
          "data access"
        ]
      },
      "preconditions": [
        "command and message_data are provided"
      ],
      "postconditions": [
        "If invalid, parent returns error immediately"
      ],
      "guarantees": [
        "Only valid commands and complete data proceed"
      ],
      "composition_role": "validate",
      "stop_decompose": false,
      "stop_reason": "",
      "inputs": [
        {
          "name": "command",
          "type": "str",
          "description": "Chat command to validate",
          "source": "parent input"
        },
        {
          "name": "message_data",
          "type": "dict",
          "description": "Message payload with content, channel_id, user_id, channel_name",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "validation_result",
          "type": "dict",
          "description": "Contains success (bool) and error (str, optional)",
          "consumer": "parent"
        }
      ],
      "signature": "def ValidateCommand(command: str, message_data: dict) -> dict"
    },
    {
      "name": "SendMessage",
      "purpose": "Execute the 'send' command: validate membership, store message, update last_seen, notify members",
      "behavior": "Check user is member of channel via channels store. If not, return error. Store message in messages store with timestamp. Update user's last_seen in users store. Retrieve channel members and prepare notification data (message details).",
      "boundary": {
        "in_scope": [
          "membership check",
          "message storage",
          "last_seen update",
          "notification preparation"
        ],
        "out_of_scope": [
          "actual notification sending",
          "history retrieval"
        ]
      },
      "preconditions": [
        "command is 'send'",
        "user is member of channel"
      ],
      "postconditions": [
        "Message stored",
        "last_seen updated",
        "notification data prepared"
      ],
      "guarantees": [
        "Message is persisted",
        "Only members are notified"
      ],
      "composition_role": "execute",
      "stop_decompose": false,
      "stop_reason": "",
      "inputs": [
        {
          "name": "message_data",
          "type": "dict",
          "description": "Contains user_id, channel_id, content",
          "source": "parent input"
        },
        {
          "name": "channels",
          "type": "Database",
          "description": "Read access to check membership",
          "source": "internal leaf access"
        },
        {
          "name": "messages",
          "type": "Database",
          "description": "Write access to store message",
          "source": "internal leaf access"
        }
      ],
      "outputs": [
        {
          "name": "send_result",
          "type": "dict",
          "description": "Success flag, message data, and list of members to notify",
          "consumer": "parent"
        }
      ],
      "signature": "def SendMessage(message_data: dict, channels: Database, messages: Database) -> dict"
    },
    {
      "name": "GetHistory",
      "purpose": "Execute the 'history' command: retrieve last 100 messages from a channel sorted by timestamp descending",
      "behavior": "Query messages store for all messages with given channel_id, sort by timestamp descending, limit to 100, return list.",
      "boundary": {
        "in_scope": [
          "message retrieval",
          "sorting",
          "limiting"
        ],
        "out_of_scope": [
          "membership check",
          "other commands"
        ]
      },
      "preconditions": [
        "command is 'history'",
        "channel_id is provided"
      ],
      "postconditions": [
        "Messages returned sorted by time"
      ],
      "guarantees": [
        "Returns at most 100 messages"
      ],
      "composition_role": "query",
      "stop_decompose": false,
      "stop_reason": "",
      "inputs": [
        {
          "name": "message_data",
          "type": "dict",
          "description": "Contains channel_id",
          "source": "parent input"
        },
        {
          "name": "messages",
          "type": "Database",
          "description": "Read access to query messages",
          "source": "internal leaf access"
        }
      ],
      "outputs": [
        {
          "name": "history_result",
          "type": "dict",
          "description": "List of up to 100 messages with content, user_id, timestamp",
          "consumer": "parent"
        }
      ],
      "signature": "def GetHistory(message_data: dict, messages: Database) -> dict"
    },
    {
      "name": "CreateChannel",
      "purpose": "Execute the 'create_channel' command: create new channel with unique name, set creator as first member",
      "behavior": "Check if channel name already exists in channels store. If yes, return error. Generate new channel_id, store channel with name, members=[user_id], created_by=user_id.",
      "boundary": {
        "in_scope": [
          "name uniqueness check",
          "channel creation",
          "member initialization"
        ],
        "out_of_scope": [
          "other commands",
          "message storage"
        ]
      },
      "preconditions": [
        "command is 'create_channel'",
        "channel_name is unique"
      ],
      "postconditions": [
        "New channel exists in store",
        "Creator is member"
      ],
      "guarantees": [
        "Channel name is unique"
      ],
      "composition_role": "mutate",
      "stop_decompose": false,
      "stop_reason": "",
      "inputs": [
        {
          "name": "message_data",
          "type": "dict",
          "description": "Contains channel_name, user_id",
          "source": "parent input"
        },
        {
          "name": "channels",
          "type": "Database",
          "description": "Read/write access",
          "source": "internal leaf access"
        }
      ],
      "outputs": [
        {
          "name": "create_result",
          "type": "dict",
          "description": "Success flag and new channel_id",
          "consumer": "parent"
        }
      ],
      "signature": "def CreateChannel(message_data: dict, channels: Database) -> dict"
    },
    {
      "name": "JoinChannel",
      "purpose": "Execute the 'join' command: add user to channel member list if not already a member",
      "behavior": "Check if user_id is already in channel's members list. If yes, return error. Otherwise, append user_id to members list and update channels store.",
      "boundary": {
        "in_scope": [
          "membership check",
          "member addition"
        ],
        "out_of_scope": [
          "other commands",
          "message retrieval"
        ]
      },
      "preconditions": [
        "command is 'join'",
        "user is not already a member"
      ],
      "postconditions": [
        "User added to channel members"
      ],
      "guarantees": [
        "No duplicate membership"
      ],
      "composition_role": "mutate",
      "stop_decompose": false,
      "stop_reason": "",
      "inputs": [
        {
          "name": "message_data",
          "type": "dict",
          "description": "Contains channel_id, user_id",
          "source": "parent input"
        },
        {
          "name": "channels",
          "type": "Database",
          "description": "Read/write access",
          "source": "internal leaf access"
        }
      ],
      "outputs": [
        {
          "name": "join_result",
          "type": "dict",
          "description": "Success flag and updated member count",
          "consumer": "parent"
        }
      ],
      "signature": "def JoinChannel(message_data: dict, channels: Database) -> dict"
    }
  ],
  "interface_preservation": {
    "parent_inputs_covered_by": {
      "command": "ValidateCommand",
      "message_data": "ValidateCommand"
    },
    "parent_outputs_produced_by": {
      "message_result": "SendMessage, GetHistory, CreateChannel, JoinChannel"
    }
  },
  "dataflow_edges": [
    {
      "from_node": "parent",
      "from_output": "command",
      "to_node": "ValidateCommand",
      "to_input": "command",
      "note": "Pass command for validation"
    },
    {
      "from_node": "parent",
      "from_output": "message_data",
      "to_node": "ValidateCommand",
      "to_input": "message_data",
      "note": "Pass message_data for validation"
    },
    {
      "from_node": "ValidateCommand",
      "from_output": "validation_result",
      "to_node": "parent",
      "to_input": "message_result",
      "note": "Return validation result to parent"
    },
    {
      "from_node": "parent",
      "from_output": "message_data",
      "to_node": "SendMessage",
      "to_input": "message_data",
      "note": "Pass message_data when command is 'send'"
    },
    {
      "from_node": "parent",
      "from_output": "message_data",
      "to_node": "GetHistory",
      "to_input": "message_data",
      "note": "Pass message_data when command is 'history'"
    },
    {
      "from_node": "parent",
      "from_output": "message_data",
      "to_node": "CreateChannel",
      "to_input": "message_data",
      "note": "Pass message_data when command is 'create_channel'"
    },
    {
      "from_node": "parent",
      "from_output": "message_data",
      "to_node": "JoinChannel",
      "to_input": "message_data",
      "note": "Pass message_data when command is 'join'"
    },
    {
      "from_node": "SendMessage",
      "from_output": "send_result",
      "to_node": "parent",
      "to_input": "message_result",
      "note": "Return send result to parent"
    },
    {
      "from_node": "GetHistory",
      "from_output": "history_result",
      "to_node": "parent",
      "to_input": "message_result",
      "note": "Return history result to parent"
    },
    {
      "from_node": "CreateChannel",
      "from_output": "create_result",
      "to_node": "parent",
      "to_input": "message_result",
      "note": "Return create result to parent"
    },
    {
      "from_node": "JoinChannel",
      "from_output": "join_result",
      "to_node": "parent",
      "to_input": "message_result",
      "note": "Return join result to parent"
    }
  ]
}