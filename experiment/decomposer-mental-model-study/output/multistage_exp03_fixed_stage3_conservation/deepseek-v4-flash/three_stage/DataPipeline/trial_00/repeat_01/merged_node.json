[
  {
    "name": "IngestData",
    "purpose": "Read raw data from source, parse records, store in raw_data, and log ingestion",
    "behavior": "Based on source type, read from CSV/JSON/API, parse into records, write to raw_data, and append log entry to pipeline_log",
    "boundary": {
      "in_scope": [
        "reading source",
        "parsing records",
        "storing to raw_data",
        "logging ingestion"
      ],
      "out_of_scope": [
        "transformation",
        "validation",
        "export"
      ]
    },
    "semantic_inputs": [
      {
        "name": "source",
        "description": "Source configuration with type and path_or_url",
        "source": "parent input (pipeline_request.source)"
      }
    ],
    "semantic_outputs": [
      {
        "name": "ingest_result",
        "description": "Dict with success, records_processed, errors, and raw_data reference",
        "consumer": "parent"
      }
    ],
    "preconditions": [
      "source is valid and accessible"
    ],
    "postconditions": [
      "raw_data populated with parsed records",
      "pipeline_log updated with ingest step"
    ],
    "guarantees": [
      "logs errors without crashing",
      "returns count of records ingested"
    ],
    "composition_role": "execute",
    "stop_decompose": false,
    "stop_reason": "",
    "inputs": [
      {
        "name": "source",
        "type": "dict",
        "description": "Source configuration with type and path_or_url",
        "source": "parent input (pipeline_request.source)"
      }
    ],
    "outputs": [
      {
        "name": "ingest_result",
        "type": "dict",
        "description": "Dict with success, records_processed, errors, and raw_data reference",
        "consumer": "parent"
      }
    ],
    "signature": "def IngestData(source: dict) -> dict",
    "global_vars": [
      {
        "variable": "raw_data",
        "op": "write",
        "description": "Write parsed records to raw_data store"
      },
      {
        "variable": "pipeline_log",
        "op": "write",
        "description": "Append ingestion log entry"
      }
    ],
    "data_operations": [
      {
        "source_name": "raw_data",
        "operation_type": "write",
        "description": "Store parsed raw records"
      },
      {
        "source_name": "pipeline_log",
        "operation_type": "write",
        "description": "Log ingestion step"
      }
    ],
    "requested_capabilities": [
      "database.write",
      "database.append"
    ],
    "constraints": [
      {
        "constraint_id": "C-001",
        "description": "Must handle malformed source records without crashing"
      },
      {
        "constraint_id": "C-002",
        "description": "Must log errors for each failed record"
      }
    ],
    "acceptance_criteria": [
      {
        "ac_id": "AC-001",
        "description": "All valid records from source are written to raw_data"
      },
      {
        "ac_id": "AC-002",
        "description": "pipeline_log contains an entry for the ingestion step with record count"
      }
    ],
    "traceability": {
      "parent_requirement_ids": [
        "FR-001"
      ]
    },
    "node_type": "atomic_operation"
  },
