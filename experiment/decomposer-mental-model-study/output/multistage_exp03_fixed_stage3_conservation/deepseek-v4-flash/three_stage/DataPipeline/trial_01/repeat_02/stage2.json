{
  "children": [
    {
      "name": "IngestData",
      "purpose": "Read raw data from source, parse records, store in raw_data, and log ingestion",
      "behavior": "Based on source type, read from CSV/JSON/API, parse into records, store in raw_data, and append log entry",
      "boundary": {
        "in_scope": [
          "reading source",
          "parsing records",
          "storing to raw_data",
          "logging ingestion"
        ],
        "out_of_scope": [
          "transformation",
          "validation",
          "export"
        ]
      },
      "preconditions": [
        "pipeline_request.action == 'ingest'",
        "source is valid"
      ],
      "postconditions": [
        "raw_data contains ingested records",
        "pipeline_log has ingestion entry"
      ],
      "guarantees": [
        "records are parsed",
        "errors are captured"
      ],
      "composition_role": "execute",
      "stop_decompose": false,
      "stop_reason": "",
      "inputs": [
        {
          "name": "pipeline_request",
          "type": "dict",
          "description": "JSON with action, source, transform_config",
          "source": "parent input"
        },
        {
          "name": "raw_data",
          "type": "database",
          "description": "Data store for raw records",
          "source": "internal leaf access"
        }
      ],
      "outputs": [
        {
          "name": "ingest_result",
          "type": "dict",
          "description": "Result with success, records_processed, errors, raw_records",
          "consumer": "parent"
        }
      ],
      "signature": "def IngestData(pipeline_request: dict, raw_data: database) -> dict"
    },
    {
      "name": "TransformData",
      "purpose": "Apply transformation rules to raw_data, store in processed_data, skip malformed records",
      "behavior": "Read raw_data, apply each rule to each record, skip and log malformed records, store valid results in processed_data",
      "boundary": {
        "in_scope": [
          "reading raw_data",
          "applying transformation rules",
          "skipping malformed records",
          "storing to processed_data"
        ],
        "out_of_scope": [
          "ingestion",
          "validation",
          "export"
        ]
      },
      "preconditions": [
        "pipeline_request.action == 'transform'",
        "raw_data is populated"
      ],
      "postconditions": [
        "processed_data contains transformed records",
        "malformed records are logged"
      ],
      "guarantees": [
        "transformation rules applied",
        "errors captured"
      ],
      "composition_role": "transform",
      "stop_decompose": false,
      "stop_reason": "",
      "inputs": [
        {
          "name": "pipeline_request",
          "type": "dict",
          "description": "JSON with action, source, transform_config",
          "source": "parent input"
        },
        {
          "name": "raw_data",
          "type": "database",
          "description": "Data store for raw records",
          "source": "internal leaf access"
        }
      ],
      "outputs": [
        {
          "name": "transform_result",
          "type": "dict",
          "description": "Result with success, records_processed, errors, processed_records",
          "consumer": "parent"
        }
      ],
      "signature": "def TransformData(pipeline_request: dict, raw_data: database) -> dict"
    },
    {
      "name": "ValidateData",
      "purpose": "Check processed_data against quality rules, mark invalid records, compute quality_score",
      "behavior": "Read processed_data, apply quality rules to each record, compute quality_score, mark invalid records, store results back to processed_data",
      "boundary": {
        "in_scope": [
          "reading processed_data",
          "applying quality rules",
          "computing quality_score",
          "marking invalid records"
        ],
        "out_of_scope": [
          "ingestion",
          "transformation",
          "export"
        ]
      },
      "preconditions": [
        "pipeline_request.action == 'validate'",
        "processed_data is populated"
      ],
      "postconditions": [
        "processed_data has quality_score per record",
        "invalid records marked"
      ],
      "guarantees": [
        "quality_score computed",
        "errors captured"
      ],
      "composition_role": "validate",
      "stop_decompose": false,
      "stop_reason": "",
      "inputs": [
        {
          "name": "pipeline_request",
          "type": "dict",
          "description": "JSON with action, source, transform_config",
          "source": "parent input"
        },
        {
          "name": "processed_data",
          "type": "database",
          "description": "Data store for processed records",
          "source": "internal leaf access"
        }
      ],
      "outputs": [
        {
          "name": "validate_result",
          "type": "dict",
          "description": "Result with success, records_processed, errors, validated_records",
          "consumer": "parent"
        }
      ],
      "signature": "def ValidateData(pipeline_request: dict, processed_data: database) -> dict"
    },
    {
      "name": "ExportData",
      "purpose": "Format validated records as output and log export",
      "behavior": "Read processed_data, filter only validated records, format as CSV or JSON, return as data list, log export",
      "boundary": {
        "in_scope": [
          "reading processed_data",
          "filtering validated records",
          "formatting output",
          "logging export"
        ],
        "out_of_scope": [
          "ingestion",
          "transformation",
          "validation"
        ]
      },
      "preconditions": [
        "pipeline_request.action == 'export'",
        "processed_data is populated"
      ],
      "postconditions": [
        "output data contains only validated records",
        "pipeline_log has export entry"
      ],
      "guarantees": [
        "formatting correct",
        "errors captured"
      ],
      "composition_role": "execute",
      "stop_decompose": false,
      "stop_reason": "",
      "inputs": [
        {
          "name": "pipeline_request",
          "type": "dict",
          "description": "JSON with action, source, transform_config",
          "source": "parent input"
        },
        {
          "name": "processed_data",
          "type": "database",
          "description": "Data store for processed records",
          "source": "internal leaf access"
        }
      ],
      "outputs": [
        {
          "name": "export_result",
          "type": "dict",
          "description": "Result with success, records_processed, errors, data",
          "consumer": "parent"
        }
      ],
      "signature": "def ExportData(pipeline_request: dict, processed_data: database) -> dict"
    }
  ],
  "interface_preservation": {
    "parent_inputs_covered_by": {
      "pipeline_request": [
        "IngestData",
        "TransformData",
        "ValidateData",
        "ExportData"
      ]
    },
    "parent_outputs_produced_by": {
      "pipeline_result": [
        "IngestData",
        "TransformData",
        "ValidateData",
        "ExportData"
      ]
    }
  },
  "dataflow_edges": [
    {
      "from_node": "parent",
      "from_output": "pipeline_request",
      "to_node": "IngestData",
      "to_input": "pipeline_request",
      "note": "parent dispatches based on action"
    },
    {
      "from_node": "IngestData",
      "from_output": "ingest_result",
      "to_node": "parent",
      "to_input": "pipeline_result",
      "note": "returns result to parent"
    },
    {
      "from_node": "parent",
      "from_output": "pipeline_request",
      "to_node": "TransformData",
      "to_input": "pipeline_request",
      "note": "parent dispatches based on action"
    },
    {
      "from_node": "TransformData",
      "from_output": "transform_result",
      "to_node": "parent",
      "to_input": "pipeline_result",
      "note": "returns result to parent"
    },
    {
      "from_node": "parent",
      "from_output": "pipeline_request",
      "to_node": "ValidateData",
      "to_input": "pipeline_request",
      "note": "parent dispatches based on action"
    },
    {
      "from_node": "ValidateData",
      "from_output": "validate_result",
      "to_node": "parent",
      "to_input": "pipeline_result",
      "note": "returns result to parent"
    },
    {
      "from_node": "parent",
      "from_output": "pipeline_request",
      "to_node": "ExportData",
      "to_input": "pipeline_request",
      "note": "parent dispatches based on action"
    },
    {
      "from_node": "ExportData",
      "from_output": "export_result",
      "to_node": "parent",
      "to_input": "pipeline_result",
      "note": "returns result to parent"
    }
  ]
}