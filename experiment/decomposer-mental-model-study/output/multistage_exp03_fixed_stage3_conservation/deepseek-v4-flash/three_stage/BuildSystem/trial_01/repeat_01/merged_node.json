[
  {
    "name": "ValidateBuildRequest",
    "purpose": "Validate the incoming build_request for required fields and business rules",
    "behavior": "Check action is one of trigger/status/list/cancel; for trigger ensure repo and config present; for status/cancel ensure build_id present; enforce one build per repo+branch constraint for trigger",
    "boundary": {
      "in_scope": [
        "validation of input fields",
        "checking business constraints"
      ],
      "out_of_scope": [
        "executing any build action",
        "modifying state"
      ]
    },
    "semantic_inputs": [
      {
        "name": "build_request",
        "description": "the incoming request JSON",
        "source": "parent input"
      },
      {
        "name": "builds",
        "description": "current build records to check constraints",
        "source": "internal leaf access"
      }
    ],
    "semantic_outputs": [
      {
        "name": "validated_request",
        "description": "validated request with defaults applied",
        "consumer": "parent"
      },
      {
        "name": "validation_error",
        "description": "error message if validation fails",
        "consumer": "parent"
      }
    ],
    "preconditions": [
      "build_request is a dict"
    ],
    "postconditions": [
      "if valid, validated_request has all required fields"
    ],
    "guarantees": [
      "no side effects on data stores"
    ],
    "composition_role": "validate",
    "stop_decompose": false,
    "stop_reason": "",
    "inputs": [
      {
        "name": "build_request",
        "type": "dict",
        "description": "the incoming request JSON",
        "source": "parent input"
      },
      {
        "name": "builds",
        "type": "Database",
        "description": "current build records to check constraints",
        "source": "internal leaf access"
      }
    ],
    "outputs": [
      {
        "name": "validated_request",
        "type": "dict",
        "description": "validated request with defaults applied",
        "consumer": "parent"
      },
      {
        "name": "validation_error",
        "type": "str",
        "description": "error message if validation fails",
        "consumer": "parent"
      }
    ],
    "signature": "def ValidateBuildRequest(build_request: dict, builds: Database) -> dict",
    "global_vars": [
      {
        "variable": "builds",
        "op": "read",
        "description": "Read builds to check one-build-per-repo-branch constraint"
      }
    ],
    "data_operations": [
      {
        "source_name": "builds",
        "operation_type": "read",
        "description": "Read existing builds to validate constraint"
      }
    ],
    "requested_capabilities": [
      "builds.read"
    ],
    "constraints": [
      {
        "constraint_id": "C-001",
        "description": "Must not modify builds or artifacts during validation"
      }
    ],
    "acceptance_criteria": [
      {
        "ac_id": "AC-001",
        "description": "Returns validated_request with defaults applied for valid input"
      },
      {
        "ac_id": "AC-002",
        "description": "Returns validation_error for invalid input"
      }
    ],
    "traceability": {
      "parent_requirement_ids": [
        "FR-001"
      ]
    },
    "node_type": "pure_function"
  },
  {
    "name": "TriggerBuild",
    "purpose": "Create a new build record, run compile and test steps, package artifacts, update status",
    "behavior": "Insert new build record with status 'running', execute compile step, then test step, on success package artifacts and set status 'completed', on failure set status 'failed'",
    "boundary": {
      "in_scope": [
        "creating build record",
        "running build steps",
        "storing artifacts",
        "updating status"
      ],
      "out_of_scope": [
        "validating request",
        "listing builds",
        "cancelling builds"
      ]
    },
    "semantic_inputs": [
      {
        "name": "validated_request",
        "description": "validated trigger request with repo, branch, config",
        "source": "parent input"
      },
      {
        "name": "builds",
        "description": "build records store",
        "source": "internal leaf access"
      },
      {
        "name": "artifacts",
        "description": "artifacts store",
        "source": "internal leaf access"
      }
    ],
    "semantic_outputs": [
      {
        "name": "build_result",
        "description": "result with build_id, status, logs",
        "consumer": "parent"
      }
    ],
    "preconditions": [
      "validated_request.action == 'trigger'",
      "no other running build for same repo+branch"
    ],
    "postconditions": [
      "build record created with final status",
      "artifacts stored if build succeeded"
    ],
    "guarantees": [
      "logs stored incrementally",
      "only one build per repo+branch runs at a time"
    ],
    "composition_role": "execute",
    "stop_decompose": false,
    "stop_reason": "",
    "inputs": [
      {
        "name": "validated_request",
        "type": "dict",
        "description": "validated trigger request with repo, branch, config",
        "source": "parent input"
      },
      {
        "name": "builds",
        "type": "Database",
        "description": "build records store",
        "source": "internal leaf access"
      },
      {
        "name": "artifacts",
        "type": "Database",
        "description": "artifacts store",
        "source": "internal leaf access"
      }
    ],
    "outputs": [
      {
        "name": "build_result",
        "type": "dict",
        "description": "result with build_id, status, logs",
        "consumer": "parent"
      }
    ],
    "signature": "def TriggerBuild(validated_request: dict, builds: Database, artifacts: Database) -> dict",
    "global_vars": [
      {
        "variable": "builds",
        "op": "read_write",
        "description": "Create new build record and update its status"
      },
      {
        "variable": "artifacts",
        "op": "read_write",
        "description": "Store build artifacts on success"
      }
    ],
    "data_operations": [
      {
        "source_name": "builds",
        "operation_type": "read_write",
        "description": "Insert build record and update status"
      },
      {
        "source_name": "artifacts",
        "operation_type": "read_write",
        "description": "Store packaged artifacts"
      }
    ],
    "requested_capabilities": [
      "builds.read",
      "builds.write",
      "artifacts.read",
      "artifacts.write"
    ],
    "constraints": [
      {
        "constraint_id": "C-002",
        "description": "Must not modify builds or artifacts outside of trigger operation"
      }
    ],
    "acceptance_criteria": [
      {
        "ac_id": "AC-003",
        "description": "Creates build record with initial status 'running'"
      },
      {
        "ac_id": "AC-004",
        "description": "Updates build status to 'completed' on success, 'failed' on failure"
      },
      {
        "ac_id": "AC-005",
        "description": "Stores artifacts on successful build"
      }
    ],
    "traceability": {
      "parent_requirement_ids": [
        "FR-002"
      ]
    },
    "node_type": "atomic_operation"
  },
