        "description": "Read channel data to check if user is a member"
      }
    ],
    "requested_capabilities": [
      "database.channels.read"
    ],
    "constraints": [
      {
        "constraint_id": "C-001",
        "description": "Must not modify any data store during validation"
      }
    ],
    "acceptance_criteria": [
