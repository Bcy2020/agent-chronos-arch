    "behavior": "Look up build by build_id in builds store, return its status and logs",
    "boundary": {
      "in_scope": [
        "build lookup",
        "status retrieval",
        "log retrieval"
      ],
      "out_of_scope": [
        "build creation",
        "build listing",
        "build cancellation"
      ]
    },
    "semantic_inputs": [
      {
        "name": "build_request",
        "description": "JSON with action='status', build_id",
        "source": "parent input"
      }
    ],
    "semantic_outputs": [
      {
        "name": "build_result",
        "description": "JSON with success, build_id, status, logs",
        "consumer": "parent"
      }
    ],
    "preconditions": [
      "Build exists"
    ],
    "postconditions": [
      "No state change"
    ],
    "guarantees": [
