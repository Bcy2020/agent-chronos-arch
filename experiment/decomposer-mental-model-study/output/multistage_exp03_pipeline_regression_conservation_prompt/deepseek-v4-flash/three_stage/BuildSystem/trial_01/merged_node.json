    ],
    "composition_role": "query",
    "stop_decompose": false,
    "stop_reason": "",
    "inputs": [
      {
        "name": "build_id",
        "type": "str",
        "description": "Unique build identifier",
        "source": "parent input build_request.build_id"
      }
    ],
    "outputs": [
      {
        "name": "build_result",
        "type": "dict",
        "description": "JSON with success, build_id, status, logs",
        "consumer": "parent"
      }
    ],
    "signature": "def CheckBuildStatus(build_id: str) -> dict",
    "global_vars": [
      {
        "variable": "builds",
        "op": "read",
        "description": "Read build record by build_id"
      }
    ],
    "data_operations": [
      {
        "source_name": "builds",
        "operation_type": "read",
        "description": "Lookup build by build_id and return status and logs"
      }
    ],
    "requested_capabilities": [
      "builds.read"
    ],
    "constraints": [
      {
        "constraint_id": "C-003",
        "description": "Must return existing build data or error if build_id not found"
      }
    ],
    "acceptance_criteria": [
      {
        "ac_id": "AC-005",
        "description": "Returns status and logs for valid build_id"
      },
      {
        "ac_id": "AC-006",
        "description": "Returns error for non-existent build_id"
      }
    ],
    "traceability": {
      "parent_requirement_ids": [
        "FR-002"
      ]
    },
    "node_type": "pure_function"
  },
  {
