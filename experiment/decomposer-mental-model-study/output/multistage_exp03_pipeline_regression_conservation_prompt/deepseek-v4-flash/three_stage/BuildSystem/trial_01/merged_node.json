  },
  {
    "name": "CancelBuild",
    "purpose": "Stop a running build and update its status to 'cancelled'",
    "behavior": "Look up build by build_id, if status is 'running', stop the build process, update status to 'cancelled', store cancellation log; if already completed, no-op",
    "boundary": {
      "in_scope": [
        "build lookup",
        "build cancellation",
        "status update",
        "log append"
      ],
      "out_of_scope": [
        "build creation",
        "status retrieval",
        "build listing"
      ]
    },
    "semantic_inputs": [
      {
        "name": "build_request",
        "description": "JSON with action='cancel', build_id",
        "source": "parent input"
      }
    ],
    "semantic_outputs": [
      {
        "name": "build_result",
        "description": "JSON with success, build_id, status, logs",
        "consumer": "parent"
      }
    ],
    "preconditions": [
      "Build exists"
    ],
    "postconditions": [
      "If build was running, status changed to 'cancelled'",
      "Logs updated"
    ],
    "guarantees": [
      "Cancelling a completed build is a no-op"
    ],
    "composition_role": "mutate",
    "stop_decompose": false,
    "stop_reason": "",
    "inputs": [
      {
        "name": "build_id",
        "type": "str",
        "description": "Unique build identifier",
        "source": "parent input build_request.build_id"
      }
    ],
    "outputs": [
      {
        "name": "build_result",
        "type": "dict",
        "description": "JSON with success, build_id, status, logs",
        "consumer": "parent"
      }
    ],
    "signature": "def CancelBuild(build_id: str) -> dict",
    "global_vars": [
      {
        "variable": "builds",
        "op": "read_write",
        "description": "Read build record, update status to cancelled, append cancellation log"
      }
    ],
    "data_operations": [
      {
        "source_name": "builds",
        "operation_type": "read_write",
        "description": "Lookup build by build_id, update status to 'cancelled', append log"
      }
    ],
    "requested_capabilities": [
      "builds.read_write"
    ],
    "constraints": [
      {
        "constraint_id": "C-005",
        "description": "Only running builds can be cancelled; completed builds are no-op"
      },
      {
        "constraint_id": "C-006",
        "description": "Cancellation log must be appended to existing logs"
      }
