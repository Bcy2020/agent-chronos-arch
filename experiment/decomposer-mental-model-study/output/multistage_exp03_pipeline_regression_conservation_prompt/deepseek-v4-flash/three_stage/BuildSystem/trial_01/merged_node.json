        "variable": "builds",
        "op": "read",
        "description": "Query builds with optional filters"
      }
    ],
    "data_operations": [
      {
        "source_name": "builds",
        "operation_type": "read",
        "description": "Query builds store with optional repo/branch/status filters"
      }
    ],
    "requested_capabilities": [
      "builds.read"
    ],
    "constraints": [
