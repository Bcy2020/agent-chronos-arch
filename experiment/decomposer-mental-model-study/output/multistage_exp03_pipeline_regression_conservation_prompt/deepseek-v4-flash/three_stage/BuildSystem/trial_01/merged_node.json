        "ac_id": "AC-009",
        "description": "Running build status changed to 'cancelled'"
      },
      {
        "ac_id": "AC-010",
        "description": "Cancellation log appended"
      },
      {
        "ac_id": "AC-011",
        "description": "Completed build remains unchanged"
      }
    ],
    "traceability": {
      "parent_requirement_ids": [
        "FR-004"
      ]
    },
    "node_type": "atomic_operation"
  }
