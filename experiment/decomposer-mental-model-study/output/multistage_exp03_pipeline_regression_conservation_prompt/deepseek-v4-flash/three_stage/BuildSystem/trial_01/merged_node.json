[
  {
    "name": "TriggerBuild",
    "purpose": "Create a new build record and run the build pipeline for a given repo and branch",
    "behavior": "Check no running build for repo+branch, create build record with status 'running', execute compile step, execute test step, package artifacts, update status to 'success' or 'failed', store logs incrementally",
    "boundary": {
      "in_scope": [
        "build record creation",
        "compile execution",
        "test execution",
        "artifact packaging",
        "status update",
        "log storage"
      ],
      "out_of_scope": [
        "status retrieval",
        "build listing",
        "build cancellation"
      ]
    },
    "semantic_inputs": [
      {
        "name": "build_request",
        "description": "JSON with action='trigger', repo, branch, config",
        "source": "parent input"
      }
    ],
    "semantic_outputs": [
      {
        "name": "build_result",
        "description": "JSON with success, build_id, status, logs",
        "consumer": "parent"
      }
    ],
    "preconditions": [
      "No running build for the same repo+branch"
    ],
    "postconditions": [
      "Build record created with final status",
      "Artifacts stored if successful"
    ],
    "guarantees": [
      "Only one build per repo+branch runs at a time",
      "Logs stored incrementally"
    ],
    "composition_role": "execute",
    "stop_decompose": false,
    "stop_reason": "",
    "inputs": [
      {
        "name": "repo",
        "type": "str",
        "description": "Repository name",
        "source": "parent input build_request.repo"
      },
      {
        "name": "branch",
        "type": "str",
        "description": "Branch name",
        "source": "parent input build_request.branch"
      },
      {
        "name": "config",
        "type": "dict",
        "description": "Build configuration",
        "source": "parent input build_request.config"
      }
    ],
    "outputs": [
      {
        "name": "build_result",
        "type": "dict",
        "description": "JSON with success, build_id, status, logs",
        "consumer": "parent"
      }
    ],
    "signature": "def TriggerBuild(repo: str, branch: str, config: dict) -> dict",
    "global_vars": [
      {
        "variable": "builds",
        "op": "read_write",
        "description": "Create build record, update status, store logs"
      },
      {
        "variable": "artifacts",
        "op": "write",
        "description": "Store packaged artifacts after successful build"
      }
    ],
    "data_operations": [
      {
        "source_name": "builds",
        "operation_type": "read_write",
        "description": "Check for running builds, create record, update status, append logs"
      },
      {
        "source_name": "artifacts",
        "operation_type": "write",
        "description": "Store artifact metadata after packaging"
      }
    ],
    "requested_capabilities": [
      "builds.read_write",
      "artifacts.write"
    ],
    "constraints": [
      {
        "constraint_id": "C-001",
        "description": "Must check no running build for same repo+branch before creating new build"
      },
      {
        "constraint_id": "C-002",
        "description": "Artifacts must be stored only on successful build"
      }
    ],
    "acceptance_criteria": [
      {
        "ac_id": "AC-001",
        "description": "Build record created with status 'running'"
      },
      {
        "ac_id": "AC-002",
        "description": "Final status updated to 'success' or 'failed'"
      },
      {
        "ac_id": "AC-003",
        "description": "Logs stored incrementally during build"
      },
      {
        "ac_id": "AC-004",
        "description": "Artifacts stored if build succeeded"
      }
    ],
    "traceability": {
      "parent_requirement_ids": [
        "FR-001",
        "FR-004"
      ]
    },
    "node_type": "atomic_operation"
  },
  {
    "name": "CheckBuildStatus",
