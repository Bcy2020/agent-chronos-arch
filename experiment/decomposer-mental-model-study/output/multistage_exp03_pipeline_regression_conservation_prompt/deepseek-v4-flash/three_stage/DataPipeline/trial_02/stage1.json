{
  "children": [
    {
      "name": "IngestData",
      "purpose": "Read raw data from source, parse records, store in raw_data, and log ingestion",
      "behavior": "Based on source type (csv/json/api), read from path/url, parse into list of dicts, store in raw_data, and append log entry to pipeline_log",
      "boundary": {
        "in_scope": [
          "reading source",
          "parsing records",
          "storing in raw_data",
          "logging ingestion"
        ],
        "out_of_scope": [
          "transformation",
          "validation",
          "export"
        ]
      },
      "semantic_inputs": [
        {
          "name": "pipeline_request",
          "description": "Contains action='ingest' and source dict",
          "source": "parent input"
        },
        {
          "name": "raw_data",
          "description": "Global data store for raw records",
          "source": "internal leaf access"
        },
        {
          "name": "pipeline_log",
          "description": "Global log store",
          "source": "internal leaf access"
        }
      ],
      "semantic_outputs": [
        {
          "name": "ingest_result",
          "description": "Dict with success, records_processed, errors",
          "consumer": "parent"
        }
      ],
      "preconditions": [
        "pipeline_request action is 'ingest'",
        "source path/url is accessible"
      ],
      "postconditions": [
        "raw_data contains parsed records",
        "pipeline_log has ingestion entry"
      ],
      "guarantees": [
        "Records are parsed into list of dicts",
        "Errors are captured without crashing"
      ],
      "composition_role": "execute",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "TransformData",
      "purpose": "Apply transformation rules to raw_data, store in processed_data, skip malformed records",
      "behavior": "Read raw_data, apply each rule (field, operation, value) to each record, skip records that cause errors, store valid results in processed_data, log transformation",
      "boundary": {
        "in_scope": [
          "applying transformation rules",
          "skipping malformed records",
          "storing in processed_data",
          "logging transformation"
        ],
        "out_of_scope": [
          "ingestion",
          "validation",
          "export"
        ]
      },
      "semantic_inputs": [
        {
          "name": "pipeline_request",
          "description": "Contains action='transform' and transform_config",
          "source": "parent input"
        },
        {
          "name": "raw_data",
          "description": "Global data store with raw records",
          "source": "internal leaf access"
        },
        {
          "name": "pipeline_log",
          "description": "Global log store",
          "source": "internal leaf access"
        }
      ],
      "semantic_outputs": [
        {
          "name": "transform_result",
          "description": "Dict with success, records_processed, errors",
          "consumer": "parent"
        }
      ],
      "preconditions": [
        "pipeline_request action is 'transform'",
        "raw_data is not empty"
      ],
      "postconditions": [
        "processed_data contains transformed records",
        "malformed records are skipped and logged"
      ],
      "guarantees": [
        "Each rule is applied to each record",
        "Errors do not stop processing"
      ],
      "composition_role": "transform",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "ValidateData",
      "purpose": "Check processed_data against quality rules, mark invalid records, compute quality_score",
      "behavior": "Read processed_data, apply quality rules to each record, compute quality_score (e.g., based on missing fields or rule violations), mark invalid records, log validation",
      "boundary": {
        "in_scope": [
          "applying quality rules",
          "computing quality_score",
          "marking invalid records",
          "logging validation"
        ],
        "out_of_scope": [
          "ingestion",
          "transformation",
          "export"
        ]
      },
      "semantic_inputs": [
        {
          "name": "pipeline_request",
          "description": "Contains action='validate'",
          "source": "parent input"
        },
        {
          "name": "processed_data",
          "description": "Global data store with transformed records",
          "source": "internal leaf access"
        },
        {
          "name": "pipeline_log",
          "description": "Global log store",
          "source": "internal leaf access"
        }
      ],
      "semantic_outputs": [
        {
          "name": "validate_result",
          "description": "Dict with success, records_processed, errors, quality_scores",
          "consumer": "parent"
        }
      ],
      "preconditions": [
        "pipeline_request action is 'validate'",
        "processed_data is not empty"
      ],
      "postconditions": [
        "Each record has quality_score",
        "Invalid records are marked"
      ],
      "guarantees": [
        "Quality rules are applied consistently",
        "Scores are computed"
      ],
      "composition_role": "validate",
      "stop_decompose": false,
      "stop_reason": ""
    },
    {
      "name": "ExportData",
      "purpose": "Format validated records as output in requested format, log export",
      "behavior": "Read processed_data, filter only records that passed validation, format as csv or json, store in pipeline_result data field, log export",
      "boundary": {
        "in_scope": [
          "filtering validated records",
          "formatting output",
          "logging export"
        ],
        "out_of_scope": [
          "ingestion",
          "transformation",
          "validation"
        ]
      },
      "semantic_inputs": [
        {
          "name": "pipeline_request",
          "description": "Contains action='export' and export_format",
          "source": "parent input"
        },
        {
          "name": "processed_data",
          "description": "Global data store with validated records",
          "source": "internal leaf access"
        },
        {
          "name": "pipeline_log",
          "description": "Global log store",
          "source": "internal leaf access"
        }
      ],
      "semantic_outputs": [
        {
          "name": "export_result",
          "description": "Dict with success, records_processed, errors, data",
          "consumer": "parent"
        }
      ],
      "preconditions": [
        "pipeline_request action is 'export'",
        "processed_data contains validated records"
      ],
      "postconditions": [
        "Output data is formatted correctly",
        "Only validated records are included"
      ],
      "guarantees": [
        "Format matches export_format",
        "Log entry is created"
      ],
      "composition_role": "execute",
      "stop_decompose": false,
      "stop_reason": ""
    }
  ],
  "decomposition_rationale": "The DataPipeline function block performs four distinct ETL steps (ingest, transform, validate, export) that are sequential and independent. Each child handles one step, using the global data stores and log, and returns results to the parent for aggregation into the final pipeline_result.",
  "orchestration_model": "conditional",
  "dataflow_sketch": [
    {
      "from": "parent",
      "to": "IngestData",
      "data": "pipeline_request (action='ingest')",
      "note": "Parent dispatches based on action"
    },
    {
      "from": "parent",
      "to": "TransformData",
      "data": "pipeline_request (action='transform')",
      "note": "Parent dispatches based on action"
    },
    {
      "from": "parent",
      "to": "ValidateData",
      "data": "pipeline_request (action='validate')",
      "note": "Parent dispatches based on action"
    },
    {
      "from": "parent",
      "to": "ExportData",
      "data": "pipeline_request (action='export')",
      "note": "Parent dispatches based on action"
    },
    {
      "from": "IngestData",
      "to": "parent",
      "data": "ingest_result",
      "note": "Parent aggregates into pipeline_result"
    },
    {
      "from": "TransformData",
      "to": "parent",
      "data": "transform_result",
      "note": "Parent aggregates into pipeline_result"
    },
    {
      "from": "ValidateData",
      "to": "parent",
      "data": "validate_result",
      "note": "Parent aggregates into pipeline_result"
    },
    {
      "from": "ExportData",
      "to": "parent",
      "data": "export_result",
      "note": "Parent aggregates into pipeline_result"
    }
  ]
}