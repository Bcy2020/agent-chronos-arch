      },
      {
        "variable": "pipeline_log",
        "op": "write",
        "description": "Append ingestion log entry"
      }
    ],
    "data_operations": [
      {
        "source_name": "raw_data",
        "operation_type": "write",
        "description": "Store parsed records"
      },
      {
        "source_name": "pipeline_log",
        "operation_type": "write",
        "description": "Log ingestion step"
      }
    ],
    "requested_capabilities": [
      "database.write",
      "database.append"
    ],
    "constraints": [
      {
        "constraint_id": "C-001",
        "description": "Must not modify processed_data or any other global store beyond raw_data and pipeline_log"
      }
    ],
    "acceptance_criteria": [
