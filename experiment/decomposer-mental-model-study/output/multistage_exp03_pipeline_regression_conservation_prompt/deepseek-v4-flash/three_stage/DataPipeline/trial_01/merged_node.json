[
  {
    "name": "IngestData",
    "purpose": "Read raw data from source, parse records, store in raw_data, and log ingestion",
    "behavior": "Reads source config from pipeline_request, fetches data from CSV/JSON/API, parses into records, writes to raw_data, logs step to pipeline_log",
    "boundary": {
      "in_scope": [
        "reading source",
        "parsing records",
        "storing in raw_data",
        "logging ingestion"
      ],
      "out_of_scope": [
        "transformation",
        "validation",
        "export"
      ]
    },
    "semantic_inputs": [
      {
        "name": "pipeline_request",
        "description": "Contains action='ingest' and source config",
        "source": "parent input"
      },
      {
        "name": "raw_data",
        "description": "Data store for raw records",
        "source": "internal leaf access"
      }
    ],
    "semantic_outputs": [
      {
        "name": "ingest_result",
        "description": "Dict with records_processed, errors, and raw_data reference",
        "consumer": "parent"
      }
    ],
    "preconditions": [
      "pipeline_request.action == 'ingest'",
      "source config is valid"
    ],
    "postconditions": [
      "raw_data contains parsed records",
      "pipeline_log has ingestion entry"
    ],
    "guarantees": [
      "All records parsed without crashing",
      "Malformed records logged as errors"
    ],
    "composition_role": "execute",
    "stop_decompose": false,
    "stop_reason": "",
    "inputs": [
      {
        "name": "pipeline_request",
        "type": "dict",
        "description": "JSON with action='ingest' and source config",
        "source": "parent input"
      }
    ],
    "outputs": [
      {
        "name": "ingest_result",
        "type": "dict",
        "description": "JSON with records_processed (int), errors (list), raw_data reference",
        "consumer": "parent"
      }
    ],
    "signature": "def IngestData(pipeline_request: dict) -> dict",
    "global_vars": [
      {
        "variable": "raw_data",
        "op": "write",
        "description": "Write parsed records to raw_data store"
      },
      {
        "variable": "pipeline_log",
        "op": "write",
        "description": "Log ingestion step details"
      }
    ],
    "data_operations": [
      {
        "source_name": "raw_data",
        "operation_type": "write",
        "description": "Store parsed raw records"
      },
      {
        "source_name": "pipeline_log",
        "operation_type": "write",
        "description": "Log ingestion step"
      }
    ],
    "requested_capabilities": [
      "database.write",
      "database.write"
    ],
    "constraints": [
      {
        "constraint_id": "C-001",
        "description": "Must handle malformed records without crashing"
      }
    ],
    "acceptance_criteria": [
      {
        "ac_id": "AC-001",
        "description": "All valid records are written to raw_data"
      },
      {
        "ac_id": "AC-002",
        "description": "Ingestion step is logged in pipeline_log"
      }
    ],
    "traceability": {
      "parent_requirement_ids": [
        "FR-001"
      ]
    },
    "node_type": "atomic_operation"
  },
  {
    "name": "TransformData",
    "purpose": "Apply transformation rules to raw_data, store in processed_data, skip malformed records",
    "behavior": "Reads raw_data and transform_config, applies rules field by field, writes valid results to processed_data, logs step with counts",
    "boundary": {
      "in_scope": [
        "applying transformation rules",
        "skipping malformed records",
        "storing in processed_data",
        "logging transformation"
      ],
      "out_of_scope": [
        "ingestion",
        "validation",
        "export"
      ]
    },
    "semantic_inputs": [
      {
        "name": "pipeline_request",
        "description": "Contains transform_config",
        "source": "parent input"
      },
      {
        "name": "raw_data",
        "description": "Raw records to transform",
        "source": "internal leaf access"
      }
    ],
    "semantic_outputs": [
      {
        "name": "transform_result",
        "description": "Dict with records_processed, errors, and processed_data reference",
        "consumer": "parent"
      }
    ],
    "preconditions": [
      "pipeline_request.action == 'transform'",
      "raw_data is populated"
    ],
    "postconditions": [
      "processed_data contains transformed records",
      "pipeline_log has transformation entry"
    ],
    "guarantees": [
      "Malformed records are skipped without failure",
      "Each record transformed independently"
    ],
    "composition_role": "transform",
    "stop_decompose": false,
    "stop_reason": "",
    "inputs": [
      {
        "name": "pipeline_request",
        "type": "dict",
        "description": "JSON with action='transform' and transform_config",
        "source": "parent input"
      }
    ],
    "outputs": [
      {
        "name": "transform_result",
        "type": "dict",
        "description": "JSON with records_processed (int), errors (list), processed_data reference",
        "consumer": "parent"
      }
    ],
    "signature": "def TransformData(pipeline_request: dict) -> dict",
    "global_vars": [
      {
        "variable": "raw_data",
        "op": "read",
        "description": "Read raw records for transformation"
      },
      {
        "variable": "processed_data",
        "op": "write",
        "description": "Write transformed records to processed_data"
      },
      {
        "variable": "pipeline_log",
        "op": "write",
        "description": "Log transformation step details"
      }
    ],
    "data_operations": [
      {
        "source_name": "raw_data",
        "operation_type": "read",
        "description": "Read raw records"
      },
      {
        "source_name": "processed_data",
        "operation_type": "write",
        "description": "Store transformed records"
      },
      {
        "source_name": "pipeline_log",
        "operation_type": "write",
        "description": "Log transformation step"
      }
    ],
    "requested_capabilities": [
      "database.read",
      "database.write",
      "database.write"
    ],
    "constraints": [
      {
        "constraint_id": "C-002",
        "description": "Malformed records must be skipped without failure"
      }
    ],
    "acceptance_criteria": [
      {
        "ac_id": "AC-003",
        "description": "All valid transformed records are written to processed_data"
      },
      {
        "ac_id": "AC-004",
        "description": "Transformation step is logged in pipeline_log"
      }
    ],
    "traceability": {
      "parent_requirement_ids": [
        "FR-002"
      ]
    },
    "node_type": "atomic_operation"
  },
  {
    "name": "ValidateData",
    "purpose": "Check processed_data against quality rules, assign quality_score, mark invalid records",
    "behavior": "Reads processed_data, applies quality rules (e.g., completeness, range checks), computes quality_score per record, marks invalid records, logs step",
    "boundary": {
      "in_scope": [
        "quality rule checking",
        "quality_score assignment",
        "marking invalid records",
        "logging validation"
      ],
      "out_of_scope": [
        "ingestion",
        "transformation",
        "export"
      ]
    },
    "semantic_inputs": [
      {
        "name": "pipeline_request",
        "description": "May contain quality rules (implicit or from config)",
        "source": "parent input"
      },
      {
        "name": "processed_data",
        "description": "Transformed records to validate",
        "source": "internal leaf access"
      }
    ],
    "semantic_outputs": [
      {
        "name": "validate_result",
        "description": "Dict with records_processed, errors, quality_scores, and updated processed_data",
        "consumer": "parent"
      }
    ],
    "preconditions": [
      "pipeline_request.action == 'validate'",
      "processed_data is populated"
    ],
    "postconditions": [
      "Each record has quality_score",
      "Invalid records marked",
      "pipeline_log has validation entry"
    ],
    "guarantees": [
      "All records evaluated",
      "Quality_score is a float between 0 and 1"
    ],
    "composition_role": "validate",
    "stop_decompose": false,
    "stop_reason": "",
    "inputs": [
      {
        "name": "pipeline_request",
        "type": "dict",
        "description": "JSON with action='validate' (quality rules implicit or from config)",
        "source": "parent input"
      }
    ],
    "outputs": [
      {
        "name": "validate_result",
        "type": "dict",
        "description": "JSON with records_processed (int), errors (list), quality_scores (list of float), updated processed_data reference",
        "consumer": "parent"
      }
    ],
    "signature": "def ValidateData(pipeline_request: dict) -> dict",
    "global_vars": [
      {
        "variable": "processed_data",
        "op": "read_write",
        "description": "Read processed records and update with quality_score and validity marks"
      },
      {
        "variable": "pipeline_log",
        "op": "write",
        "description": "Log validation step details"
      }
    ],
    "data_operations": [
      {
        "source_name": "processed_data",
        "operation_type": "read_write",
        "description": "Read and update records with quality metadata"
      },
      {
        "source_name": "pipeline_log",
        "operation_type": "write",
        "description": "Log validation step"
      }
    ],
    "requested_capabilities": [
      "database.read_write",
      "database.write"
    ],
    "constraints": [
      {
        "constraint_id": "C-003",
        "description": "Must assign quality_score as float between 0 and 1"
      }
    ],
    "acceptance_criteria": [
      {
        "ac_id": "AC-005",
        "description": "All records in processed_data have quality_score and validity marks"
      },
      {
        "ac_id": "AC-006",
        "description": "Validation step is logged in pipeline_log"
      }
    ],
    "traceability": {
      "parent_requirement_ids": [
        "FR-003"
      ]
    },
    "node_type": "atomic_operation"
  },
  {
