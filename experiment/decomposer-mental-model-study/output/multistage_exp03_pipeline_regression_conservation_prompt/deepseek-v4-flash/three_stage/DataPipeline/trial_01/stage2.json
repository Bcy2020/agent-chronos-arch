{
  "children": [
    {
      "name": "IngestData",
      "purpose": "Read raw data from source, parse records, store in raw_data, and log ingestion",
      "behavior": "Reads source config from pipeline_request, fetches data from CSV/JSON/API, parses into records, writes to raw_data, logs step to pipeline_log",
      "boundary": {
        "in_scope": [
          "reading source",
          "parsing records",
          "storing in raw_data",
          "logging ingestion"
        ],
        "out_of_scope": [
          "transformation",
          "validation",
          "export"
        ]
      },
      "preconditions": [
        "pipeline_request.action == 'ingest'",
        "source config is valid"
      ],
      "postconditions": [
        "raw_data contains parsed records",
        "pipeline_log has ingestion entry"
      ],
      "guarantees": [
        "All records parsed without crashing",
        "Malformed records logged as errors"
      ],
      "composition_role": "execute",
      "stop_decompose": false,
      "stop_reason": "",
      "inputs": [
        {
          "name": "pipeline_request",
          "type": "dict",
          "description": "JSON with action='ingest' and source config",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "ingest_result",
          "type": "dict",
          "description": "JSON with records_processed (int), errors (list), raw_data reference",
          "consumer": "parent"
        }
      ],
      "signature": "def IngestData(pipeline_request: dict) -> dict"
    },
    {
      "name": "TransformData",
      "purpose": "Apply transformation rules to raw_data, store in processed_data, skip malformed records",
      "behavior": "Reads raw_data and transform_config, applies rules field by field, writes valid results to processed_data, logs step with counts",
      "boundary": {
        "in_scope": [
          "applying transformation rules",
          "skipping malformed records",
          "storing in processed_data",
          "logging transformation"
        ],
        "out_of_scope": [
          "ingestion",
          "validation",
          "export"
        ]
      },
      "preconditions": [
        "pipeline_request.action == 'transform'",
        "raw_data is populated"
      ],
      "postconditions": [
        "processed_data contains transformed records",
        "pipeline_log has transformation entry"
      ],
      "guarantees": [
        "Malformed records are skipped without failure",
        "Each record transformed independently"
      ],
      "composition_role": "transform",
      "stop_decompose": false,
      "stop_reason": "",
      "inputs": [
        {
          "name": "pipeline_request",
          "type": "dict",
          "description": "JSON with action='transform' and transform_config",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "transform_result",
          "type": "dict",
          "description": "JSON with records_processed (int), errors (list), processed_data reference",
          "consumer": "parent"
        }
      ],
      "signature": "def TransformData(pipeline_request: dict) -> dict"
    },
    {
      "name": "ValidateData",
      "purpose": "Check processed_data against quality rules, assign quality_score, mark invalid records",
      "behavior": "Reads processed_data, applies quality rules (e.g., completeness, range checks), computes quality_score per record, marks invalid records, logs step",
      "boundary": {
        "in_scope": [
          "quality rule checking",
          "quality_score assignment",
          "marking invalid records",
          "logging validation"
        ],
        "out_of_scope": [
          "ingestion",
          "transformation",
          "export"
        ]
      },
      "preconditions": [
        "pipeline_request.action == 'validate'",
        "processed_data is populated"
      ],
      "postconditions": [
        "Each record has quality_score",
        "Invalid records marked",
        "pipeline_log has validation entry"
      ],
      "guarantees": [
        "All records evaluated",
        "Quality_score is a float between 0 and 1"
      ],
      "composition_role": "validate",
      "stop_decompose": false,
      "stop_reason": "",
      "inputs": [
        {
          "name": "pipeline_request",
          "type": "dict",
          "description": "JSON with action='validate' (quality rules implicit or from config)",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "validate_result",
          "type": "dict",
          "description": "JSON with records_processed (int), errors (list), quality_scores (list of float), updated processed_data reference",
          "consumer": "parent"
        }
      ],
      "signature": "def ValidateData(pipeline_request: dict) -> dict"
    },
    {
      "name": "ExportData",
      "purpose": "Format validated records as output in requested format, log export",
      "behavior": "Reads processed_data, filters to only validated records, formats as CSV or JSON, writes to pipeline_result, logs step",
      "boundary": {
        "in_scope": [
          "filtering validated records",
          "formatting output",
          "logging export"
        ],
        "out_of_scope": [
          "ingestion",
          "transformation",
          "validation"
        ]
      },
      "preconditions": [
        "pipeline_request.action == 'export'",
        "processed_data contains validated records"
      ],
      "postconditions": [
        "pipeline_result contains formatted data",
        "pipeline_log has export entry"
      ],
      "guarantees": [
        "Only validated records exported",
        "Output format matches request"
      ],
      "composition_role": "execute",
      "stop_decompose": false,
      "stop_reason": "",
      "inputs": [
        {
          "name": "pipeline_request",
          "type": "dict",
          "description": "JSON with action='export' and export_format (str)",
          "source": "parent input"
        }
      ],
      "outputs": [
        {
          "name": "export_result",
          "type": "dict",
          "description": "JSON with success (bool), records_processed (int), errors (list), data (list of dicts)",
          "consumer": "parent"
        }
      ],
      "signature": "def ExportData(pipeline_request: dict) -> dict"
    }
  ],
  "interface_preservation": {
    "parent_inputs_covered_by": {
      "pipeline_request": [
        "IngestData.pipeline_request",
        "TransformData.pipeline_request",
        "ValidateData.pipeline_request",
        "ExportData.pipeline_request"
      ]
    },
    "parent_outputs_produced_by": {
      "pipeline_result": [
        "ExportData.export_result"
      ]
    }
  },
  "dataflow_edges": [
    {
      "from_node": "parent",
      "from_output": "pipeline_request",
      "to_node": "IngestData",
      "to_input": "pipeline_request",
      "note": "Pass action and source config"
    },
    {
      "from_node": "IngestData",
      "from_output": "ingest_result",
      "to_node": "parent",
      "to_input": "pipeline_result",
      "note": "Return ingestion status (parent may aggregate)"
    },
    {
      "from_node": "parent",
      "from_output": "pipeline_request",
      "to_node": "TransformData",
      "to_input": "pipeline_request",
      "note": "Pass transform_config"
    },
    {
      "from_node": "TransformData",
      "from_output": "transform_result",
      "to_node": "parent",
      "to_input": "pipeline_result",
      "note": "Return transformation status"
    },
    {
      "from_node": "parent",
      "from_output": "pipeline_request",
      "to_node": "ValidateData",
      "to_input": "pipeline_request",
      "note": "Pass validation context"
    },
    {
      "from_node": "ValidateData",
      "from_output": "validate_result",
      "to_node": "parent",
      "to_input": "pipeline_result",
      "note": "Return validation status"
    },
    {
      "from_node": "parent",
      "from_output": "pipeline_request",
      "to_node": "ExportData",
      "to_input": "pipeline_request",
      "note": "Pass export_format"
    },
    {
      "from_node": "ExportData",
      "from_output": "export_result",
      "to_node": "parent",
      "to_input": "pipeline_result",
      "note": "Return final pipeline_result"
    }
  ]
}