[
  {
    "name": "IngestData",
    "purpose": "Read raw data from source and store in raw_data",
    "behavior": "Read from source based on type (csv/json/api), parse records, store in raw_data, log ingestion with counts",
    "boundary": {
      "in_scope": [
        "reading source",
        "parsing records",
        "storing to raw_data",
        "logging ingestion"
      ],
      "out_of_scope": [
        "transformation",
        "validation",
        "export"
      ]
    },
    "semantic_inputs": [
      {
        "name": "pipeline_request",
        "description": "Contains action and source details",
        "source": "parent input"
      }
    ],
    "semantic_outputs": [
      {
        "name": "ingest_result",
        "description": "Success status, records count, errors",
        "consumer": "parent"
      }
    ],
    "preconditions": [
      "pipeline_request.action == 'ingest'",
      "source path/url is accessible"
    ],
    "postconditions": [
      "raw_data populated with parsed records",
      "ingestion logged"
    ],
    "guarantees": [
      "All records from source are stored",
      "Errors are captured without crashing"
    ],
    "composition_role": "execute",
    "stop_decompose": false,
    "stop_reason": "",
    "inputs": [
      {
        "name": "pipeline_request",
        "type": "dict",
        "description": "JSON with action='ingest', source details",
        "source": "parent input"
      }
    ],
    "outputs": [
      {
        "name": "ingest_result",
        "type": "dict",
        "description": "Success status, records count, errors",
        "consumer": "parent"
      }
    ],
    "signature": "def IngestData(pipeline_request: dict) -> dict",
    "global_vars": [
      {
        "variable": "raw_data",
        "op": "write",
        "description": "Store ingested raw records"
      },
      {
        "variable": "pipeline_log",
        "op": "write",
        "description": "Log ingestion step details"
      }
    ],
    "data_operations": [
      {
        "source_name": "raw_data",
        "operation_type": "write",
        "description": "Write ingested records to raw_data store"
      },
      {
        "source_name": "pipeline_log",
        "operation_type": "write",
        "description": "Append log entry for ingestion step"
      }
    ],
    "requested_capabilities": [
      "data_store.raw_data.write",
      "data_store.pipeline_log.write"
    ],
    "constraints": [
      {
        "constraint_id": "C-001",
        "description": "Must handle source read errors gracefully without crashing pipeline"
      }
    ],
    "acceptance_criteria": [
      {
        "ac_id": "AC-001",
        "description": "All records from source are stored in raw_data"
      },
      {
        "ac_id": "AC-002",
        "description": "Ingestion is logged with timestamp, records count, and any errors"
      }
    ],
    "traceability": {
      "parent_requirement_ids": [
        "FR-001"
      ]
    },
    "node_type": "atomic_operation"
  },
