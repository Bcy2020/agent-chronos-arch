[
  {
    "name": "IngestData",
    "purpose": "Read raw data from source, parse records, store in raw_data, and log ingestion",
    "behavior": "Based on source type, read from CSV/JSON/API, parse into records, store in raw_data, and append log entry",
    "boundary": {
      "in_scope": [
        "reading source",
        "parsing records",
        "storing to raw_data",
        "logging ingestion"
      ],
      "out_of_scope": [
        "transformation",
        "validation",
        "export"
      ]
    },
    "semantic_inputs": [
      {
        "name": "pipeline_request",
        "description": "Contains action and source details",
        "source": "parent input"
      },
      {
        "name": "raw_data",
        "description": "Database to store ingested records",
        "source": "internal leaf access"
      }
    ],
    "semantic_outputs": [
      {
        "name": "ingest_result",
        "description": "Dict with success, records_processed, errors, and raw_records list",
        "consumer": "parent"
      }
    ],
    "preconditions": [
      "pipeline_request.action == 'ingest'",
      "source is valid"
    ],
    "postconditions": [
      "raw_data contains ingested records",
      "pipeline_log has ingestion entry"
    ],
    "guarantees": [
      "records are parsed",
      "errors are captured"
    ],
    "composition_role": "execute",
    "stop_decompose": false,
    "stop_reason": "",
    "inputs": [
      {
        "name": "pipeline_request",
        "type": "dict",
        "description": "JSON with action, source, transform_config",
        "source": "parent input"
      },
      {
        "name": "raw_data",
        "type": "database",
        "description": "Data store for raw records",
        "source": "internal leaf access"
      }
    ],
    "outputs": [
      {
        "name": "ingest_result",
        "type": "dict",
        "description": "Result with success, records_processed, errors, raw_records",
        "consumer": "parent"
      }
    ],
    "signature": "def IngestData(pipeline_request: dict, raw_data: database) -> dict",
    "global_vars": [
      {
        "variable": "raw_data",
        "op": "write",
        "description": "Store ingested raw records"
      },
      {
        "variable": "pipeline_log",
        "op": "write",
        "description": "Log ingestion step details"
      }
    ],
    "data_operations": [
      {
        "source_name": "raw_data",
        "operation_type": "write",
        "description": "Write parsed records to raw_data store"
      },
      {
        "source_name": "pipeline_log",
        "operation_type": "write",
        "description": "Append log entry for ingestion step"
      }
    ],
    "requested_capabilities": [
      "database.write",
      "logging.write"
    ],
    "constraints": [
      {
        "constraint_id": "C-001",
        "description": "Must handle source read errors gracefully without crashing pipeline"
      },
      {
        "constraint_id": "C-002",
        "description": "Must parse records according to source format (CSV/JSON/API)"
      }
    ],
    "acceptance_criteria": [
      {
        "ac_id": "AC-001",
        "description": "All records from source are parsed and stored in raw_data"
      },
      {
        "ac_id": "AC-002",
        "description": "Ingestion log entry contains step name, timestamp, records count, and errors"
      }
    ],
    "traceability": {
      "parent_requirement_ids": [
        "FR-001",
        "FR-002"
      ]
    },
    "node_type": "atomic_operation"
  },
