    {
      "name": "PlaceOrder",
      "purpose": "Execute the 'place' command: validate items, charge payment, reserve inventory, create order record, send notification.",
      "behavior": "Sequentially call internal sub-steps: validate items, charge payment, reserve inventory, create order, send notification. On failure, rollback previous steps.",
      "inputs": [
        "order_data: dict"
      ],
      "outputs": [
        "order_result: dict"
      ],
      "signature": "def PlaceOrder(order_data: dict) -> dict",
      "global_vars": [
        {
          "variable": "orders",
          "op": "read_write",
          "description": "Order records database"
        },
        {
          "variable": "inventory",
          "op": "read_write",
          "description": "Inventory database"
        },
        {
          "variable": "payments",
          "op": "read_write",
          "description": "Payment records database"
        }
      ],
      "data_operations": [
        {
          "source_name": "orders",
          "operation_type": "read_write",
          "description": "Create new order record"
        },
        {
          "source_name": "inventory",
          "operation_type": "read_write",
          "description": "Reserve items in inventory"
        },
        {
          "source_name": "payments",
          "operation_type": "read_write",
          "description": "Charge payment and record transaction"
        }
      ],
      "requested_capabilities": [
        "database.orders.read_write",
        "database.inventory.read_write",
        "database.payments.read_write"
      ],
      "constraints": [
        {
          "constraint_id": "C-002",
          "description": "All items must exist in inventory with sufficient stock"
        },
        {
          "constraint_id": "C-003",
          "description": "Payment must be successfully charged before inventory reservation"
        },
        {
          "constraint_id": "C-004",
          "description": "On any failure, all previous operations must be rolled back"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-005",
          "description": "Order is created with status 'placed' when all steps succeed"
        },
        {
          "ac_id": "AC-006",
          "description": "Inventory is reduced by ordered quantities on success"
        },
        {
          "ac_id": "AC-007",
          "description": "Payment is charged on success"
        },
        {
          "ac_id": "AC-008",
          "description": "On failure, no order is created, inventory unchanged, payment not charged"
        }
      ],
      "traceability": {
        "parent_requirement_ids": [
          "FR-002"
        ]
      },
      "node_type": "atomic_operation",
      "stop_decompose": false,
      "stop_reason": "Complex multi-step operation requiring rollback"
    },
    {
      "name": "CancelOrder",
