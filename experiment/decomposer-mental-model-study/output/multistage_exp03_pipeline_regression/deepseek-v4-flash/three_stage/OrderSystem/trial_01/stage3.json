          "variable": "orders",
          "op": "read_write",
          "description": "Order records database"
        },
        {
          "variable": "inventory",
          "op": "read_write",
          "description": "Inventory database"
        },
        {
          "variable": "payments",
          "op": "read_write",
          "description": "Payment records database"
        }
      ],
      "data_operations": [
        {
          "source_name": "orders",
          "operation_type": "read_write",
          "description": "Update order status to cancelled"
        },
        {
          "source_name": "inventory",
          "operation_type": "read_write",
          "description": "Restore reserved inventory"
        },
        {
          "source_name": "payments",
          "operation_type": "read_write",
          "description": "Refund payment and update transaction"
        }
