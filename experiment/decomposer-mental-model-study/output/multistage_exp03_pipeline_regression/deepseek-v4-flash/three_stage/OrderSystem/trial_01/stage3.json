      "behavior": "Check that command is one of 'place', 'cancel', 'track'. Return the command type or raise an error.",
      "inputs": [
        "command: str"
      ],
      "outputs": [
        "command_type: str"
      ],
      "signature": "def ParseCommand(command: str) -> str",
      "global_vars": [],
      "data_operations": [],
      "requested_capabilities": [],
      "constraints": [
        {
          "constraint_id": "C-001",
          "description": "command must be one of 'place', 'cancel', 'track'"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-001",
          "description": "Returns 'place' when command is 'place'"
        },
        {
          "ac_id": "AC-002",
          "description": "Returns 'cancel' when command is 'cancel'"
        },
        {
          "ac_id": "AC-003",
          "description": "Returns 'track' when command is 'track'"
