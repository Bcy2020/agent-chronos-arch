          "description": "Order must exist and not be in 'shipped' or 'cancelled' status"
        },
        {
          "constraint_id": "C-006",
          "description": "Payment must be refunded before inventory restoration"
        },
        {
          "constraint_id": "C-007",
          "description": "On any failure, all previous operations must be rolled back"
        }
      ],
      "acceptance_criteria": [
        {
          "ac_id": "AC-009",
          "description": "Order status is updated to 'cancelled' on success"
        },
        {
          "ac_id": "AC-010",
          "description": "Inventory is restored by previously reserved quantities on success"
        },
        {
          "ac_id": "AC-011",
          "description": "Payment is refunded on success"
